#!/bin/bash
set -e

# dev CLI for ValueOS

COMPOSE_FILE="infra/docker/docker-compose.dev.yml"
# Attempt to find .env.local or fallback to .env
if [ -f ".env.local" ]; then
    ENV_FILE=".env.local"
elif [ -f ".env" ]; then
    ENV_FILE=".env"
else
    ENV_FILE="/dev/null"
fi

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

function print_usage {
  echo "Usage: ./dev <command>"
  echo "Commands:"
  echo "  up      Start development environment"
  echo "  down    Stop development environment"
  echo "  doctor  Diagnose issues"
  echo "  logs    View logs (optional: <service>)"
  echo "  reset   Reset environment (prune volumes)"
  echo "  smoke   Run smoke tests"
}

function check_docker {
  if ! command -v docker &> /dev/null; then
    echo -e "${RED}Error: docker is not installed.${NC}"
    exit 1
  fi
  if ! docker info &> /dev/null; then
    echo -e "${RED}Error: docker daemon is not running.${NC}"
    exit 1
  fi
}

function check_ports {
    echo -e "${YELLOW}Checking ports...${NC}"
    # Source env file to get port vars in a subshell to avoid polluting current shell
    (
        if [ -f "$ENV_FILE" ]; then
            set -a
            source "$ENV_FILE"
            set +a
        fi

        PORTS_TO_CHECK=(
            "${API_PORT:-3001}"
            "${VITE_PORT:-5173}"
            "${POSTGRES_PORT:-5432}"
            "${REDIS_PORT:-6379}"
        )

        for port in "${PORTS_TO_CHECK[@]}"; do
            if lsof -i :"$port" >/dev/null 2>&1; then
                 echo -e "${RED}Error: Port $port is already in use.${NC}"
                 echo -e "${YELLOW}Please stop the process using port $port or change the port in .env.local.${NC}"
                 exit 1
            fi
        done
    )
    if [ $? -ne 0 ]; then
        exit 1
    fi
    echo -e "${GREEN}Ports are available.${NC}"
}

function cmd_up {
  echo -e "${GREEN}Starting development environment...${NC}"
  check_docker

  if [ "$ENV_FILE" == "/dev/null" ]; then
      echo -e "${YELLOW}Warning: No .env.local or .env found. Using defaults.${NC}"
  else
      echo -e "${GREEN}Using environment file: $ENV_FILE${NC}"
  fi

  check_ports

  # Pass env file if it exists (for variable substitution in compose file)
  docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" up -d --remove-orphans

  echo -e "${GREEN}Environment started.${NC}"
  echo "Backend: http://localhost:3001"
  echo "Frontend: http://localhost:5173"
}

function cmd_down {
  echo -e "${GREEN}Stopping development environment...${NC}"
  docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" down
}

function cmd_doctor {
  echo -e "${GREEN}Running diagnostics...${NC}"
  check_docker
  echo "Docker is running."

  if [ -f "scripts/validate-env.js" ]; then
      node scripts/validate-env.js
  else
      echo -e "${YELLOW}scripts/validate-env.js not found. Skipping env validation.${NC}"
  fi
}

function cmd_logs {
  service=$1
  echo -e "${GREEN}Fetching logs...${NC}"
  if [ -z "$service" ]; then
    docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" logs -f
  else
    docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" logs -f "$service"
  fi
}

function cmd_reset {
  echo -e "${YELLOW}Resetting environment...${NC}"
  # If -y or --yes is passed, skip confirmation (useful for scripts)
  if [[ "$1" == "-y" || "$1" == "--yes" ]]; then
      REPLY="y"
  else
      read -p "Are you sure you want to delete all volumes? [y/N] " -n 1 -r
      echo
  fi

  if [[ $REPLY =~ ^[Yy]$ ]]; then
    docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" down -v --remove-orphans
    echo -e "${GREEN}Environment reset.${NC}"
  else
    echo "Cancelled."
  fi
}

function cmd_smoke {
  echo -e "${GREEN}Running smoke tests...${NC}"
  if [ -f "scripts/smoke-test.js" ]; then
      node scripts/smoke-test.js
  else
      echo -e "${RED}scripts/smoke-test.js not found.${NC}"
      exit 1
  fi
}

command=$1
shift

case "$command" in
  up)
    cmd_up
    ;;
  down)
    cmd_down
    ;;
  doctor)
    cmd_doctor
    ;;
  logs)
    cmd_logs "$@"
    ;;
  reset)
    cmd_reset "$@"
    ;;
  smoke)
    cmd_smoke
    ;;
  *)
    print_usage
    exit 1
    ;;
esac
