# ValueVerse Analysis Engine — required environment variables
# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL connection string.
# DB_PASSWORD is used by docker-compose.yml to construct this URL.
# Example: postgresql://analyst:yourpassword@localhost:5432/valueverse
DB_URL=postgresql://analyst:CHANGE_ME@localhost:5432/valueverse

# Password used by docker-compose.yml to configure the postgres service.
# Must match the password in DB_URL above.
DB_PASSWORD=CHANGE_ME

# Together.ai API key (https://api.together.ai)
# Used for LLM-based value tree extraction from SEC filings.
TOGETHER_API_KEY=

# LLM model to use via Together.ai. Defaults to the repo primary model.
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# SEC EDGAR user-agent string. Required by SEC fair-access policy.
# Format: "AppName (contact-url-or-email)"
# See: https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=ValueOS Analysis (+https://example.com/contact)
