{
  "strict_zones": [
    "packages/integrations/src",
    "packages/memory/src",
    "packages/shared/src",
    "packages/sdui-types",
    "packages/mcp"
  ],
  "strict_projects": [
    "packages/integrations/tsconfig.strict-zone.json",
    "packages/memory/tsconfig.strict-zone.json",
    "packages/shared/tsconfig.strict-zone.json",
    "packages/sdui-types/tsconfig.strict-zone.json",
    "packages/mcp/tsconfig.strict-zone.json"
  ],
  "eslint_strict_any_zones": [
    "packages/backend/src/middleware",
    "packages/backend/src/lib/agent-fabric",
    "packages/backend/src/runtime",
    "packages/backend/src/services/billing",
    "packages/backend/src/api/auth.ts",
    "packages/backend/src/api/admin.ts",
    "packages/infra/eso",
    "packages/sdui/src/performance/PerformanceMonitor.ts",
    "packages/sdui/src/migrations.ts",
    "packages/sdui/src/theme/SDUITheme.ts",
    "packages/sdui/src/components/Agent/ConfidenceDisplay.tsx",
    "packages/sdui/src/LazyComponentRegistry.tsx",
    "packages/sdui/src/SchemaStore.ts"
  ],
  "comment": "Strict islands phase 2: expanded to shared, sdui-types, and mcp packages (all at 0 TS errors). ESLint strict-any zones now ratchet production runtime first, then newly cleaned shared-library modules in infra/eso and SDUI.",
  "migration_note": "Expand strict_zones one package at a time after each zone reaches zero TS errors under its strict-zone tsconfig. Expand eslint_strict_any_zones after each debt-reduction PR lowers explicit-any counts in production-runtime and shared-library buckets.",
  "ratchet": {
    "baseline_file": ".quality/tsc-baseline.json",
    "command": "pnpm exec tsc --noEmit --pretty false"
  }
}
