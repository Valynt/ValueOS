{
  "name": "valueos-ui",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev:frontend": "pnpm --filter valynt-app dev",
    "dev:backend": "pnpm --filter @valueos/backend dev",
    "dev": "pnpm run dev:backend & pnpm run dev:frontend",
    "build": "pnpm --filter valynt-app build && pnpm --filter @valueos/backend build",
    "start": "pnpm --filter @valueos/backend start",
    "lint": "turbo run lint",
    "check": "turbo run typecheck",
    "typecheck:signal": "tsx scripts/dx/typecheck-telemetry.ts",
    "ci:governance:self-check": "node scripts/ci/check-canonical-ci-entrypoint.mjs",
    "ci:verify": "pnpm run lint && pnpm run check && pnpm run typecheck:signal --verify && bash scripts/ci/check-legacy-path-imports.sh && pnpm run check:docs:boundaries && pnpm run check:docs:secrets && pnpm run check:docs:date-integrity && pnpm run check:eventing-architecture && pnpm run test && pnpm run ci:governance:self-check && pnpm run check:workflow-pnpm-contract && pnpm run check:any-ratchet && pnpm run check:debt-ratchet && pnpm run build"
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e:gate": "vitest run --config vitest.e2e.config.ts",
    "check:runtime-sentinels": "node scripts/ci/check-runtime-sentinels.mjs",
    "check:browser-provider-secrets": "node scripts/ci/check-browser-provider-secrets.mjs",
    "check:frontend-bundle-service-role": "node scripts/ci/check-frontend-bundle-service-role.mjs",
    "check:backend-service-role-boundaries": "node scripts/ci/check-backend-service-role-boundaries.mjs",
    "check:telemetry-completeness": "node scripts/ci/check-telemetry-completeness.mjs",
    "check:observability-deployment-gates": "node scripts/ci/check-observability-deployment-gates.mjs",
    "check:workflow-package-script-drift": "node scripts/ci/check-workflow-package-script-drift.mjs",
    "check:workflow-pnpm-contract": "node scripts/ci/check-workflow-pnpm-contract.mjs",
    "check:runtime-platform-contract": "node scripts/ci/check-runtime-platform-contract.mjs",
    "check:archived-ecs-guardrails": "node scripts/ci/check-archived-ecs-guardrails.mjs",
    "check:catalog-metadata": "node scripts/ci/check-catalog-metadata.mjs",
    "test:rls": "vitest run --config tests/security/vitest.security.config.ts",
    "db:apply-migrations": "bash scripts/db/apply-migrations.sh",
    "db:migrate": "bash scripts/db/apply-migrations.sh",
    "check:alert-runbooks": "node scripts/ci/check-alert-runbooks.mjs",
    "check:kong-cors-origins": "node scripts/ci/check-kong-cors-origins.mjs --mode=production",
    "check:docs:boundaries": "node scripts/ci/docs-boundary-consistency-lint.mjs",
    "check:docs:consistency": "tsx scripts/ci/check-docs-consistency.ts",
    "check:any-ratchet": "node scripts/ci/any-ratchet.mjs",
    "check:lint-ratchet": "node scripts/ci/lint-ratchet-check.mjs",
    "lint:ci:backend": "mkdir -p artifacts/eslint && pnpm --filter @valueos/backend exec eslint src --max-warnings=99999 --format json --output-file ../../artifacts/eslint/backend.json || true",
    "lint:ci:valynt-app": "mkdir -p artifacts/eslint && pnpm --filter valynt-app exec eslint src --max-warnings=99999 --format json --output-file ../../artifacts/eslint/valynt-app.json || true",
    "lint:ci:shared": "mkdir -p artifacts/eslint && pnpm --filter @valueos/shared exec eslint src --max-warnings=99999 --format json --output-file ../../artifacts/eslint/shared.json || true",
    "dx:check": "node scripts/dx/doctor.js",
    "test:workflow-dag-validation": "SUPABASE_URL=http://127.0.0.1:54321 SUPABASE_KEY=test-key SUPABASE_ANON_KEY=test-key vitest run packages/backend/src/services/workflows/__tests__/WorkflowDAGDefinitions.test.ts packages/backend/src/runtime/execution-runtime/__tests__/WorkflowExecutor.test.ts -t \"WorkflowExecutor._validateWorkflowDAG\"",
    "security:scan": "bash scripts/security/scan.sh",
    "check:workspace-package-governance": "node scripts/ci/check-workspace-package-governance.mjs",
    "check:latency-target-consistency": "node scripts/ci/check-latency-target-consistency.mjs",
    "check:debt-ratchet": "node scripts/ci/debt-ratchet.mjs",
    "typecheck:full": "pnpm run check 2>&1 | head -1000",
    "check:eventing-architecture": "node scripts/ci/check-eventing-architecture-tags.mjs",
    "check:docs:secrets": "node scripts/ci/check-docs-secrets.mjs"
    "check:docs:date-integrity": "node scripts/ci/check-docs-date-integrity.mjs"
  },
