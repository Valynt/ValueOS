{
  "name": "valuecanvas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@9.2.0",
  "scripts": {
    "setup": "node scripts/dx/setup.js",
    "dx": "node scripts/dx/doctor.js --mode local && node scripts/dx/dev.js --mode local",
    "dx:doctor": "node scripts/dx/doctor.js",
    "dx:docker": "node scripts/dx/doctor.js --mode docker && node scripts/dx/dev.js --mode docker",
    "dx:down": "sh -c \"docker compose --env-file deploy/envs/.env.ports -f infra/docker/docker-compose.dev.yml down --remove-orphans || true; rm -f .dx-lock .dx-state.json\"",
    "dx:reset": "sh -c \"docker compose --env-file deploy/envs/.env.ports -f infra/docker/docker-compose.dev.yml down -v --remove-orphans || true; rm -f .dx-lock .dx-state.json\"",
    "dx:clean": "sh -c \"npm run dx:down && docker system prune -f && docker volume prune -f && rm -f .env.local .env .env.ports\"",
    "dx:check": "node scripts/dx/comprehensive-check.js",
    "dx:ps": "docker compose --env-file deploy/envs/.env.ports -f infra/docker/docker-compose.dev.yml ps",
    "dx:logs": "docker compose --env-file deploy/envs/.env.ports -f infra/docker/docker-compose.dev.yml logs -f",
    "dx:caddy:start": "bash scripts/dev-caddy-start.sh",
    "dx:caddy:stop": "bash scripts/dev-caddy-stop.sh",
    "dx:caddy:logs": "docker compose -f infra/docker/docker-compose.dev.yml logs -f caddy",
    "dx:caddy:trust": "docker compose -f infra/docker/docker-compose.dev.yml exec caddy caddy trust",
    "dx:caddy:validate": "docker run --rm -v \"$PWD/infra/caddy:/etc/caddy\" caddy:2-alpine caddy validate --config /etc/caddy/Caddyfile.dev --adapter caddyfile",
    "dx:caddy:reload": "docker compose -f infra/docker/docker-compose.dev.yml exec caddy caddy reload --config /etc/caddy/Caddyfile.dev --adapter caddyfile",
    "dev": "vite --config .config/configs/vite.config.ts",
    "health": "node scripts/dx/health.js",
    "env:validate": "tsx scripts/env-validate.ts",
    "env:dev": "node scripts/setup-dev-env.js",
    "build": "tsc && vite build --config .config/configs/vite.config.ts",
    "build:minimal": "vite build --config .config/configs/vite.config.ts --mode minimal",
    "build:bare": "vite build --config .config/configs/vite.config.ts --mode bare",
    "debug": "vite --config .config/configs/vite.config.ts --mode debug",
    "build:backend": "npx tsc -p .config/configs/tsconfig.backend.json && node -e \"require('fs').mkdirSync('dist/backend',{recursive:true});require('fs').writeFileSync('dist/backend/package.json',JSON.stringify({type:'commonjs'}));\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint:openapi": "node scripts/validate-openapi.mjs",
    "lint:console": "bash scripts/cleanup-console-logs.sh",
    "lint:design-tokens": "node scripts/validate-design-tokens.cjs",
    "preview": "serve dist -s -l 5173",
    "test": "tsx scripts/test-preflight.ts && vitest run --coverage",
    "test:unit": "tsx scripts/test-preflight.ts && vitest run --config .config/configs/vitest.config.unit.ts",
    "test:integration": "TEST_MODE=integration tsx scripts/test-preflight.ts && vitest run --config .config/configs/vitest.integration.config.ts",
    "test:all": "TEST_MODE=all tsx scripts/test-preflight.ts && vitest run --config .config/configs/vitest.config.unit.ts && TEST_MODE=integration vitest run --config .config/configs/vitest.integration.config.ts",
    "test:watch": "vitest --config .config/configs/vitest.config.unit.ts",
    "test:watch:integration": "TEST_MODE=integration vitest --config .config/configs/vitest.integration.config.ts",
    "test:docker": "docker-compose -f infra/docker/docker-compose.test.yml up -d && npm run test:unit && docker-compose -f infra/docker/docker-compose.test.yml down",
    "test:docker:integration": "docker-compose -f infra/docker/docker-compose.test.yml up -d && npm run test:integration && docker-compose -f infra/docker/docker-compose.test.yml down",
    "bias:probes": "tsx scripts/run-bias-probes.ts",
    "typecheck": "tsc --noEmit --project .config/configs/tsconfig.json",
    "test:rls": "supabase test db supabase/tests/database/rls_policies.test.sql supabase/tests/database/multi_tenant_rls.test.sql",
    "test:perf": "vitest run --config .config/configs/vitest.config.ts --include \"test/performance/**/*.test.ts\"",
    "test:testcafe": "testcafe chrome:headless test/testcafe/**/*.test.js",
    "sdk:generate": "openapi-typescript openapi.yaml --output src/api/client/generated-types.ts",
    "db:setup": "bash infra/supabase/setup.sh",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:repair": "supabase migration repair",
    "db:link": "supabase link --project-ref ${SUPABASE_PROJECT_ID}",
    "db:reset": "supabase db reset",
    "seed:demo": "tsx scripts/seed-demo-user.ts",
    "db:types": "supabase gen types typescript --local > src/types/supabase.ts",
    "db:types:remote": "supabase gen types typescript --linked > src/types/supabase.ts",
    "db:test": "supabase test db",
    "db:test:init": "tsx scripts/test-db-init.ts",
    "db:test:seed": "tsx scripts/test-db-seed.ts",
    "db:test:setup": "npm run db:test:init && npm run db:test:seed",
    "test:rls:leakage": "tsx scripts/test-rls-leakage.ts",
    "test:load": "k6 run test/performance/load-test.js",
    "test:a11y": "npx playwright test --config .config/configs/playwright.config.ts test/playwright/accessibility.spec.ts",
    "docker:build": "docker-compose -f infra/docker/docker-compose.dev.yml build",
    "docker:up": "docker-compose -f infra/docker/docker-compose.dev.yml up",
    "docker:up:build": "docker-compose -f infra/docker/docker-compose.dev.yml up --build",
    "docker:down": "docker-compose -f infra/docker/docker-compose.dev.yml down",
    "docker:down:volumes": "docker-compose -f infra/docker/docker-compose.dev.yml down -v",
    "docker:logs": "docker-compose -f infra/docker/docker-compose.dev.yml logs -f",
    "docker:prod:build": "docker-compose -f infra/docker/docker-compose.prod.yml build",
    "docker:prod:up": "docker-compose -f infra/docker/docker-compose.prod.yml up -d",
    "docker:prod:down": "docker-compose -f infra/docker/docker-compose.prod.yml down",
    "docker:prod:logs": "docker-compose -f infra/docker/docker-compose.prod.yml logs -f",
    "analyze:deps": "tsx scripts/analyze-dependencies.ts",
    "analyze:impact": "tsx scripts/analyze-dependencies.ts && cat impact.json",
    "generate:codemap": "tsx scripts/generate-codemap.ts",
    "policy:check": "tsx scripts/architectural-rules.ts",
    "ci:local": "bash .devcontainer/scripts/local-ci.sh",
    "ci:verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "db:validate": "tsx scripts/run-sql-file.ts supabase/tests/database/validate_all_fixes.sql",
    "db:validate-tenant-rls": "bash scripts/validate-tenant-rls.sh",
    "security:scan": "npm audit --audit-level=high",
    "security:scan:snyk": "snyk test --severity-threshold=high",
    "security:scan:all": "npm run security:scan && npm run security:scan:snyk",
    "security:sbom": "npx @cyclonedx/cyclonedx-npm --output-file sbom.json --output-format JSON",
    "storybook:snapshot": "storybook test --watch=false",
    "billing:aggregate": "node -r tsx/cjs src/services/metering/UsageAggregator.ts",
    "billing:submit": "node -r tsx/cjs src/services/metering/UsageSink.ts",
    "billing:setup-stripe": "./infra/billing/stripe-products-setup.sh",
    "billing:test-flow": "./infra/testing/test-billing-flow.sh",
    "backend:dev": "tsx watch src/backend/server.ts",
    "backend:start": "node dist/backend/backend/server.js",
    "test:saml": "playwright test --config .config/configs/playwright.config.ts test/playwright/saml-compliance.spec.ts test/playwright/saml-slo.spec.ts",
    "config:validate": "bash scripts/config-validate.sh",
    "config:diff": "bash scripts/config-diff.sh",
    "migration:safety": "bash scripts/migration-safety.sh",
    "migration:validate": "bash scripts/validate-migrations.sh",
    "migration:rollback": "bash scripts/rollback-migration.sh",
    "test:saml:compliance": "playwright test --config .config/configs/playwright.config.ts test/playwright/saml-compliance.spec.ts",
    "test:saml:slo": "playwright test --config .config/configs/playwright.config.ts test/playwright/saml-slo.spec.ts",
    "test:saml:headed": "playwright test --config .config/configs/playwright.config.ts test/playwright/saml-compliance.spec.ts test/playwright/saml-slo.spec.ts --headed",
    "test:saml:report": "playwright show-report",
    "saml:start": "docker-compose -f infra/docker/compose.saml-test.yml up -d",
    "saml:stop": "docker-compose -f infra/docker/compose.saml-test.yml down",
    "saml:logs": "docker-compose -f infra/docker/compose.saml-test.yml logs -f",
    "saml:certs": "cd test/saml/certs && ./generate-test-certs.sh",
    "test:chaos": "ts-node scripts/chaos-test.ts",
    "chaos:enable": "CHAOS_ENABLED=true npm run dev",
    "dev:fix": "bash scripts/dev-automation/fix-port-forwarding.sh",
    "dev:diagnose": "bash scripts/dev-automation/diagnose-network.sh",
    "dev:test-ports": "bash scripts/dev-automation/test-ports.sh",
    "dx:lint-ports": "node scripts/dx/lint-ports.js",
    "dev:health": "bash scripts/dev-automation/dev-health-check.sh",
    "dev:auto-fix": "bash scripts/dev-automation/auto-fix.sh",
    "chaos:pipeline": "bash scripts/run-chaos-pipeline.sh",
    "ci:bias-probes": "node -r tsx/cjs scripts/run-bias-probes.ts",
    "prepare": "husky",
    "beta:provision": "node -r tsx/cjs scripts/beta-provision.ts",
    "monitor:golden-path": "npx playwright test --config=.config/configs/playwright.monitor.config.ts --reporter=list",
    "staging:build": "NODE_ENV=staging vite build",
    "staging:dev": "NODE_ENV=staging vite",
    "staging:preview": "NODE_ENV=staging vite preview",
    "staging:start": "NODE_ENV=staging docker-compose -f infra/docker/docker-compose.staging.yml up --build",
    "staging:stop": "docker-compose -f infra/docker/docker-compose.staging.yml down",
    "staging:logs": "docker-compose -f infra/docker/docker-compose.staging.yml logs -f",
    "staging:backend": "NODE_ENV=staging tsx watch src/backend/server.ts",
    "staging:test": "NODE_ENV=staging vitest run",
    "staging:deploy": "NODE_ENV=staging npm run build && docker-compose -f infra/docker/docker-compose.staging.yml up -d --build",
    "staging:clean": "docker-compose -f infra/docker/docker-compose.staging.yml down -v --remove-orphans",
    "test:smoke": "playwright test tests/smoke --project=chromium",
    "test:staging": "BASE_URL=$STAGING_URL playwright test tests/smoke",
    "deploy:validate": "bash scripts/validate-deployment.sh",
    "deploy:pre-check": "bash scripts/pre-deployment-checklist.sh",
    "db:backup": "bash scripts/backup-restore.sh backup",
    "db:restore": "bash scripts/backup-restore.sh restore",
    "db:backup:list": "bash scripts/backup-restore.sh list",
    "env:staging": "cp deploy/envs/.env.staging .env.local && echo '✅ Switched to STAGING environment'",
    "env:production": "cp deploy/envs/.env.production .env.local && echo '⚠️ Switched to PRODUCTION environment'",
    "env:status": "grep VITE_SUPABASE_URL .env.local | sed 's/VITE_SUPABASE_URL=/Current environment: /'",
    "db:backup:manual": "mkdir -p backups && npx supabase db dump > backups/backup-$(date +%Y%m%d-%H%M%S).sql && echo 'Backup saved to backups/'",
    "db:push:staging": "npm run env:staging && npx supabase db push",
    "db:push:prod": "npm run env:production && echo '⚠️ PUSHING TO PRODUCTION in 5 seconds (Ctrl+C to cancel)' && sleep 5 && npx supabase db push",
    "dev:staging": "npm run env:staging && npm run dev",
    "dev:production": "npm run env:production && npm run dev",
    "verify:llm-instrumentation": "node -r tsx/cjs scripts/verify-llm-instrumentation.ts",
    "verify:trace-reconstruction": "node -r tsx/cjs scripts/verify/trace_reconstruction.ts",
    "memory:gc": "tsx scripts/run-memory-gc.ts",
    "agent:dev": "tsx scripts/agentic-dev/run-agent-team.ts",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "lint:inline-check": "node scripts/check-inline-styles.cjs",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:inline-check",
    "check:tw-config": "node scripts/validate-tailwind-config.js",
    "build:validate": "node scripts/dx/validate-build.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
