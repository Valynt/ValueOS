{
  "name": "valueos-ui",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev:frontend": "pnpm --filter valynt-app dev",
    "dev:backend": "pnpm --filter @valueos/backend dev",
    "dev": "pnpm run dev:backend & pnpm run dev:frontend",
    "build": "pnpm --filter valynt-app build && pnpm --filter @valueos/backend build",
    "start": "pnpm --filter @valueos/backend start",
    "check": "turbo run typecheck",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e:gate": "pnpm run check:e2e-path && vitest run --config vitest.e2e.config.ts",
    "check:runtime-sentinels": "node scripts/ci/check-runtime-sentinels.mjs",
    "check:no-prod-mocks": "tsx scripts/check-no-prod-mocks.ts",
    "check:browser-provider-secrets": "node scripts/ci/check-browser-provider-secrets.mjs",
    "check:frontend-bundle-service-role": "node scripts/ci/check-frontend-bundle-service-role.mjs",
    "build:failure-packet": "tsx scripts/build-failure-packet.ts",
    "test:infra-pilot": "vitest run --config tests/vitest.shared.config.ts tests/matrix/infra-mode.pilot.test.ts tests/matrix/infra-mode.matrix.test.ts tests/matrix/runInInfraMode.test.ts",
    "test:rls": "vitest run --config tests/security/vitest.security.config.ts && vitest run --reporter=verbose tests/integration/rls_isolation.integration.test.ts tests/integration/rls_leak.test.ts tests/integration/workflow_rls.integration.test.ts tests/integration/supabase_messagebus_rls.integration.test.ts",
    "db:apply-migrations": "bash scripts/db/apply-migrations.sh",
    "check:e2e-path": "node scripts/ci/guard-deprecated-e2e-path.mjs"
  },
  "dependencies": {
