{
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["vitest/globals", "node", "@testing-library/jest-dom"],

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@pages/*": ["./src/pages/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@components/*": ["./src/components/*"],
      "@features/*": ["./src/features/*"],
      "@services/*": ["./src/services/*"],
      "@lib/*": ["./src/lib/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@types/*": ["./src/types/*"],
      "@assets/*": ["./src/assets/*"],
      "@valueos/shared": ["../../packages/shared/src"],
      "@valueos/shared/*": ["../../packages/shared/src/*"],
      "@shared/*": ["../../packages/shared/src/*"],
      "@valueos/sdui-types": ["../../packages/sdui-types/index.ts"],
      "@valueos/sdui": ["../../packages/sdui/src/index.ts"],
      "@valueos/components": ["../../packages/components/index.ts"],
      "@valueos/components/*": ["../../packages/components/*"],
      "@valueos/agents": ["../../packages/agents/index.ts"],
      "@valueos/agents/*": ["../../packages/agents/*/src"],
      "@valueos/infra": ["../../packages/infra/index.ts"],
      "@valueos/memory": ["../../packages/memory/index.ts"],
      "@valueos/integrations": ["../../packages/integrations/index.ts"],
      "@valueos/mcp": ["../../packages/mcp/index.ts"],
      "@backend/*": ["../../packages/backend/src/*"],
      "@sdui/*": ["../../packages/sdui/src/*"],
      "@mcp/*": ["../../packages/mcp/*"],
      "@mcp-common/*": ["../../packages/mcp/common/*"]
    },

    /* Strict TypeScript Configuration */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "alwaysStrict": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitThis": true
  },
  "include": ["src"],
  "exclude": ["src/legacy-merge/**"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
