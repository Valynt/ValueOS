# ValyntApp — copy to .env and fill in values

# Supabase (required)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# App
VITE_RELEASE=dev
VITE_SENTRY_DSN=
VITE_GTM_CONTAINER_ID=

# Feature flags
VITE_ANALYTICS_ENABLED=false
VITE_AGENT_PREVIEW_MODE=false
VITE_ENABLE_AGENT_PLACEHOLDER_MODE=false
VITE_ENABLE_AUDIT_LOGGING=false
VITE_ENABLE_CIRCUIT_BREAKER=true
VITE_ENABLE_CLIENT_LLM_STREAMING=false
VITE_ENABLE_INPUT_SANITIZATION=true
VITE_ENABLE_RATE_LIMITING=true
VITE_ENABLE_SAFE_JSON_PARSER=true
VITE_ENABLE_STATELESS_ORCHESTRATION=false
VITE_ENABLE_TRACE_LOGGING=false
VITE_ENABLE_UNIFIED_ORCHESTRATION=false
VITE_ENABLE_VALUE_COMMITMENT_SERVICE=false
VITE_TENANTS_API_ENABLED=false
VITE_USE_BACKEND_COMMITMENT_API=false
VITE_ENABLE_BILLING_APPROVAL_WORKFLOWS=false
VITE_ENABLE_BILLING_INVOICE_GENERATION=false
VITE_ENABLE_BILLING_OVERAGE_CHARGING=false
VITE_ENABLE_BILLING_USAGE_METERING=false

# Backend proxy target (defaults to http://127.0.0.1:8000)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Vite server (optional overrides)
# VITE_PORT=5173
# VITE_HOST=0.0.0.0
# VITE_HMR_PORT=
# VITE_HMR_CLIENT_PORT=
# VITE_HMR_HOST=
# VITE_HMR_PROTOCOL=
# VITE_USE_POLLING=false

# Observability (optional)
OTEL_SERVICE_NAME=valynt-app
OTEL_EXPORTER_OTLP_ENDPOINT=
OTLP_ENDPOINT=
OTLP_AUTH_TOKEN=
PROMETHEUS_ENDPOINT=
