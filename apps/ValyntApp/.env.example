# Auth0 Configuration
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_AUTH0_REDIRECT_URI=http://localhost:5173

# Public Supabase (anon key is OK to expose)
VITE_SUPABASE_URL=http://localhost:${SUPABASE_API_PORT:-54321}
VITE_SUPABASE_ANON_KEY=

# API base (client-facing)
VITE_API_BASE_URL=/api

# Dev-only proxy target (used by Vite dev server)
# Local (run Vite on your laptop):
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
# Docker (run Vite inside Docker):
# VITE_API_PROXY_TARGET=http://backend:8000

# Feature flags
VITE_TENANTS_API_ENABLED=true
VITE_BILLING_ENABLED=false

# Marketing analytics
VITE_GTM_CONTAINER_ID=

# Academy integration
VITE_ACADEMY_ENABLED=true
VITE_ACADEMY_API_BASE_URL=
VITE_ACADEMY_OAUTH_PORTAL_URL=
VITE_ACADEMY_APP_ID=

# Graceful shutdown timeout (ms)
VITE_SHUTDOWN_TIMEOUT_MS=120000
