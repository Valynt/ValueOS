# ValyntApp/.env.example

# Together.ai API Key (for direct LLM access)
# Get your key at: https://api.together.xyz/settings/api-keys
VITE_TOGETHER_API_KEY=

# Auth0 Configuration
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# Blog (Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

VITE_API_BASE_URL=

# Marketing analytics
VITE_GTM_CONTAINER_ID=

# Academy (VOS Academy integration)
VITE_ACADEMY_ENABLED=true
VITE_ACADEMY_API_BASE_URL=
VITE_ACADEMY_OAUTH_PORTAL_URL=
VITE_ACADEMY_APP_ID=
