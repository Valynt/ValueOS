import { StrictMode } from "react";
import { createRoot } from "react-dom/client";
import "./index.css";

function main() {
  const rootElement = document.getElementById("root");
  if (!rootElement) return;
  
  const root = createRoot(rootElement);
  root.render(
    <StrictMode>
      <div style={{ padding: '20px', color: '#0D9488', fontSize: '24px' }}>
        React Successfully Hydrated!
      </div>
    </StrictMode>
  );
  console.log("App partially hydrated (Minimal Mode)");
}

main();
