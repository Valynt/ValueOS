# VOSAcademy — copy to .env and fill in values

# Supabase (required)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# App identity
VITE_APP_ID=vosacademy
VITE_APP_TITLE=VOS Academy
VITE_APP_LOGO=/logo.png
VITE_RELEASE=dev

# OAuth (required for login)
OAUTH_CLIENT_SECRET=
OAUTH_STATE_SECRET=
OAUTH_ISSUER=
OAUTH_AUDIENCE=
OAUTH_REDIRECT_HOST=http://localhost:5174
OAUTH_ALLOWED_HOSTS=localhost
VOS_ACADEMY_PUBLIC_URL=http://localhost:5174
OWNER_OPENID=

# Database (server-side tRPC handlers)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/valueos

# Redis (optional — used by rate limiting)
REDIS_URL=redis://localhost:6379

# Session JWT
SESSION_JWT_KEYS=
SESSION_JWT_ACTIVE_KID=
SESSION_JWT_ISSUER=vosacademy
SESSION_JWT_AUDIENCE=vosacademy
SESSION_JWT_TENANT=
SESSION_JWT_TTL_SECONDS=86400

# Feature flags
SIMULATION_AI_RECOMMENDATIONS_ENABLED=false
VITE_CONTENT_SOURCE=local
VITE_LOG_LEVEL=info
VITE_OAUTH_PORTAL_URL=http://localhost:5174/api/oauth/login
