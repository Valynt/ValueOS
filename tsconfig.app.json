{
  "extends": "./packages/config-v2/tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "baseUrl": ".",
    "downlevelIteration": true,
    "module": "ESNext",
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    /* Path Aliases */
    "paths": {
      // Existing @ aliases (preferred style)
      "@/*": [
        "./src/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@pages/*": [
        "./src/pages/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@app/*": [
        "./src/app/*"
      ],
      "@shared/*": [
        "./packages/shared/src/*"
      ],
      "@valueos/shared": [
        "./packages/shared/src/index.ts"
      ],
      "@valueos/shared/*": [
        "./packages/shared/src/*"
      ],
      "@valueos/infra": [
        "./packages/infra/index.ts"
      ],
      "@valueos/memory": [
        "./packages/memory/index.ts"
      ],
      "@valueos/memory/*": [
        "./packages/memory/*/index.ts"
      ],
      "@valueos/sdui": [
        "./packages/sdui/src/index.ts"
      ],
      "@valueos/sdui-types": [
        "./packages/sdui-types/index.ts"
      ],
      "@valueos/integrations": [
        "./packages/integrations/index.ts"
      ],
      "@valueos/mcp": [
        "./packages/mcp/index.ts"
      ],

      "@valueos/components": [
        "./packages/components/index.ts"
      ],
      "@backend/*": [
        "./packages/backend/src/*"
      ],
      "@infra/*": [
        "./packages/infra/*"
      ],
      "@memory/*": [
        "./packages/memory/*"
      ],

      "@integrations/*": [
        "./packages/integrations/*"
      ],
      "@mcp/*": [
        "./packages/mcp/*"
      ],
      "@mcp-common/*": [
        "./packages/mcp/common/*"
      ],
      "@sdui/*": [
        "./packages/sdui/src/*"
      ],
      "@valueos/design-system": [
        "./packages/components/design-system/src"
      ],
      "@valueos/design-system/*": [
        "./packages/components/design-system/src/*"
      ],
      // Legacy / non-@ imports observed in the repo (map common bare specifiers)
      "components/*": [
        "./src/components/*",
        "./packages/components/design-system/src/*",
        "./packages/components/design-system/src/primitives/*"
      ],
      "components": [
        "./src/components",
        "./packages/components/design-system/src"
      ],
      "components/ui/*": [
        "./src/components/ui/*",
        "./packages/components/design-system/src/primitives/*"
      ],
      "lib/*": [
        "./src/lib/*",
        "./packages/shared/src/lib/*",
        "./packages/backend/src/lib/*"
      ],
      "hooks/*": [
        "./src/hooks/*",
        "./packages/shared/src/hooks/*"
      ],
      "hooks": [
        "./src/hooks",
        "./packages/shared/src/hooks"
      ],
      // Fallbacks for a few specific missed imports
      "lib/trpc": [
        "./packages/shared/src/lib/trpc",
        "./src/lib/trpc"
      ],
      "lib/utils": [
        "./packages/shared/src/lib/utils",
        "./src/lib/utils"
      ]
    },
    /* Linting - Strict Configuration */
    "strict": true,
    // Strictness rollout plan (detailed milestones in docs/engineering/code-standards.md):
    // Phase 1: Keep strict baseline enabled at root; use per-package override files for temporary exceptions.
    // Phase 2: Ratchet down `any` counts in backend/shared via CI (scripts/ci/any-ratchet.mjs).
    // Phase 3: Remove per-package overrides once strict/noImplicitAny compile cleanly.
    // Disabled: codebase has 400+ violations. Re-enable after fixing array index access patterns.
    "noUncheckedIndexedAccess": false,
    // Disabled temporarily to reduce TS6133 errors - re-enable after debt < 500
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "alwaysStrict": true,
    "exactOptionalPropertyTypes": false,
    "incremental": true,
  },
  "include": [
    "src",
    "scripts",
    "packages/*/src"
  ],
  "exclude": [
    "**/legacy-merge/**",
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx",
    "./src/**/*.spec.ts",
    "./src/**/*.spec.tsx",
    "./src/tests/**/*"
  ]
}
