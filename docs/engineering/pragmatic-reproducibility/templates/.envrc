# .envrc
# direnv configuration for automatic Nix shell activation
#
# Prerequisites:
#   1. Install direnv: https://direnv.net/docs/installation.html
#   2. Hook into shell: eval "$(direnv hook bash)"  # or zsh/fish
#   3. Allow this directory: direnv allow
#
# This file enables automatic environment activation when entering the project.

# Use Nix flake if available
if has nix; then
    use flake
else
    # Fallback: load .env files manually
    echo "⚠️  Nix not available, using basic environment"

    # Load environment files
    [[ -f .env ]] && dotenv .env
    [[ -f .env.local ]] && dotenv .env.local

    # Set basic development environment
    export NODE_ENV=development
    export ENVIRONMENT=development
    export VALUEOS_DEV_MODE=native
fi

# Always add node_modules/.bin to PATH
PATH_add node_modules/.bin

# Load local overrides if present
[[ -f .envrc.local ]] && source .envrc.local
