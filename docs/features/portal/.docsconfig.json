{
  "$schema": "./docsconfig.schema.json",
  "version": "1.0.0",
  "name": "ValueOS Documentation",
  "description": "Modern SaaS platform documentation",
  
  "structure": {
    "overview": {
      "path": "./overview",
      "sections": [
        {
          "id": "overview-welcome",
          "title": "Welcome to ValueOS",
          "file": "README.md",
          "mappings": [
            { "type": "file", "path": "/README.md" },
            { "type": "file", "path": "/package.json" }
          ]
        },
        {
          "id": "overview-use-cases",
          "title": "Use Cases",
          "file": "use-cases.md",
          "mappings": [
            { "type": "directory", "path": "/src/services" },
            { "type": "directory", "path": "/src/integrations" }
          ]
        },
        {
          "id": "overview-pricing",
          "title": "Pricing",
          "file": "pricing.md",
          "mappings": [
            { "type": "directory", "path": "/src/services/billing" },
            { "type": "file", "path": "/src/config/plans.ts" }
          ]
        }
      ]
    },
    
    "user-guide": {
      "path": "./user-guide",
      "sections": [
        {
          "id": "user-guide-getting-started",
          "title": "Getting Started",
          "file": "getting-started.md",
          "mappings": [
            { "type": "directory", "path": "/scripts/dx" },
            { "type": "directory", "path": "/src/components/onboarding" }
          ]
        },
        {
          "id": "user-guide-user-management",
          "title": "User Management",
          "file": "user-management.md",
          "mappings": [
            { "type": "directory", "path": "/src/services/auth" },
            { "type": "directory", "path": "/src/components/users" },
            { "type": "file", "path": "/src/types/user.ts" }
          ]
        },
        {
          "id": "user-guide-sso",
          "title": "SSO Setup",
          "file": "sso-setup.md",
          "mappings": [
            { "type": "directory", "path": "/src/services/auth/sso" },
            { "type": "file", "path": "/src/config/auth.ts" }
          ]
        },
        {
          "id": "user-guide-billing",
          "title": "Billing & Subscription",
          "file": "billing.md",
          "mappings": [
            { "type": "directory", "path": "/src/services/billing" },
            { "type": "directory", "path": "/src/components/billing" },
            { "type": "directory", "path": "/src/integrations/stripe" }
          ]
        }
      ]
    },
    
    "developer-guide": {
      "path": "./developer-guide",
      "sections": [
        {
          "id": "dev-guide-quick-start",
          "title": "Quick Start",
          "file": "quick-start.md",
          "mappings": [
            { "type": "directory", "path": "/src/api" },
            { "type": "directory", "path": "/src/api/client" }
          ]
        },
        {
          "id": "dev-guide-installation",
          "title": "Installation",
          "file": "installation.md",
          "mappings": [
            { "type": "file", "path": "/package.json" },
            { "type": "file", "path": "/.devcontainer/devcontainer.json" },
            { "type": "directory", "path": "/scripts" }
          ]
        },
        {
          "id": "dev-guide-configuration",
          "title": "Configuration",
          "file": "configuration.md",
          "mappings": [
            { "type": "file", "path": "/.env.example" },
            { "type": "directory", "path": "/src/config" },
            { "type": "file", "path": "/vite.config.ts" }
          ]
        }
      ]
    }
  },
  
  "automation": {
    "enabled": true,
    "triggers": {
      "onCommit": true,
      "onPullRequest": true,
      "onRelease": true,
      "schedule": "0 0 * * *"
    },
    "actions": {
      "detectChanges": true,
      "updateDocs": false,
      "notifyReviewers": true,
      "createIssues": true
    }
  },
  
  "versioning": {
    "enabled": true,
    "strategy": "semver",
    "trackChanges": true,
    "archiveOldVersions": true
  },
  
  "validation": {
    "checkLinks": true,
    "checkCodeExamples": true,
    "checkMappings": true,
    "requireReview": true
  },
  
  "notifications": {
    "slack": {
      "enabled": false,
      "channel": "#documentation",
      "events": ["outdated", "broken-link", "missing-mapping"]
    },
    "email": {
      "enabled": false,
      "recipients": ["docs@valueos.com"],
      "events": ["outdated", "review-required"]
    }
  },
  
  "api": {
    "enabled": true,
    "baseUrl": "/api/docs",
    "authentication": "bearer",
    "rateLimit": {
      "enabled": true,
      "requests": 100,
      "window": "15m"
    }
  }
}
