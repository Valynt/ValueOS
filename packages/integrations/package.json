{
  "name": "@valueos/integrations",
  "version": "1.0.0",
  "description": "ValueOS Enterprise integration adapters - HubSpot, Salesforce, ServiceNow, SharePoint, Slack",
  "type": "module",
  "private": true,
  "exports": {
    "./base": "./base/index.ts",
    "./hubspot": "./hubspot/index.ts",
    "./salesforce": "./salesforce/index.ts",
    "./servicenow": "./servicenow/index.ts",
    "./sharepoint": "./sharepoint/index.ts",
    "./slack": "./slack/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.29",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "valueos": {
    "classification": "internal-library",
    "supportTier": "internal-supported",
    "owner": "team-integrations",
    "shipped": true,
    "ci": {
      "rootVitest": {
        "status": "covered",
        "justification": "Covered by the packages/integrations Vitest workspace project."
      },
      "release": {
        "status": "excluded",
        "justification": "Internal adapters shipped through backend/application deployments only."
      }
    }
  }
}
