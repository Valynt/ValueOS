{
  "name": "@valueos/infra",
  "version": "1.0.0",
  "description": "ValueOS Infrastructure adapters - supabase, database, queues, storage, observability, eso",
  "type": "module",
  "private": true,
  "exports": {
    "./supabase": "./supabase/index.ts",
    "./database": "./database/index.ts",
    "./queues": "./queues/index.ts",
    "./storage": "./storage/index.ts",
    "./observability": "./observability/index.ts",
    "./eso": "./eso/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest run --watch"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "ioredis": "^5.9.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.29",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "tsErrorBaseline": 6,
  "valueos": {
    "classification": "internal-library",
    "supportTier": "internal-supported",
    "owner": "team-platform",
    "shipped": true,
    "ci": {
      "rootVitest": {
        "status": "covered",
        "justification": "Covered by the root Vitest workspace inline infra project."
      },
      "release": {
        "status": "excluded",
        "justification": "Internal infrastructure adapters are released only through product runtimes."
      }
    }
  }
}
