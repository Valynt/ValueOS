{
  "name": "@valueos/shared",
  "version": "1.0.0",
  "description": "ValueOS shared runtime-agnostic utilities, types, and validators",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./config/*": {
      "types": "./dist/config/*.d.ts",
      "import": "./dist/config/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js"
    },
    "./platform": {
      "types": "./dist/lib/platform/index.d.ts",
      "import": "./dist/lib/platform/index.js"
    },
    "./platform/browser": {
      "types": "./dist/lib/platform/browser.d.ts",
      "import": "./dist/lib/platform/browser.js"
    },
    "./platform/server": {
      "types": "./dist/lib/platform/server.d.ts",
      "import": "./dist/lib/platform/server.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@supabase/supabase-js": "^2.90.1",
    "ioredis": "^5.9.1",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.29",
    "@types/uuid": "^11.0.0",
    "typescript": "^5.9.3"
  },
  "tsErrorBaseline": 1,
  "valueos": {
    "classification": "internal-library",
    "supportTier": "internal-supported",
    "owner": "team-platform",
    "shipped": true,
    "ci": {
      "rootVitest": {
        "status": "covered",
        "justification": "Covered by the root Vitest workspace inline shared package project."
      },
      "release": {
        "status": "excluded",
        "justification": "Canonical internal domain model package; not independently released."
      }
    }
  }
}
