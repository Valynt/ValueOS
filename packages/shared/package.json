{
  "name": "@valueos/shared",
  "version": "1.0.0",
  "description": "ValueOS shared runtime-agnostic utilities, types, and validators",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./lib/*": "./src/lib/*",
    "./config/*": "./src/config/*",
    "./types/*": "./src/types/*",
    "./platform": "./src/lib/platform/index.ts",
    "./platform/browser": "./src/lib/platform/browser.ts",
    "./platform/server": "./src/lib/platform/server.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "ioredis": "^5.9.1",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.29",
    "typescript": "^5.9.3"
  }
}
