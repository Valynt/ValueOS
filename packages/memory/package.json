{
  "name": "@valueos/memory",
  "version": "1.0.0",
  "description": "ValueOS Memory layer - semantic, episodic, vector, provenance",
  "type": "module",
  "private": true,
  "exports": {
    "./semantic": "./semantic/index.ts",
    "./episodic": "./episodic/index.ts",
    "./vector": "./vector/index.ts",
    "./provenance": "./provenance/index.ts",
    "./lifecycle": "./lifecycle/index.ts",
    "./context-ledger": "./context-ledger/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run packages/memory/**/*.test.ts"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@valueos/infra": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.29",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "valueos": {
    "classification": "internal-library",
    "supportTier": "internal-supported",
    "owner": "team-platform",
    "shipped": true,
    "ci": {
      "rootVitest": {
        "status": "covered",
        "justification": "Covered by the root Vitest workspace inline memory project."
      },
      "release": {
        "status": "excluded",
        "justification": "Internal runtime memory layer; not released as a standalone artifact."
      }
    }
  }
}
