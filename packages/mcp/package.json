{
  "name": "@valueos/mcp",
  "version": "1.0.0",
  "description": "ValueOS MCP (Model Context Protocol) modules - common, CRM, ground-truth",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./index.ts",
    "./common": "./common/index.ts",
    "./crm": "./crm/index.ts",
    "./ground-truth": "./ground-truth/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "ioredis": "^5.6.1",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.29",
    "@vitest/coverage-v8": "3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "tsErrorBaseline": 54,
  "valueos": {
    "classification": "experimental",
    "supportTier": "experimental",
    "owner": "team-ai-platform",
    "shipped": false,
    "ci": {
      "rootVitest": {
        "status": "excluded",
        "justification": "Aggregator package for MCP experiments; shipped modules are tracked individually instead."
      },
      "release": {
        "status": "excluded",
        "justification": "Aggregator package is not a release artifact."
      }
    }
  }
}
