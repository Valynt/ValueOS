{
  "name": "@valueos/backend",
  "version": "1.0.0",
  "description": "ValueOS Backend Server - Express API, middleware, and routes",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "bash ../../scripts/dev/start-backend.sh",
    "worker:dev": "tsx src/workers/workerMain.ts",
    "worker": "node dist/workers/workerMain.js",
    "build": "node esbuild.config.mjs",
    "build:typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "typecheck:strict:api": "tsc -p tsconfig.strict-zone.api.json --noEmit",
    "typecheck:strict:auth": "tsc -p tsconfig.strict-zone.auth.json --noEmit",
    "typecheck:strict:runtime": "tsc -p tsconfig.strict-zone.runtime.json --noEmit",
    "typecheck:strict:security": "tsc -p tsconfig.strict-zone.security.json --noEmit",
    "typecheck:strict:tenant-data": "tsc -p tsconfig.strict-zone.tenant-data.json --noEmit",
    "typecheck:strict:zones": "pnpm run typecheck:strict:api && pnpm run typecheck:strict:auth && pnpm run typecheck:strict:runtime && pnpm run typecheck:strict:security && pnpm run typecheck:strict:tenant-data",
    "lint": "eslint src/ --max-warnings=2436",
    "debt:summary": "node ../../scripts/ci/backend-debt-summary.mjs",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "worker:billing-aggregator": "tsx src/workers/billingAggregatorWorker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.1012.0",
    "@aws-sdk/client-secrets-manager": "^3.989.0",
    "@aws-sdk/client-sts": "^3.1012.0",
    "@e2b/code-interpreter": "^2.3.3",
    "@mcp/ground-truth": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.43.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/compression": "^1.8.1",
    "@types/qrcode": "^1.5.6",
    "@valueos/memory": "workspace:*",
    "@valueos/sdui": "workspace:*",
    "@valueos/shared": "workspace:*",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "bullmq": "^5.56.0",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cron": "^4.4.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.9.1",
    "ipaddr.js": "^2.3.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "kafkajs": "^2.2.4",
    "lz-string": "^1.5.0",
    "nats": "^2.29.2",
    "node-vault": "^0.11.1",
    "otpauth": "^9.5.0",
    "p-queue": "^9.1.0",
    "pg": "^8.18.0",
    "pptxgenjs": "^4.0.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "rate-limiter-flexible": "^9.0.1",
    "redis": "^4.7.1",
    "socket.io": "^4.8.1",
    "stripe": "^14.25.0",
    "swagger-ui-express": "^5.0.1",
    "together-ai": "^0.14.0",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/cron": "^2.4.3",
    "@types/express": "^4.17.25",
    "@types/handlebars": "^4.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.29",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "eslint-plugin-security": "^4.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.90.1"
  },
  "tsErrorBaseline": 0,
  "exports": {
    ".": "./index.ts"
  },
  "valueos": {
    "classification": "production-runtime",
    "supportTier": "customer-critical",
    "owner": "team-platform",
    "shipped": true,
    "ci": {
      "rootVitest": {
        "status": "covered",
        "justification": "Covered by the dedicated packages/backend Vitest workspace project."
      },
      "release": {
        "status": "eligible",
        "justification": "Versioned backend runtime artifact."
      }
    }
  }
}
