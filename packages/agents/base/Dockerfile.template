# syntax=docker/dockerfile:1.7

# Standardized agent Dockerfile template.
# Generate per-agent Dockerfiles from this template to avoid drift.

ARG NODE_VERSION=20.19.0
ARG BUILD_IMAGE=node:${NODE_VERSION}-slim
ARG RUNTIME_IMAGE=node:${NODE_VERSION}-slim
ARG PNPM_VERSION=9.15.0
ARG AGENT_NAME

# Stage 1: Base tooling
FROM ${BUILD_IMAGE} AS base
ARG PNPM_VERSION
ENV PNPM_HOME=/pnpm
ENV PNPM_STORE_PATH=/pnpm/store
ENV PATH=$PNPM_HOME:$PATH
WORKDIR /workspace

RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate
RUN pnpm config set store-dir ${PNPM_STORE_PATH}

# Stage 2: Prune workspace for dependency caching
FROM base AS prune
ARG AGENT_NAME
WORKDIR /workspace

RUN test -n "${AGENT_NAME}"

COPY . .

RUN pnpm dlx turbo prune --docker --scope=@valueos/agent-base --scope=@valueos/${AGENT_NAME}-agent

# Stage 3: Dependencies
FROM base AS deps
ARG AGENT_NAME
WORKDIR /workspace

RUN test -n "${AGENT_NAME}"

COPY --from=prune /workspace/out/json/ ./
COPY --from=prune /workspace/.npmrc ./

RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store pnpm fetch --frozen-lockfile

RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store pnpm install --frozen-lockfile --offline

# Stage 4: Build
FROM deps AS build
ARG AGENT_NAME
WORKDIR /workspace

RUN test -n "${AGENT_NAME}"

COPY --from=prune /workspace/out/full/ ./

RUN pnpm --filter @valueos/agent-base build && pnpm --filter @valueos/${AGENT_NAME}-agent build

# Stage 5: Production dependencies
FROM deps AS prod-deps
ARG AGENT_NAME
WORKDIR /workspace

RUN test -n "${AGENT_NAME}"

COPY --from=prune /workspace/out/full/ ./

RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store pnpm install --prod --frozen-lockfile --offline --filter @valueos/agent-base --filter @valueos/${AGENT_NAME}-agent \
    && pnpm store prune

FROM ${RUNTIME_IMAGE} AS final
ARG AGENT_NAME
RUN addgroup -g 1001 -S agent && adduser -S -D -H -u 1001 -G agent agent
WORKDIR /app
ENV NODE_ENV=production

RUN test -n "${AGENT_NAME}"
COPY --from=prod-deps --chown=agent:agent /workspace/node_modules /app/node_modules
COPY --from=build --chown=agent:agent /workspace/packages/agents/base/package.json /app/packages/agents/base/package.json
COPY --from=build --chown=agent:agent /workspace/packages/agents/base/dist /app/packages/agents/base/dist
COPY --from=build --chown=agent:agent /workspace/packages/agents/${AGENT_NAME}/package.json /app/packages/agents/${AGENT_NAME}/package.json
COPY --from=build --chown=agent:agent /workspace/packages/agents/${AGENT_NAME}/dist /app/packages/agents/${AGENT_NAME}/dist

RUN test -f packages/agents/${AGENT_NAME}/dist/index.js
RUN find /app -type f -name '*.map' -delete && rm -rf /tmp/*

USER agent
EXPOSE 8080
CMD ["sh", "-c", "node packages/agents/${AGENT_NAME}/dist/index.js"]
