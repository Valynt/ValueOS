{
  "name": "github-code-optimizer",
  "version": "1.0.0",
  "description": "Autonomous GitHub bot for code optimization and refactoring",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "pnpm exec vitest run",
    "test:watch": "pnpm exec vitest --watch",
    "lint": "pnpm exec eslint \"src/**/*.ts\"",
    "lint:fix": "pnpm exec eslint \"src/**/*.ts\" --fix",
    "typecheck": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@octokit/webhooks": "^13.2.6",
    "@octokit/rest": "^20.0.2",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "winston": "^3.11.0",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.21.0",
    "tmp": "^0.2.1",
    "zod": "^3.22.4",
    "p-queue": "^8.0.1",
    "node-cron": "^3.0.3",
    "supertest": "^6.3.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.19.0",
    "@types/js-yaml": "^4.0.9",
    "@types/tmp": "^0.2.6",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.7.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.4",
    "eslint": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "valueos": {
    "classification": "experimental",
    "supportTier": "experimental",
    "owner": "team-devex",
    "shipped": false,
    "ci": {
      "rootVitest": {
        "status": "excluded",
        "justification": "Lab service kept for reference/prototyping and not part of the supported shipped surface."
      },
      "release": {
        "status": "excluded",
        "justification": "Reference/experimental service; excluded from automated release tagging."
      }
    }
  }
}
