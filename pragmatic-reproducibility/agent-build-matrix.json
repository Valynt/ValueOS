{
  "$schema": "https://json.schemastore.org/docker-compose-build.json",
  "version": "1.0.0",
  "lastUpdated": "2026-02-08",
  "buildConfig": {
    "nodeVersion": "20.19.0",
    "pnpmVersion": "9.15.0",
    "alpineVersion": "3.19",
    "registry": "ghcr.io/valynt/valueos"
  },
  "agents": {
    "opportunity": {
      "source": "apps/ValyntApp/src/lib/agent-fabric/agents/OpportunityAgent.ts",
      "package": "@valueos/opportunity-agent",
      "packagePath": "packages/agents/opportunity",
      "dependencies": ["@valueos/agent-base", "@valueos/memory", "@valueos/shared"],
      "exposePort": 8081,
      "lifecycleStage": "discovery",
      "riskCategory": "discovery",
      "confidenceThreshold": {
        "low": 0.5,
        "target": 0.7,
        "critical": 0.8
      },
      "resources": {
        "limits": {
          "cpus": "0.5",
          "memory": "512M"
        },
        "reservations": {
          "cpus": "0.1",
          "memory": "128M"
        }
      },
      "healthCheck": {
        "endpoint": "/health",
        "interval": "30s",
        "timeout": "5s",
        "retries": 3
      },
      "description": "Discovery phase agent for opportunity identification and analysis"
    },
