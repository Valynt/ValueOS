  "networkPolicies": {
    "agentNetwork": {
      "internal": true,
      "description": "Internal network for agent-to-agent and agent-to-infrastructure communication"
    },
    "messageBusNetwork": {
      "internal": true,
      "description": "Dedicated network for MessageBus (NATS) communication"
    },
    "observabilityNetwork": {
      "internal": true,
      "description": "Network for observability stack (Prometheus, Loki, Tempo)"
    }
  },
  "securityContext": {
    "runAsNonRoot": true,
    "runAsUser": 1001,
    "runAsGroup": 1001,
    "allowPrivilegeEscalation": false,
    "readOnlyRootFilesystem": true,
    "capabilities": {
      "drop": ["ALL"],
