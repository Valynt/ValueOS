{
  "ci": {
    "collect": {
      "url": ["http://localhost:5173"],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        
        "first-contentful-paint": ["error", { "maxNumericValue": 1800 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["error", { "maxNumericValue": 300 }],
        "speed-index": ["error", { "maxNumericValue": 3400 }],
        
        "interactive": ["error", { "maxNumericValue": 3800 }],
        "max-potential-fid": ["error", { "maxNumericValue": 130 }],
        
        "resource-summary:script:size": ["error", { "maxNumericValue": 350000 }],
        "resource-summary:stylesheet:size": ["error", { "maxNumericValue": 100000 }],
        "resource-summary:document:size": ["error", { "maxNumericValue": 50000 }],
        "resource-summary:image:size": ["error", { "maxNumericValue": 500000 }],
        "resource-summary:font:size": ["error", { "maxNumericValue": 200000 }],
        "resource-summary:total:size": ["error", { "maxNumericValue": 1500000 }],
        
        "unused-javascript": ["warn", { "maxNumericValue": 30000 }],
        "unused-css-rules": ["warn", { "maxNumericValue": 20000 }],
        
        "uses-responsive-images": "error",
        "uses-optimized-images": "warn",
        "modern-image-formats": "warn",
        "uses-text-compression": "error",
        "uses-long-cache-ttl": "warn",
        
        "dom-size": ["warn", { "maxNumericValue": 1500 }],
        "screenshot-thumbnails": "off",
        "final-screenshot": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
