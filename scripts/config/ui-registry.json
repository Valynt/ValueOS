{
  "$schema": "./ui-registry.schema.json",
  "version": "1.0.0",
  "description": "Intent-based UI registry configuration for ValueCanvas",
  "defaultFallback": "JsonViewer",
  "intents": [
    {
      "intentType": "visualize_graph",
      "component": "SystemMapCanvas",
      "fallback": "JsonViewer",
      "description": "Display system maps, entity-relationship diagrams, and network graphs",
      "propMappings": {
        "entities": "data.entities",
        "relationships": "data.relationships",
        "leveragePoints": "data.leveragePoints",
        "title": "data.title"
      }
    },
    {
      "intentType": "visualize_tree",
      "component": "ValueTreeCard",
      "fallback": "JsonViewer",
      "description": "Display hierarchical value trees and driver structures",
      "propMappings": {
        "tree": "data.tree",
        "title": "data.title",
        "expandedNodes": "data.expandedNodes"
      }
    },
    {
      "intentType": "display_metric",
      "component": "MetricBadge",
      "fallback": "StatCard",
      "description": "Display a single KPI or metric value",
      "propMappings": {
        "value": "data.value",
        "label": "data.label",
        "trend": "data.trend",
        "format": "data.format",
        "icon": "data.icon"
      }
    },
    {
      "intentType": "display_metrics_grid",
      "component": "RealizationDashboard",
      "fallback": "DataTable",
      "description": "Display multiple metrics in a dashboard grid",
      "propMappings": {
        "metrics": "data.metrics",
        "baseline": "data.baseline",
        "target": "data.target",
        "actual": "data.actual"
      }
    },
    {
      "intentType": "display_table",
      "component": "DataTable",
      "fallback": "JsonViewer",
      "description": "Display tabular data with sorting and filtering",
      "propMappings": {
        "data": "data.rows",
        "columns": "data.columns",
        "sortable": "context.sortable",
        "filterable": "context.filterable",
        "pagination": "context.pagination"
      }
    },
    {
      "intentType": "display_list",
      "component": "ItemList",
      "fallback": "DataTable",
      "description": "Display a list of items",
      "propMappings": {
        "items": "data.items",
        "title": "data.title"
      }
    },
    {
      "intentType": "input_form",
      "component": "KPIForm",
      "fallback": "BasicForm",
      "description": "Display a dynamic form for user input",
      "propMappings": {
        "fields": "data.fields",
        "initialValues": "data.initialValues",
        "validation": "data.validation"
      }
    },
    {
      "intentType": "show_agent_response",
      "component": "AgentResponseCard",
      "fallback": "InfoBanner",
      "description": "Display agent response with reasoning transparency",
      "propMappings": {
        "response": "data.response",
        "reasoning": "data.reasoning",
        "confidence": "data.confidence",
        "agentName": "source.agentType",
        "timestamp": "source.timestamp"
      }
    },
    {
      "intentType": "show_agent_progress",
      "component": "AgentWorkflowPanel",
      "fallback": "ProgressBar",
      "description": "Display agent workflow progress and status",
      "propMappings": {
        "stages": "data.stages",
        "currentStage": "data.currentStage",
        "progress": "data.progress",
        "estimatedTime": "data.estimatedTime"
      }
    },
    {
      "intentType": "show_confidence",
      "component": "ConfidenceIndicator",
      "fallback": "MetricBadge",
      "description": "Display confidence or certainty indicator",
      "propMappings": {
        "value": "data.confidence",
        "label": "data.label",
        "breakdown": "data.breakdown",
        "explanation": "data.explanation"
      }
    },
    {
      "intentType": "show_info",
      "component": "InfoBanner",
      "fallback": "TextBlock",
      "description": "Display informational message",
      "propMappings": {
        "message": "data.message",
        "title": "data.title",
        "variant": "data.variant",
        "dismissible": "context.dismissible"
      }
    },
    {
      "intentType": "display_dashboard_panel",
      "component": "DashboardPanel",
      "fallback": "TextBlock",
      "description": "Collapsible dashboard section panel",
      "propMappings": {
        "children": "data.children"
      }
    },
    {
      "intentType": "show_hallucination_badge",
      "component": "HallucinationBadge",
      "fallback": "TextBlock",
      "description": "Agent trust indicator. Green = hallucination check passed, red = failed, amber = unknown. Shows grounding score on click.",
      "propMappings": {
        "hallucination_check": "data.hallucination_check",
        "grounding_score": "data.grounding_score",
        "detail": "data.detail"
      }
    },
    {
      "intentType": "show_discovery_card",
      "component": "DiscoveryCard",
      "fallback": "TextBlock",
      "description": "Discovery prompts for opportunity framing.",
      "propMappings": {
        "questions": "data.questions"
      }
    },
    {
      "intentType": "show_value_tree",
      "component": "ValueTreeCard",
      "fallback": "TextBlock",
      "description": "Nested value drivers for target outcomes.",
      "propMappings": {
        "title": "data.title",
        "nodes": "data.nodes"
      }
    },
    {
      "intentType": "show_expansion_block",
      "component": "ExpansionBlock",
      "fallback": "TextBlock",
      "description": "ROI snapshot for expansion stage.",
      "propMappings": {
        "gaps": "data.gaps",
        "roi": "data.roi"
      }
    },
    {
      "intentType": "show_kpi_form",
      "component": "KPIForm",
      "fallback": "TextBlock",
      "description": "Form for entering baseline and target values for a KPI.",
      "propMappings": {
        "kpiName": "data.kpiName"
      }
    },
    {
      "intentType": "show_realization_dashboard",
      "component": "RealizationDashboard",
      "fallback": "TextBlock",
      "description": "Displays baseline vs. target vs. actual results for realized value.",
      "propMappings": {}
    },
    {
      "intentType": "show_integrity_review",
      "component": "IntegrityReviewPanel",
      "fallback": "TextBlock",
      "description": "Displays manifesto rule validation results.",
      "propMappings": {
        "results": "data.results"
      }
    },
    {
      "intentType": "show_side_navigation",
      "component": "SideNavigation",
      "fallback": "TextBlock",
      "description": "Collapsible sidebar navigation with workflow stages.",
      "propMappings": {
        "items": "data.items"
      }
    },
    {
      "intentType": "show_tab_bar",
      "component": "TabBar",
      "fallback": "TextBlock",
      "description": "Secondary navigation with neon green active indicator.",
      "propMappings": {
        "tabs": "data.tabs"
      }
    },
    {
      "intentType": "show_breadcrumbs",
      "component": "Breadcrumbs",
      "fallback": "TextBlock",
      "description": "Path indicators with separators for navigation hierarchy.",
      "propMappings": {
        "items": "data.items"
      }
    },
    {
      "intentType": "show_confidence_indicator",
      "component": "ConfidenceIndicator",
      "fallback": "MetricBadge",
      "description": "Visual confidence meter for AI outputs (0-100%).",
      "propMappings": {
        "value": "data.value"
      }
    },
    {
      "intentType": "show_agent_response",
      "component": "AgentResponseCard",
      "fallback": "TextBlock",
      "description": "Displays agent outputs with reasoning transparency and actions.",
      "propMappings": {
        "response": "data.response"
      }
    },
    {
      "intentType": "show_agent_workflow_panel",
      "component": "AgentWorkflowPanel",
      "fallback": "TextBlock",
      "description": "Shows active agents, collaboration status, and communication log.",
      "propMappings": {
        "agents": "data.agents"
      }
    },
    {
      "intentType": "show_narrative_block",
      "component": "NarrativeBlock",
      "fallback": "TextBlock",
      "description": "Displays AI-generated narrative content with optional editing and transparency.",
      "propMappings": {
        "title": "data.title",
        "content": "data.content"
      }
    },
    {
      "intentType": "show_sdui_form",
      "component": "SDUIForm",
      "fallback": "TextBlock",
      "description": "Dynamic form generation from JSON schema with validation and AI suggestions.",
      "propMappings": {
        "id": "data.id"
      }
    },
    {
      "intentType": "show_scenario_selector",
      "component": "ScenarioSelector",
      "fallback": "TextBlock",
      "description": "Template/scenario selection interface with AI recommendations.",
      "propMappings": {
        "scenarios": "data.scenarios"
      }
    },
    {
      "intentType": "show_component_preview",
      "component": "ComponentPreview",
      "fallback": "JsonViewer",
      "description": "Developer preview tool for ui-registry.json entries with validation.",
      "propMappings": {
        "intentType": "data.intentType",
        "componentName": "data.componentName",
        "registryEntry": "data.registryEntry",
        "organizationId": "data.organizationId"
      }
    },
    {
      "intentType": "visualize_timeline",
      "component": "LifecyclePanel",
      "fallback": "DataTable",
      "description": "Display workflow lifecycle or timeline",
      "propMappings": {
        "stages": "data.stages",
        "currentStage": "data.currentStage",
        "completedStages": "data.completedStages"
      }
    },
    {
      "intentType": "input_confirmation",
      "component": "ValueCommitForm",
      "fallback": "ConfirmationDialog",
      "description": "Display commitment or confirmation form",
      "propMappings": {
        "kpis": "data.kpis",
        "assumptions": "data.assumptions",
        "commitments": "data.commitments"
      }
    },
    {
      "intentType": "show_workflow_status",
      "component": "WorkflowStatusBar",
      "fallback": "ProgressBar",
      "description": "Display real-time workflow progress and current agent status",
      "propMappings": {
        "currentStage": "data.currentStage",
        "lastAgentAction": "data.lastAgentAction",
        "agentName": "data.agentName",
        "confidence": "data.confidence",
        "hallucinationCheck": "data.hallucinationCheck",
        "isLoading": "data.isLoading",
        "estimatedTimeRemaining": "data.estimatedTimeRemaining"
      }
    },
    {
      "intentType": "request_human_approval",
      "component": "HumanCheckpoint",
      "fallback": "ConfirmationDialog",
      "description": "Display human approval interface for workflow checkpoints",
      "propMappings": {
        "stageId": "data.stageId",
        "agentName": "data.agentName",
        "action": "data.action",
        "riskLevel": "data.riskLevel",
        "confidence": "data.confidence",
        "reasoning": "data.reasoning"
      }
    },
    {
      "intentType": "show_agent_confidence",
      "component": "ConfidenceDisplay",
      "fallback": "MetricBadge",
      "description": "Display agent confidence and hallucination status",
      "propMappings": {
        "confidence": "data.confidence",
        "hallucinationCheck": "data.hallucinationCheck",
        "reasoning": "data.reasoning",
        "agentName": "data.agentName"
      }
    },
    {
      "intentType": "show_value_graph",
      "component": "ValueGraphVisualization",
      "fallback": "JsonViewer",
      "description": "Interactive ReactFlow canvas of the Value Graph for an opportunity. Color-coded nodes by entity type; click to inspect.",
      "propMappings": {
        "opportunityId": "data.opportunityId",
        "organizationId": "data.organizationId"
      }
    },
    {
      "intentType": "show_value_path_card",
      "component": "ValuePathCard",
      "fallback": "TextBlock",
      "description": "Renders a single causal path from UseCase to VgValueDriver with confidence score and evidence tier chips.",
      "propMappings": {
        "path": "data.path"
      }
    },
    {
      "intentType": "show_metric_card",
      "component": "MetricCard",
      "fallback": "MetricBadge",
      "description": "Renders a VgMetric with baseline, target, unit-formatted values, evidence tier badge, and measurement method.",
      "propMappings": {
        "metric": "data.metric",
        "evidenceTier": "data.evidenceTier"
      }
    },
    {
      "intentType": "show_reasoning_trace",
      "component": "ReasoningTracePanel",
      "fallback": "JsonViewer",
      "description": "Display agent reasoning trace: Inputs, Transformations, Assumptions, Confidence Breakdown, Evidence Links.",
      "propMappings": {
        "trace_id": "data.trace_id",
        "trace": "data.trace",
        "onClose": "actions.onClose"
      }
    }
  ],
  "tenantOverrides": {
    "enterprise-demo": [
      {
        "intentType": "visualize_graph",
        "component": "EnterpriseSystemMap",
        "priority": 10
      }
    ]
  },
  "agentMappings": {
    "SystemMapperAgent": {
      "primaryIntent": "visualize_graph",
      "secondaryIntents": [
        "display_list"
      ]
    },
    "InterventionDesignerAgent": {
      "primaryIntent": "input_form",
      "secondaryIntents": [
        "show_agent_response"
      ]
    },
    "OutcomeEngineerAgent": {
      "primaryIntent": "display_metrics_grid",
      "secondaryIntents": [
        "show_confidence"
      ]
    },
    "RealizationLoopAgent": {
      "primaryIntent": "display_metrics_grid",
      "secondaryIntents": [
        "visualize_timeline"
      ]
    },
    "ValueEvalAgent": {
      "primaryIntent": "display_metric",
      "secondaryIntents": [
        "show_confidence"
      ]
    },
    "CoordinatorAgent": {
      "primaryIntent": "show_agent_progress",
      "secondaryIntents": [
        "show_info"
      ]
    }
  }
}
