# ValueOS Development Environment Configuration
# Inherits from base.env and overrides for development-specific settings

NODE_ENV=development
DEV_DOMAIN=localhost
CADDY_ADMIN=0.0.0.0:2019
CADDY_LOG_LEVEL=DEBUG
AUTO_HTTPS=off

# Development URLs
VITE_APP_URL=https://localhost:8443
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Development CORS
CORS_ALLOWED_ORIGINS=https://localhost:8443,http://localhost:5173

# Development Features
VITE_ENABLE_CIRCUIT_BREAKER=false
VITE_ENABLE_RATE_LIMITING=false
VITE_ENABLE_AUDIT_LOGGING=true
VITE_DEV_TOOLS=true
VITE_SOURCE_MAPS=true

# Development Ports
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
VITE_HMR_PORT=24678

# API Configuration
API_PORT=3001
API_UPSTREAM=http://backend:3001
FRONTEND_UPSTREAM=http://frontend:5173

# Development Security (relaxed)
SECURITY_CORS=false
SECURITY_HELMET=false
SECURITY_RATE_LIMIT=false

# Database (Development passwords - CHANGE FOR PRODUCTION!)
POSTGRES_PASSWORD=dev_password
REDIS_PASSWORD=redis_dev_password_CHANGE_ME

# LLM API Keys (Development - CHANGE FOR PRODUCTION!)
TOGETHER_API_KEY=your-together-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Performance Tuning (Development)
UV_THREADPOOL_SIZE=8
PG_POOL_MIN=4
PG_POOL_MAX=40
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000

# Development Database URLs
# CRITICAL: sslmode=disable required - local postgres has no TLS
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev?sslmode=disable
DIRECT_DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev?sslmode=disable
DB_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev?sslmode=disable
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SESSION_SECRET=your-dev-session-secret-here
JWT_SECRET=your-dev-jwt-secret-here
