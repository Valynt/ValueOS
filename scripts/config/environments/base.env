# ============================================================================
# ValueOS Base Environment Configuration
# This file contains common environment variables used across all environments
# Environment-specific files inherit from this base and override specific settings
# ============================================================================

# Application
NODE_ENV=development
VITE_APP_NAME=ValueOS
VITE_APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://localhost:5432/valueos
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30000
POSTGRES_DB=valuecanvas_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=redis_dev_password_CHANGE_ME

# Supabase
VITE_SUPABASE_URL=http://localhost:54321
SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Authentication
AUTH_SESSION_TIMEOUT=86400000
AUTH_REFRESH_TIMEOUT=604800000
AUTH_ENABLE_MFA=false

# API
VITE_API_URL=http://localhost:3000
API_PORT=3001
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3

# Features
FEATURE_AGENTS=true
FEATURE_CANVAS=true
FEATURE_INTEGRATIONS=true
FEATURE_BILLING=false
FEATURE_MONITORING=true

# Monitoring
MONITORING_ENABLED=true
LOG_LEVEL=info
METRICS_ENABLED=true
METRICS_INTERVAL=60000

# Security
SECURITY_CORS=true
SECURITY_HELMET=true
SECURITY_RATE_LIMIT=true
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# Development Tools
VITE_DEV_TOOLS=true
VITE_SOURCE_MAPS=true

# Application URLs
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=/api

# Caddy Edge (Development Defaults)
DEV_DOMAIN=localhost
API_UPSTREAM=http://backend:3001
FRONTEND_UPSTREAM=http://frontend:5173
CADDY_ADMIN=0.0.0.0:2019
CADDY_LOG_LEVEL=DEBUG
AUTO_HTTPS=off

# LLM Configuration
VITE_LLM_PROVIDER=together
TOGETHER_API_KEY=your-together-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Connection Pool & Threading (Performance Tuning)
UV_THREADPOOL_SIZE=8
PG_POOL_MIN=4
PG_POOL_MAX=40
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000

# Prisma Connection Pooling
# CRITICAL: sslmode=disable required - local postgres has no TLS
DIRECT_DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev?sslmode=disable

# Database connection URLs (constructed from above)
DB_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev?sslmode=disable

# Redis Configuration
REDIS_MAX_MEMORY=512mb
REDIS_POLICY=allkeys-lru

# Port Configuration
POSTGRES_PORT=5432
REDIS_PORT=6379
VITE_PORT=5173
VITE_HMR_PORT=24678
API_PORT=3001
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
CADDY_ADMIN_PORT=2019

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# Docker
CADDY_LOG_DIR=/var/log/caddy
CADDY_STORAGE=/data
CADDY_LOG_LEVEL=DEBUG

# Security Settings (Development)
VITE_ENABLE_CIRCUIT_BREAKER=false
VITE_ENABLE_RATE_LIMITING=false
VITE_ENABLE_AUDIT_LOGGING=true

# CORS Settings
CORS_ALLOWED_ORIGINS=https://localhost:8443,http://localhost:5173
