# ValueOS Test Environment Configuration
# Inherits from base.env and overrides for test-specific settings

NODE_ENV=test

# Test Database (isolated test database)
DATABASE_URL=postgresql://postgres:test_password@localhost:5432/valueos_test
DIRECT_DATABASE_URL=postgresql://postgres:test_password@localhost:5432/valueos_test
DB_URL=postgresql://postgres:test_password@localhost:5432/valueos_test

# Test Database Configuration
POSTGRES_DB=valueos_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test_password
POSTGRES_PORT=5433  # Different port to avoid conflicts

# Test Redis (isolated test Redis)
REDIS_URL=redis://localhost:6380
REDIS_PASSWORD=test_redis_password
REDIS_MAX_MEMORY=128mb
REDIS_PORT=6380  # Different port to avoid conflicts

# Test API Configuration
API_PORT=3002  # Different port to avoid conflicts
API_TIMEOUT=5000
API_RETRY_ATTEMPTS=1  # Fail fast in tests

# Test URLs
VITE_APP_URL=http://localhost:5174
VITE_API_BASE_URL=http://localhost:3002
VITE_SUPABASE_URL=http://localhost:54322  # Different Supabase port
VITE_SUPABASE_ANON_KEY=test-supabase-anon-key
SUPABASE_URL=http://localhost:54322
SUPABASE_ANON_KEY=test-supabase-anon-key

# Test Features (all disabled for clean testing)
FEATURE_AGENTS=false
FEATURE_CANVAS=true
FEATURE_INTEGRATIONS=false
FEATURE_BILLING=false
FEATURE_MONITORING=false

# Test Security (disabled for testing)
SECURITY_CORS=false
SECURITY_HELMET=false
SECURITY_RATE_LIMIT=false
VITE_ENABLE_CIRCUIT_BREAKER=false
VITE_ENABLE_RATE_LIMITING=false
VITE_ENABLE_AUDIT_LOGGING=false

# Test Development Tools (enabled for debugging)
VITE_DEV_TOOLS=false
VITE_SOURCE_MAPS=true

# Test Monitoring (minimal)
MONITORING_ENABLED=false
LOG_LEVEL=error
METRICS_ENABLED=false

# Test Authentication (short timeouts)
AUTH_SESSION_TIMEOUT=300000  # 5 minutes
AUTH_REFRESH_TIMEOUT=600000  # 10 minutes
AUTH_ENABLE_MFA=false

# Test Secrets (test values)
JWT_SECRET=test-jwt-secret-for-testing-only
ENCRYPTION_KEY=test-encryption-key-for-testing-only

# Test API Keys (test values)
TOGETHER_API_KEY=test-together-api-key
OPENAI_API_KEY=test-openai-api-key
ANTHROPIC_API_KEY=test-anthropic-api-key

# Test Performance (minimal)
UV_THREADPOOL_SIZE=2
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=5000
PG_POOL_CONNECTION_TIMEOUT_MS=1000

# Test Ports (isolated)
VITE_PORT=5174
VITE_HMR_PORT=24679
CADDY_HTTP_PORT=8081
CADDY_HTTPS_PORT=8444
CADDY_ADMIN_PORT=2020

# Test CORS (permissive)
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3002

# Test Docker Configuration
CADDY_LOG_DIR=/tmp/test-caddy-logs
CADDY_STORAGE=/tmp/test-caddy-storage
CADDY_LOG_LEVEL=ERROR

# Test Observability (disabled)
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=test

# Test Health Checks (fast)
HEALTH_CHECK_INTERVAL=5s
HEALTH_CHECK_TIMEOUT=2s
HEALTH_CHECK_RETRIES=1

# Test Resource Limits (minimal)
API_MEMORY_LIMIT=512MB
FRONTEND_MEMORY_LIMIT=256MB
REDIS_MEMORY_LIMIT=128MB

# Test Database Cleanup
TEST_DATABASE_CLEANUP=true
TEST_REDIS_CLEANUP=true

# Test Timeouts (short)
TEST_TIMEOUT=30000
TEST_REQUEST_TIMEOUT=5000

# Test Mocking
ENABLE_MOCK_SERVICES=true
MOCK_EXTERNAL_APIS=true

# Test Reporting
TEST_COVERAGE_REPORT=true
TEST_REPORT_FORMAT=json
TEST_OUTPUT_DIR=./test-results
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SESSION_SECRET=test-session-secret-for-testing-only
