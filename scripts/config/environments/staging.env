# ValueOS Staging Environment Configuration
# Inherits from base.env and overrides for staging-specific settings

NODE_ENV=staging

# Staging Domain Configuration
APP_DOMAIN=staging.valueos.com
ACME_EMAIL=security@valueos.com
ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
TLS_MODE=

# Staging URLs
VITE_APP_URL=https://staging.valueos.com
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-supabase-anon-key-here

# Staging API Configuration
API_PORT=3001
API_UPSTREAM=http://backend:3001
CORS_ALLOWED_ORIGINS=https://staging.valueos.com,http://localhost:3000

# Staging Security (enabled but relaxed for testing)
SECURITY_CORS=true
SECURITY_HELMET=true
SECURITY_RATE_LIMIT=true
VITE_ENABLE_CIRCUIT_BREAKER=true
VITE_ENABLE_RATE_LIMITING=true
VITE_ENABLE_AUDIT_LOGGING=true

# Staging Features (some development tools enabled)
VITE_DEV_TOOLS=false
VITE_SOURCE_MAPS=true

# Staging Database (staging database)
DATABASE_URL=postgresql://user:password@staging-db.example.com:5432/valueos_staging
DIRECT_DATABASE_URL=postgresql://user:password@staging-db.example.com:5432/valueos_staging

# Staging Redis (secure but accessible)
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=staging-redis-password
REDIS_MAX_MEMORY=512mb

# Staging Monitoring
MONITORING_ENABLED=true
LOG_LEVEL=info
METRICS_ENABLED=true
CADDY_LOG_LEVEL=INFO

# Staging Performance Tuning
UV_THREADPOOL_SIZE=12
PG_POOL_MIN=8
PG_POOL_MAX=60
PG_POOL_IDLE_TIMEOUT_MS=20000
PG_POOL_CONNECTION_TIMEOUT_MS=4000

# Staging Authentication
AUTH_SESSION_TIMEOUT=7200000  # 2 hours
AUTH_REFRESH_TIMEOUT=43200000  # 12 hours
AUTH_ENABLE_MFA=false

# Staging Secrets (must be provided externally)
JWT_SECRET=your-staging-jwt-secret-here
ENCRYPTION_KEY=your-staging-encryption-key-here

# Staging API Keys (staging keys)
TOGETHER_API_KEY=your-staging-together-api-key
OPENAI_API_KEY=your-staging-openai-api-key
ANTHROPIC_API_KEY=your-staging-anthropic-api-key

# Supabase Staging Configuration
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
SUPABASE_URL=https://your-staging-project.supabase.co

# Staging Ports (some external exposure for testing)
POSTGRES_PORT=5432  # Internal only
REDIS_PORT=6379    # Internal only

# Staging Docker Configuration
CADDY_LOG_DIR=/var/log/caddy
CADDY_STORAGE=/data

# Staging Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=staging-grafana-password

# Staging Health Checks
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=3

# Staging Resource Limits
API_MEMORY_LIMIT=1.5G
FRONTEND_MEMORY_LIMIT=512MB
REDIS_MEMORY_LIMIT=512MB

# Staging SSL/TLS (staging certificates)
SSL_CERT_PATH=/etc/certs/staging-tls.crt
SSL_KEY_PATH=/etc/certs/staging-tls.key
