# ValueOS Production Environment Configuration
# Inherits from base.env and overrides for production-specific settings

NODE_ENV=production

# Production Domain Configuration
APP_DOMAIN=app.example.com
ACME_EMAIL=security@example.com
ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TLS_MODE=

# Production URLs
VITE_APP_URL=https://app.example.com
SUPABASE_INTERNAL_URL=https://your-project.supabase.co
SUPABASE_PUBLIC_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Production API Configuration
API_PORT=3001
API_UPSTREAM=http://backend:3001
CORS_ALLOWED_ORIGINS=https://app.example.com

# Production Security (enabled and enforced)
SECURITY_CORS=true
SECURITY_HELMET=true
SECURITY_RATE_LIMIT=true
VITE_ENABLE_CIRCUIT_BREAKER=true
VITE_ENABLE_RATE_LIMITING=true
VITE_ENABLE_AUDIT_LOGGING=true

# Production Features (development tools disabled)
VITE_DEV_TOOLS=false
VITE_SOURCE_MAPS=false

# Production Database (external database)
DATABASE_URL=postgresql://user:password@db.example.com:5432/valueos
DIRECT_DATABASE_URL=postgresql://user:password@db.example.com:5432/valueos

# Production Redis (secure)
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=change-me-strong-production-password
REDIS_MAX_MEMORY=256mb

# Production Monitoring
MONITORING_ENABLED=true
LOG_LEVEL=warn
METRICS_ENABLED=true
CADDY_LOG_LEVEL=INFO

# Production Performance Tuning
UV_THREADPOOL_SIZE=16
PG_POOL_MIN=10
PG_POOL_MAX=80
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000

# Production Authentication
AUTH_SESSION_TIMEOUT=3600000  # 1 hour
AUTH_REFRESH_TIMEOUT=86400000  # 24 hours
AUTH_ENABLE_MFA=true

# Production Secrets (must be provided externally)
JWT_SECRET=your-production-jwt-secret-here
ENCRYPTION_KEY=your-production-encryption-key-here

# Production API Keys (must be provided externally)
TOGETHER_API_KEY=your-production-together-api-key
OPENAI_API_KEY=your-production-openai-api-key
ANTHROPIC_API_KEY=your-production-anthropic-api-key

# Supabase Production Configuration
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
SUPABASE_URL=https://your-project.supabase.co

# Production Ports (no external exposure for internal services)
POSTGRES_PORT=5432  # Internal only
REDIS_PORT=6379    # Internal only

# Production Docker Configuration
CADDY_LOG_DIR=/var/log/caddy
CADDY_STORAGE=/data

# Production Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=change-me-strong-grafana-password

# Production Health Checks
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=3

# Production Resource Limits
API_MEMORY_LIMIT=2G
FRONTEND_MEMORY_LIMIT=1G
REDIS_MEMORY_LIMIT=256MB

# Production SSL/TLS
SSL_CERT_PATH=/etc/certs/tls.crt
SSL_KEY_PATH=/etc/certs/tls.key
