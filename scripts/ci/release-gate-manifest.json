{
  "version": 1,
  "releaseBlockingGates": [
    {
      "id": "lint-typecheck-unit-and-workflow-dag",
      "description": "Lint, typecheck, unit/integration coverage, and workflow DAG validation.",
      "workflow": ".github/workflows/main-verify.yml",
      "jobId": "unit-component-schema",
      "jobName": "unit/component/schema",
      "coverage": [
        "lint",
        "typecheck",
        "unit/integration tests",
        "workflow DAG validation"
      ]
    },
    {
      "id": "tenant-isolation-and-rls",
      "description": "Runtime tenant-isolation, RLS, vector-memory boundary, and DSR compliance suites.",
      "workflow": ".github/workflows/main-verify.yml",
      "jobId": "tenant-isolation-gate",
      "jobName": "tenant-isolation-gate",
      "coverage": [
        "RLS / tenant-isolation suites"
      ]
    },
    {
      "id": "security-scans",
      "description": "Semgrep SAST, pnpm audit SCA, Gitleaks secret scan, Trivy image/filesystem scans, and SBOM generation.",
      "workflow": ".github/workflows/main-verify.yml",
      "jobId": "security-gate",
      "jobName": "security-gate",
      "coverage": [
        "security scans (SAST, SCA, secret scan, image/filesystem scan)"
      ]
    },
    {
      "id": "ci-release-aggregator",
      "description": "CI aggregator that blocks release promotion unless upstream CI lanes are green.",
      "workflow": ".github/workflows/main-verify.yml",
      "jobId": "staging-deploy-release-gates",
      "jobName": "staging-deploy-release-gates",
      "coverage": [
        "canonical CI deploy/release aggregation"
      ]
    },
    {
      "id": "codeql",
      "description": "Dedicated CodeQL analysis required by branch protection and release promotion.",
      "workflow": ".github/workflows/codeql.yml",
      "jobId": "codeql-analyze",
      "jobName": "codeql-analyze (js-ts)",
      "coverage": [
        "CodeQL"
      ]
    },
    {
      "id": "dast",
      "description": "OWASP ZAP DAST gate executed inside the deploy workflow before production promotion.",
      "workflow": ".github/workflows/deploy.yml",
      "jobId": "dast-gate",
      "jobName": "DAST Gate",
      "coverage": [
        "DAST"
      ]
    }
  ],
  "externalRequiredChecks": [
    {
      "jobId": "staging-deploy-release-gates",
      "checkName": "staging-deploy-release-gates",
      "workflow": ".github/workflows/main-verify.yml"
    },
    {
      "jobId": "codeql-analyze",
      "checkName": "codeql-analyze (js-ts)",
      "workflow": ".github/workflows/codeql.yml"
    }
  ],
  "deployWorkflow": {
    "aggregateJobId": "release-gate-contract",
    "aggregateJobName": "Release Gate Contract",
    "localNeeds": [
      "dast-gate",
      "emergency-skip-audit"
    ],
    "productionNeedsMustInclude": [
      "release-gate-contract",
      "deploy-staging",
      "staging-performance-benchmarks",
      "preprod-slo-guard",
      "preprod-launch-gate",
      "build-images",
      "verify-supply-chain",
      "stability-seal",
      "emergency-skip-audit"
    ],
    "productionNeedsMustExclude": [
      "quality-gate",
      "dast-gate"
    ]
  }
}
