{
  "version": 2,
  "releaseBlockingGates": [
    {
      "id": "main-verify",
      "description": "Durable post-merge CI aggregate that verifies the canonical mainline blockers before release promotion.",
      "workflow": ".github/workflows/ci.yml",
      "jobId": "staging-deploy-release-gates",
      "jobName": "main-verify",
      "coverage": [
        "post-merge CI verification aggregate"
      ]
    },
    {
      "id": "dast",
      "description": "OWASP ZAP DAST gate executed inside the deploy workflow before production promotion.",
      "workflow": ".github/workflows/deploy.yml",
      "jobId": "dast-gate",
      "jobName": "DAST Gate",
      "coverage": [
        "DAST"
      ]
    }
  ],
  "externalRequiredChecks": [
    {
      "jobId": "staging-deploy-release-gates",
      "checkName": "main-verify",
      "workflow": ".github/workflows/ci.yml"
    }
  ],
  "deployWorkflow": {
    "aggregateJobId": "release-gate-contract",
    "aggregateJobName": "release-readiness",
    "localNeeds": [
      "dast-gate",
      "emergency-skip-audit"
    ],
    "productionNeedsMustInclude": [
      "release-gate-contract",
      "deploy-staging",
      "staging-performance-benchmarks",
      "preprod-slo-guard",
      "preprod-launch-gate",
      "build-images",
      "verify-supply-chain",
      "stability-seal",
      "emergency-skip-audit"
    ],
    "productionNeedsMustExclude": [
      "quality-gate",
      "dast-gate"
    ]
  }
}
