{
  "version": 2,
  "releaseBlockingGates": [
    {
      "id": "pr-fast-lane",
      "description": "PR-only fast lane covering lint, typecheck, unit tests, lightweight security, tenant static checks, and conditional frontend checks.",
      "workflow": ".github/workflows/ci.yml",
      "jobId": "pr-only-blocking-gate",
      "jobName": "pr-only-blocking-gate",
      "coverage": [
        "PR fast lane"
      ]
    },
    {
      "id": "main-trusted-runtime",
      "description": "Trusted-branch tenant runtime suites and critical validation.",
      "workflow": ".github/workflows/ci.yml",
      "jobId": "main-only-blocking-gate",
      "jobName": "main-only-blocking-gate",
      "coverage": [
        "trusted branch runtime validation"
      ]
    },
    {
      "id": "codeql",
      "description": "Dedicated CodeQL analysis for trusted main runs.",
      "workflow": ".github/workflows/codeql.yml",
      "jobId": "codeql-analyze",
      "jobName": "main-codeql-analyze (js-ts)",
      "coverage": [
        "CodeQL"
      ]
    },
    {
      "id": "deploy-dast",
      "description": "OWASP ZAP DAST gate executed inside the deploy workflow before production promotion.",
      "workflow": ".github/workflows/deploy.yml",
      "jobId": "deploy-dast-gate",
      "jobName": "Deploy DAST Gate",
      "coverage": [
        "DAST"
      ]
    }
  ],
  "externalRequiredChecks": [
    {
      "jobId": "pr-only-blocking-gate",
      "checkName": "pr-only-blocking-gate",
      "workflow": ".github/workflows/ci.yml"
    }
  ],
  "deployWorkflow": {
    "aggregateJobId": "release-gate-contract",
    "aggregateJobName": "Release Gate Contract",
    "localNeeds": [
      "deploy-dast-gate",
      "emergency-skip-audit"
    ],
    "productionNeedsMustInclude": [
      "release-gate-contract",
      "deploy-staging",
      "staging-performance-benchmarks",
      "preprod-slo-guard",
      "preprod-launch-gate",
      "build-images",
      "verify-supply-chain",
      "secret-rotation-gate",
      "emergency-skip-audit"
    ],
    "productionNeedsMustExclude": [
      "disabled-quality-gate",
      "deploy-dast-gate",
      "main-only-advisory-stability-seal"
    ]
  }
}
