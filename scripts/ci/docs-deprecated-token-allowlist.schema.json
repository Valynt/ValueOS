{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["allowlist"],
  "properties": {
    "allowlist": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "tokens", "reason"],
        "properties": {
          "file": { "type": "string" },
          "tokens": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
