#!/bin/bash
set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${GREEN}🚀 Starting ValueOS Ephemeral Environment...${NC}"
echo "============================================="

# Configuration
COMPOSE_FILE="infra/docker/docker-compose.dev.yml"
PROJECT_NAME="valueos"
ENVIRONMENTS_DIR="config/environments"
ENVIRONMENT="development"

# 1. Environment Check
echo -e "${BLUE}🔍 Checking environment...${NC}"

# Check if docker-compose is available
if ! command -v docker-compose &> /dev/null; then
    echo -e "${RED}❌ docker-compose not found. Please install Docker.${NC}"
    exit 1
fi

# Check if Docker is running
if ! docker info &> /dev/null; then
    echo -e "${RED}❌ Docker is not running. Please start Docker.${NC}"
    exit 1
fi

echo -e "${GREEN}✅ Docker environment ready${NC}"

# 2. Environment Configuration Loading
echo -e "${BLUE}🔧 Loading environment configuration...${NC}"

# Load base environment first
if [ -f "$ENVIRONMENTS_DIR/base.env" ]; then
    echo -e "${GREEN}✅ Loading base environment${NC}"
    set -a
    source "$ENVIRONMENTS_DIR/base.env"
    set +a
else
    echo -e "${RED}❌ Base environment file not found: $ENVIRONMENTS_DIR/base.env${NC}"
    exit 1
fi

# Load environment-specific overrides
if [ -f "$ENVIRONMENTS_DIR/$ENVIRONMENT.env" ]; then
    echo -e "${GREEN}✅ Loading $ENVIRONMENT environment overrides${NC}"
    set -a
    source "$ENVIRONMENTS_DIR/$ENVIRONMENT.env"
    set +a
else
    echo -e "${YELLOW}⚠️ Environment file not found: $ENVIRONMENTS_DIR/$ENVIRONMENT.env (using base only)${NC}"
fi

# Export NODE_ENV explicitly
export NODE_ENV=$ENVIRONMENT

# 3. Secret Management
echo -e "${BLUE}🔐 Setting up secrets...${NC}"

if [ -f ".env.local" ]; then
    echo -e "${GREEN}✅ Using existing .env.local${NC}"
else
    echo -e "${YELLOW}⚠️ No .env.local found${NC}"

    # Try Doppler if available
    if command -v doppler &> /dev/null && doppler whoami &> /dev/null; then
        echo -e "${BLUE}☁️ Fetching secrets from Doppler...${NC}"
        if doppler secrets download --project valueos-dev --config dev --no-file --format env > .env.local 2>/dev/null; then
            echo -e "${GREEN}✅ Secrets loaded from Doppler${NC}"
        else
            echo -e "${YELLOW}⚠️ Doppler secrets not configured, creating template...${NC}"
            cp .env.example .env.local
        fi
    else
        echo -e "${YELLOW}⚠️ Doppler secrets not configured, creating template...${NC}"
        cp .env.example .env.local
        echo -e "${YELLOW}💡 Consider setting up Doppler for secret management${NC}"
    fi
fi

# Override with environment-specific secrets if available
if [ -f "$ENVIRONMENTS_DIR/$ENVIRONMENT.env" ]; then
    echo -e "${BLUE}🔧 Merging environment-specific configuration...${NC}"
    # Environment variables from config files take precedence over Doppler secrets
    set -a
    source "$ENVIRONMENTS_DIR/$ENVIRONMENT.env"
    set +a
fi

# 3. Port Management
echo -e "${BLUE}🔌 Checking port availability...${NC}"

# Load ports from environment or use defaults
VITE_PORT=${VITE_PORT:-5173}
API_PORT=${API_PORT:-3001}
POSTGRES_PORT=${POSTGRES_PORT:-5432}
REDIS_PORT=${REDIS_PORT:-6379}

# Function to check if port is in use
check_port() {
    local port=$1
    local service=$2

    if lsof -i :$port &> /dev/null; then
        echo -e "${YELLOW}⚠️ Port $port ($service) is already in use${NC}"
        echo -e "${YELLOW}💡 Run: lsof -i :$port | grep LISTEN to see what's using it${NC}"
        return 1
    else
        return 0
    fi
}

# Check critical ports
port_conflicts=0
check_port $VITE_PORT "Frontend" || port_conflicts=$((port_conflicts + 1))
check_port $API_PORT "Backend API" || port_conflicts=$((port_conflicts + 1))
check_port $POSTGRES_PORT "PostgreSQL" || port_conflicts=$((port_conflicts + 1))
check_port $REDIS_PORT "Redis" || port_conflicts=$((port_conflicts + 1))

if [ $port_conflicts -gt 0 ]; then
    echo -e "${RED}❌ $port_conflicts port conflicts detected${NC}"
    echo -e "${YELLOW}💡 Resolve conflicts or use DX_ALLOW_PORT_IN_USE=1 to force start${NC}"

    if [ "$DX_ALLOW_PORT_IN_USE" = "1" ]; then
        echo -e "${YELLOW}⚠️ Starting despite port conflicts (DX_ALLOW_PORT_IN_USE=1)${NC}"
    else
        exit 1
    fi
else
    echo -e "${GREEN}✅ All required ports are available${NC}"
fi

# 4. Container Orchestration
echo -e "${BLUE}🐳 Starting containers...${NC}"

# Stop any existing containers
echo -e "${YELLOW}🔄 Stopping existing containers...${NC}"
docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME down --remove-orphans 2>/dev/null || true

# Start the services
echo -e "${YELLOW}🚀 Bringing up services...${NC}"
if docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME up -d --remove-orphans; then
    echo -e "${GREEN}✅ Containers started successfully${NC}"
else
    echo -e "${RED}❌ Failed to start containers${NC}"
    exit 1
fi

# 5. Health Check Wait
echo -e "${BLUE}⏳ Waiting for services to be healthy...${NC}"

# Function to wait for service health
wait_for_service() {
    local service_name=$1
    local max_attempts=30
    local attempt=1

    echo -n "  Waiting for $service_name..."

    while [ $attempt -le $max_attempts ]; do
        if docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME ps -q $service_name | xargs -r docker inspect --format='{{.State.Health.Status}}' 2>/dev/null | grep -q "healthy"; then
            echo -e " ${GREEN}✅${NC}"
            return 0
        fi

        echo -n "."
        sleep 2
        attempt=$((attempt + 1))
    done

    echo -e " ${RED}❌ Timeout${NC}"
    return 1
}

# Wait for core services
services_failed=0
wait_for_service "postgres" || services_failed=$((services_failed + 1))
wait_for_service "redis" || services_failed=$((services_failed + 1))
wait_for_service "backend" || services_failed=$((services_failed + 1))

if [ $services_failed -gt 0 ]; then
    echo -e "${RED}❌ $services_failed services failed to become healthy${NC}"
    echo -e "${YELLOW}💡 Check logs: docker-compose -f $COMPOSE_FILE logs${NC}"
else
    echo -e "${GREEN}✅ All services are healthy${NC}"
fi

# 6. Database Setup
echo -e "${BLUE}🗄️ Setting up database...${NC}"

# Wait a bit more for database to be fully ready
sleep 5

# Check if database is accessible
if docker exec valueos-postgres pg_isready -U postgres -d valuecanvas_dev &> /dev/null; then
    echo -e "${GREEN}✅ Database is ready${NC}"

    # Run migrations if they exist
    if [ -f "package.json" ] && grep -q "db:push" package.json; then
        echo -e "${YELLOW}🔄 Running database migrations...${NC}"
        if pnpm run db:push &> /dev/null; then
            echo -e "${GREEN}✅ Migrations completed${NC}"
        else
            echo -e "${YELLOW}⚠️ Migration failed (may be normal for first run)${NC}"
        fi
    fi

    # Seed data if script exists
    if [ -f "scripts/seed-development-data.sh" ]; then
        echo -e "${YELLOW}🌱 Seeding development data...${NC}"
        if bash scripts/seed-development-data.sh &> /dev/null; then
            echo -e "${GREEN}✅ Development data seeded${NC}"
        else
            echo -e "${YELLOW}⚠️ Data seeding failed${NC}"
        fi
    fi
else
    echo -e "${RED}❌ Database is not accessible${NC}"
fi

# 7. Final Health Check
echo -e "${BLUE}🏥 Running final health check...${NC}"

# Function to check HTTP endpoint
check_endpoint() {
    local url=$1
    local name=$2
    local max_attempts=10
    local attempt=1

    echo -n "  Checking $name..."

    while [ $attempt -le $max_attempts ]; do
        if curl -f -s $url > /dev/null 2>&1; then
            echo -e " ${GREEN}✅${NC}"
            return 0
        fi

        echo -n "."
        sleep 2
        attempt=$((attempt + 1))
    done

    echo -e " ${RED}❌${NC}"
    return 1
}

# Check endpoints
check_endpoint "http://localhost:$API_PORT/health" "Backend API"
check_endpoint "http://localhost:$VITE_PORT" "Frontend"

# 8. Success Summary
echo ""
echo -e "${GREEN}⭐ ValueOS is ready!${NC}"
echo "=================="
echo -e "${BLUE}🌐 Services:${NC}"
echo "  Frontend:    http://localhost:$VITE_PORT"
echo "  Backend:     http://localhost:$API_PORT"
echo "  Database:    localhost:$POSTGRES_PORT"
echo "  Redis:       localhost:$REDIS_PORT"
echo ""
echo -e "${BLUE}🔧 Management commands:${NC}"
echo "  dev-down     - Stop all services"
echo "  dev-logs     - View service logs"
echo "  dev-ps       - Show service status"
echo "  health-check - Run health check"
echo ""
echo -e "${BLUE}🔗 Useful links:${NC}"
echo "  API Health:  http://localhost:$API_PORT/health"
echo "  API Docs:    http://localhost:$API_PORT/api-docs"
echo ""
echo -e "${GREEN}🎉 Happy coding!${NC}"
