#!/bin/bash
set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${GREEN}ЁЯЪА Starting ValueOS Production Environment...${NC}"
echo "=========================================="

# Configuration
COMPOSE_FILE="infra/docker/docker-compose.prod.yml"
PROJECT_NAME="valueos-prod"
ENVIRONMENTS_DIR="config/environments"
ENVIRONMENT="production"

# 1. Environment Check
echo -e "${BLUE}ЁЯФН Checking production environment...${NC}"

# Check if docker-compose is available
if ! command -v docker-compose &> /dev/null; then
    echo -e "${RED}тЭМ docker-compose not found. Please install Docker.${NC}"
    exit 1
fi

# Check if Docker is running
if ! docker info &> /dev/null; then
    echo -e "${RED}тЭМ Docker is not running. Please start Docker.${NC}"
    exit 1
fi

# Check if running in production mode
if [ "$NODE_ENV" != "production" ] && [ "$FORCE_PROD" != "1" ]; then
    echo -e "${YELLOW}тЪая╕П Not in production mode. Use FORCE_PROD=1 to override.${NC}"
    echo -e "${YELLOW}ЁЯТб This is a safety check to prevent accidental production deployments${NC}"
    exit 1
fi

echo -e "${GREEN}тЬЕ Production environment ready${NC}"

# 2. Environment Configuration Loading
echo -e "${BLUE}ЁЯФз Loading production environment configuration...${NC}"

# Load base environment first
if [ -f "$ENVIRONMENTS_DIR/base.env" ]; then
    echo -e "${GREEN}тЬЕ Loading base environment${NC}"
    set -a
    source "$ENVIRONMENTS_DIR/base.env"
    set +a
else
    echo -e "${RED}тЭМ Base environment file not found: $ENVIRONMENTS_DIR/base.env${NC}"
    exit 1
fi

# Load production-specific overrides
if [ -f "$ENVIRONMENTS_DIR/$ENVIRONMENT.env" ]; then
    echo -e "${GREEN}тЬЕ Loading $ENVIRONMENT environment overrides${NC}"
    set -a
    source "$ENVIRONMENTS_DIR/$ENVIRONMENT.env"
    set +a
else
    echo -e "${RED}тЭМ Production environment file not found: $ENVIRONMENTS_DIR/$ENVIRONMENT.env${NC}"
    exit 1
fi

# Export NODE_ENV explicitly
export NODE_ENV=$ENVIRONMENT

# 3. Production Security Checks
echo -e "${BLUE}ЁЯФТ Running production security checks...${NC}"

# Check for required production secrets
required_secrets=("JWT_SECRET" "ENCRYPTION_KEY" "VITE_SUPABASE_ANON_KEY" "SUPABASE_SERVICE_ROLE_KEY")
missing_secrets=()

for secret in "${required_secrets[@]}"; do
    if [ -z "${!secret}" ]; then
        echo -e "${RED}тЭМ Missing required production secret: $secret${NC}"
        missing_secrets+=("$secret")
    fi
done

if [ ${#missing_secrets[@]} -gt 0 ]; then
    echo -e "${RED}тЭМ Production setup incomplete. Missing secrets:${NC}"
    printf '%s\n' "${missing_secrets[@]}"
    echo -e "${YELLOW}ЁЯТб Ensure all required secrets are configured in Doppler or environment variables${NC}"
    exit 1
else
    echo -e "${GREEN}тЬЕ All required production secrets are configured${NC}"
fi

# 4. Secret Management
echo -e "${BLUE}ЁЯФР Setting up production secrets...${NC}"

# Try Doppler for production secrets
if command -v doppler &> /dev/null && doppler whoami &> /dev/null; then
    echo -e "${BLUE}тШБя╕П Fetching production secrets from Doppler...${NC}"
    if doppler secrets download --project valueos-prod --config production --no-file --format env > .env.local 2>/dev/null; then
        echo -e "${GREEN}тЬЕ Production secrets loaded from Doppler${NC}"
    else
        echo -e "${RED}тЭМ Failed to load production secrets from Doppler${NC}"
        exit 1
    fi
else
    echo -e "${RED}тЭМ Doppler not configured for production${NC}"
    echo -e "${YELLOW}ЁЯТб Doppler is required for production secret management${NC}"
    exit 1
fi

# Override with production-specific configuration
if [ -f "$ENVIRONMENTS_DIR/$ENVIRONMENT.env" ]; then
    echo -e "${BLUE}ЁЯФз Merging production-specific configuration...${NC}"
    # Environment variables from config files take precedence over Doppler secrets
    set -a
    source "$ENVIRONMENTS_DIR/$ENVIRONMENT.env"
    set +a
fi

# 5. Production Port Management
echo -e "${BLUE}ЁЯФМ Checking production port availability...${NC}"

# Use production ports from environment
VITE_PORT=${VITE_PORT:-80}
API_PORT=${API_PORT:-443}
POSTGRES_PORT=${POSTGRES_PORT:-5432}
REDIS_PORT=${REDIS_PORT:-6379}

# Function to check if port is in use
check_port() {
    local port=$1
    local service=$2

    if lsof -i :$port &> /dev/null; then
        echo -e "${RED}тЭМ Port $port ($service) is already in use - this is a production issue!${NC}"
        echo -e "${RED}ЁЯТб Production ports must be available. Check for other services.${NC}"
        return 1
    else
        return 0
    fi
}

# Check critical production ports
port_conflicts=0
check_port $VITE_PORT "Frontend" || port_conflicts=$((port_conflicts + 1))
check_port $API_PORT "Backend API" || port_conflicts=$((port_conflicts + 1))
check_port $POSTGRES_PORT "PostgreSQL" || port_conflicts=$((port_conflicts + 1))
check_port $REDIS_PORT "Redis" || port_conflicts=$((port_conflicts + 1))

if [ $port_conflicts -gt 0 ]; then
    echo -e "${RED}тЭМ $port_conflicts production port conflicts detected${NC}"
    echo -e "${RED}ЁЯТб Production ports must be available. This is a critical issue.${NC}"
    exit 1
else
    echo -e "${GREEN}тЬЕ All production ports are available${NC}"
fi

# 6. Production Container Orchestration
echo -e "${BLUE}ЁЯР│ Starting production containers...${NC}"

# Stop any existing containers
echo -e "${YELLOW}ЁЯФД Stopping existing containers...${NC}"
docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME down --remove-orphans 2>/dev/null || true

# Start the services
echo -e "${YELLOW}ЁЯЪА Bringing up production services...${NC}"
if docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME up -d --remove-orphans; then
    echo -e "${GREEN}тЬЕ Production containers started successfully${NC}"
else
    echo -e "${RED}тЭМ Failed to start production containers${NC}"
    exit 1
fi

# 7. Production Health Check Wait
echo -e "${BLUE}тП│ Waiting for production services to be healthy...${NC}"

# Function to wait for service health
wait_for_service() {
    local service_name=$1
    local max_attempts=60  # Longer wait for production
    local attempt=1

    echo -n "  Waiting for $service_name..."

    while [ $attempt -le $max_attempts ]; do
        if docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME ps -q $service_name | xargs -r docker inspect --format='{{.State.Health.Status}}' 2>/dev/null | grep -q "healthy"; then
            echo -e " ${GREEN}тЬЕ${NC}"
            return 0
        fi

        echo -n "."
        sleep 3  # Longer wait for production
        attempt=$((attempt + 1))
    done

    echo -e " ${RED}тЭМ Timeout${NC}"
    return 1
}

# Wait for core services
services_failed=0
wait_for_service "postgres" || services_failed=$((services_failed + 1))
wait_for_service "redis" || services_failed=$((services_failed + 1))
wait_for_service "backend" || services_failed=$((services_failed + 1))

if [ $services_failed -gt 0 ]; then
    echo -e "${RED}тЭМ $services_failed production services failed to become healthy${NC}"
    echo -e "${RED}ЁЯТб This is a production issue. Check logs immediately.${NC}"
    echo -e "${YELLOW}ЁЯТб Check logs: docker-compose -f $COMPOSE_FILE logs${NC}"
    exit 1
else
    echo -e "${GREEN}тЬЕ All production services are healthy${NC}"
fi

# 8. Production Database Setup
echo -e "${BLUE}ЁЯЧДя╕П Setting up production database...${NC}"

# Wait for database to be fully ready
sleep 10

# Check if production database is accessible
if docker exec ${PROJECT_NAME}-postgres-1 pg_isready -U postgres -d valueos_prod &> /dev/null; then
    echo -e "${GREEN}тЬЕ Production database is ready${NC}"

    # Run production migrations
    if [ -f "package.json" ] && grep -q "db:push" package.json; then
        echo -e "${YELLOW}ЁЯФД Running production database migrations...${NC}"
        if pnpm run db:push; then
            echo -e "${GREEN}тЬЕ Production migrations completed${NC}"
        else
            echo -e "${RED}тЭМ Production migration failed - this is critical${NC}"
            exit 1
        fi
    fi
else
    echo -e "${RED}тЭМ Production database is not accessible${NC}"
    exit 1
fi

# 9. Production Final Health Check
echo -e "${BLUE}ЁЯПе Running production final health check...${NC}"

# Function to check HTTP endpoint
check_endpoint() {
    local url=$1
    local name=$2
    local max_attempts=15  # More attempts for production
    local attempt=1

    echo -n "  Checking $name..."

    while [ $attempt -le $max_attempts ]; do
        if curl -f -s $url > /dev/null 2>&1; then
            echo -e " ${GREEN}тЬЕ${NC}"
            return 0
        fi

        echo -n "."
        sleep 3  # Longer wait for production
        attempt=$((attempt + 1))
    done

    echo -e " ${RED}тЭМ${NC}"
    return 1
}

# Check endpoints
check_endpoint "http://localhost:$API_PORT/health" "Backend API"
check_endpoint "http://localhost:$VITE_PORT" "Frontend"

# 10. Production Success Summary
echo ""
echo -e "${GREEN}тнР ValueOS Production is LIVE!${NC}"
echo "========================="
echo -e "${BLUE}ЁЯМР Production Services:${NC}"
echo "  Frontend:    https://$APP_DOMAIN"
echo "  Backend:     https://$APP_DOMAIN/api"
echo "  Database:    Internal (port $POSTGRES_PORT)"
echo "  Redis:       Internal (port $REDIS_PORT)"
echo ""
echo -e "${BLUE}ЁЯФз Production Management:${NC}"
echo "  prod-down     - Stop all production services"
echo "  prod-logs     - View production service logs"
echo "  prod-ps       - Show production service status"
echo "  prod-health   - Run production health check"
echo ""
echo -e "${BLUE}ЁЯФЧ Production Links:${NC}"
echo "  API Health:  https://$APP_DOMAIN/api/health"
echo "  API Docs:    https://$APP_DOMAIN/api-docs"
echo ""
echo -e "${GREEN}ЁЯОЙ Production deployment successful!${NC}"
echo -e "${BLUE}ЁЯУК Monitoring and observability are active${NC}"
