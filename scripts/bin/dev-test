#!/bin/bash
set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${GREEN}рЯІ™ Starting ValueOS Test Environment...${NC}"
echo "=========================================="

# Configuration
COMPOSE_FILE="infra/docker/docker-compose.test.yml"
PROJECT_NAME="valueos-test"
ENVIRONMENTS_DIR="config/environments"
ENVIRONMENT="test"

# 1. Environment Check
echo -e "${BLUE}рЯФН Checking test environment...${NC}"

# Check if docker-compose is available
if ! command -v docker-compose &> /dev/null; then
    echo -e "${RED}вЭМ docker-compose not found. Please install Docker.${NC}"
    exit 1
fi

# Check if Docker is running
if ! docker info &> /dev/null; then
    echo -e "${RED}вЭМ Docker is not running. Please start Docker.${NC}"
    exit 1
fi

echo -e "${GREEN}вЬЕ Docker environment ready${NC}"

# 2. Environment Configuration Loading
echo -e "${BLUE}рЯФІ Loading test environment configuration...${NC}"

# Load base environment first
if [ -f "$ENVIRONMENTS_DIR/base.env" ]; then
    echo -e "${GREEN}вЬЕ Loading base environment${NC}"
    set -a
    source "$ENVIRONMENTS_DIR/base.env"
    set +a
else
    echo -e "${RED}вЭМ Base environment file not found: $ENVIRONMENTS_DIR/base.env${NC}"
    exit 1
fi

# Load test-specific overrides
if [ -f "$ENVIRONMENTS_DIR/$ENVIRONMENT.env" ]; then
    echo -e "${GREEN}вЬЕ Loading $ENVIRONMENT environment overrides${NC}"
    set -a
    source "$ENVIRONMENTS_DIR/$ENVIRONMENT.env"
    set +a
else
    echo -e "${YELLOW}вЪ†пЄП Environment file not found: $ENVIRONMENTS_DIR/$ENVIRONMENT.env (using base only)${NC}"
fi

# Export NODE_ENV explicitly
export NODE_ENV=$ENVIRONMENT

# 3. Test Secret Management
echo -e "${BLUE}рЯФР Setting up test secrets...${NC}"

# Use test secrets from environment or create mock secrets
if [ -f ".env.local" ]; then
    echo -e "${GREEN}вЬЕ Using existing .env.local${NC}"
else
    echo -e "${YELLOW}вЪ†пЄП No .env.local found, creating test secrets...${NC}"

    # Create test secrets (not using Doppler for test environment)
    cat > .env.local << EOF
# Test Environment Secrets (Mock Values)
JWT_SECRET=test-jwt-secret-for-testing-only
ENCRYPTION_KEY=test-encryption-key-for-testing-only
VITE_SUPABASE_URL=http://localhost:54322
VITE_SUPABASE_ANON_KEY=test-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key
TOGETHER_API_KEY=test-together-api-key
OPENAI_API_KEY=test-openai-api-key
ANTHROPIC_API_KEY=test-anthropic-api-key
EOF
    echo -e "${GREEN}вЬЕ Test secrets created${NC}"
fi

# Override with test-specific configuration
if [ -f "$ENVIRONMENTS_DIR/$ENVIRONMENT.env" ]; then
    echo -e "${BLUE}рЯФІ Merging test-specific configuration...${NC}"
    set -a
    source "$ENVIRONMENTS_DIR/$ENVIRONMENT.env"
    set +a
fi

# 4. Test Port Management
echo -e "${BLUE}рЯФМ Checking test port availability...${NC}"

# Load ports from environment or use test defaults
VITE_PORT=${VITE_PORT:-5175}
API_PORT=${API_PORT:-3003}
POSTGRES_PORT=${POSTGRES_PORT:-5434}
REDIS_PORT=${REDIS_PORT:-6381}

# Function to check if port is in use
check_port() {
    local port=$1
    local service=$2

    if lsof -i :$port &> /dev/null; then
        echo -e "${YELLOW}вЪ†пЄП Port $port ($service) is already in use${NC}"
        echo -e "${YELLOW}рЯТ° Test environment requires isolated ports${NC}"
        return 1
    else
        return 0
    fi
}

# Check critical test ports
port_conflicts=0
check_port $VITE_PORT "Frontend" || port_conflicts=$((port_conflicts + 1))
check_port $API_PORT "Backend API" || port_conflicts=$((port_conflicts + 1))
check_port $POSTGRES_PORT "PostgreSQL" || port_conflicts=$((port_conflicts + 1))
check_port $REDIS_PORT "Redis" || port_conflicts=$((port_conflicts + 1))

if [ $port_conflicts -gt 0 ]; then
    echo -e "${RED}вЭМ $port_conflicts test port conflicts detected${NC}"
    echo -e "${YELLOW}рЯТ° Test environment requires isolated ports. Resolve conflicts or use different ports.${NC}"
    exit 1
else
    echo -e "${GREEN}вЬЕ All test ports are available${NC}"
fi

# 5. Test Container Orchestration
echo -e "${BLUE}рЯР≥ Starting test containers...${NC}"

# Stop any existing test containers
echo -e "${YELLOW}рЯФД Stopping existing test containers...${NC}"
docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME down --remove-orphans 2>/dev/null || true

# Start the services
echo -e "${YELLOW}рЯЪА Bringing up test services...${NC}"
if docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME up -d --remove-orphans; then
    echo -e "${GREEN}вЬЕ Test containers started successfully${NC}"
else
    echo -e "${RED}вЭМ Failed to start test containers${NC}"
    exit 1
fi

# 6. Test Health Check Wait
echo -e "${BLUE}вП≥ Waiting for test services to be healthy...${NC}"

# Function to wait for service health (shorter timeout for tests)
wait_for_service() {
    local service_name=$1
    local max_attempts=15  # Shorter wait for test environment
    local attempt=1

    echo -n "  Waiting for $service_name..."

    while [ $attempt -le $max_attempts ]; do
        if docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME ps -q $service_name | xargs -r docker inspect --format='{{.State.Health.Status}}' 2>/dev/null | grep -q "healthy"; then
            echo -e " ${GREEN}вЬЕ${NC}"
            return 0
        fi

        echo -n "."
        sleep 1  # Faster wait for test environment
        attempt=$((attempt + 1))
    done

    echo -e " ${RED}вЭМ Timeout${NC}"
    return 1
}

# Wait for core services
services_failed=0
wait_for_service "postgres" || services_failed=$((services_failed + 1))
wait_for_service "redis" || services_failed=$((services_failed + 1))
wait_for_service "backend" || services_failed=$((services_failed + 1))

if [ $services_failed -gt 0 ]; then
    echo -e "${RED}вЭМ $services_failed test services failed to become healthy${NC}"
    echo -e "${YELLOW}рЯТ° Check logs: docker-compose -f $COMPOSE_FILE logs${NC}"
else
    echo -e "${GREEN}вЬЕ All test services are healthy${NC}"
fi

# 7. Test Database Setup
echo -e "${BLUE}рЯЧДпЄП Setting up test database...${NC}"

# Wait for database to be ready
sleep 3

# Check if test database is accessible
if docker exec ${PROJECT_NAME}-postgres-1 pg_isready -U postgres -d valueos_test &> /dev/null; then
    echo -e "${GREEN}вЬЕ Test database is ready${NC}"

    # Run test migrations
    if [ -f "package.json" ] && grep -q "db:push" package.json; then
        echo -e "${YELLOW}рЯФД Running test database migrations...${NC}"
        if pnpm run db:push &> /dev/null; then
            echo -e "${GREEN}вЬЕ Test migrations completed${NC}"
        else
            echo -e "${YELLOW}вЪ†пЄП Migration failed (may be normal for test setup)${NC}"
        fi
    fi

    # Seed test data if script exists
    if [ -f "scripts/seed-test-data.sh" ]; then
        echo -e "${YELLOW}рЯМ± Seeding test data...${NC}"
        if bash scripts/seed-test-data.sh &> /dev/null; then
            echo -e "${GREEN}вЬЕ Test data seeded${NC}"
        else
            echo -e "${YELLOW}вЪ†пЄП Test data seeding failed${NC}"
        fi
    fi
else
    echo -e "${RED}вЭМ Test database is not accessible${NC}"
    exit 1
fi

# 8. Test Final Health Check
echo -e "${BLUE}рЯП• Running test final health check...${NC}"

# Function to check HTTP endpoint
check_endpoint() {
    local url=$1
    local name=$2
    local max_attempts=5  # Very fast wait for test environment
    local attempt=1

    echo -n "  Checking $name..."

    while [ $attempt -le $max_attempts ]; do
        if curl -f -s $url > /dev/null 2>&1; then
            echo -e " ${GREEN}вЬЕ${NC}"
            return 0
        fi

        echo -n "."
        sleep 1  # Very fast wait for test environment
        attempt=$((attempt + 1))
    done

    echo -e " ${RED}вЭМ${NC}"
    return 1
}

# Check endpoints
check_endpoint "http://localhost:$API_PORT/health" "Backend API"
check_endpoint "http://localhost:$VITE_PORT" "Frontend"

# 9. Test Success Summary
echo ""
echo -e "${GREEN}в≠Р ValueOS Test Environment Ready!${NC}"
echo "================================="
echo -e "${BLUE}рЯІ™ Test Services:${NC}"
echo "  Frontend:    http://localhost:$VITE_PORT"
echo "  Backend:     http://localhost:$API_PORT"
echo "  Database:    localhost:$POSTGRES_PORT"
echo "  Redis:       localhost:$REDIS_PORT"
echo ""
echo -e "${BLUE}рЯФІ Test Management:${NC}"
echo "  test-down     - Stop all test services"
echo "  test-logs     - View test service logs"
echo "  test-ps       - Show test service status"
echo "  test-health   - Run test health check"
echo ""
echo -e "${BLUE}рЯФЧ Test Links:${NC}"
echo "  API Health:  http://localhost:$API_PORT/health"
echo "  API Docs:    http://localhost:$API_PORT/api-docs"
echo ""
echo -e "${GREEN}рЯІ™ Test environment ready for testing!${NC}"
echo -e "${BLUE}рЯТ° Run tests with: pnpm test${NC}"
