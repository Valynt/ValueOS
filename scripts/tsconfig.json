{
  // Keep the scripts project scoped to this tree while inheriting the root
  // TypeScript defaults and workspace-level type resolution.
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
