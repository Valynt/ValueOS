{
  // Standalone tsconfig for the aging scripts/ directory.  It intentionally
  // does *not* extend the root config because the parent includes `src`
  // and `packages/*/src`, causing `pnpm run typecheck:scripts` to check
  // the entire repo instead of just the scripts tree.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "../src/*"
      ]
    },
    "types": [
      "node",
      "vitest"
    ]
  },
  "include": [
    "**/*",
    "stubs.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "app/**",
    "legacy/**",
    "dev/**",
    "ci/**"
  ]
}
