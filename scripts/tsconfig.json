{
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vitest"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.mts",
    "**/*.tsx",
    "**/*.mjs",
    "**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
