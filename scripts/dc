#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

COMPOSE_FILE="${REPO_ROOT}/scripts/docker-compose.yml"
LOCAL_ENV_FILE="${REPO_ROOT}/.env.local"
ROOT_PORTS_ENV_FILE="${REPO_ROOT}/.env.ports"
ROOT_PORTS_ENV_EXAMPLE="${REPO_ROOT}/.env.ports.example"
LEGACY_PORTS_ENV_FILE="${REPO_ROOT}/scripts/.env.ports"
LEGACY_PORTS_ENV_EXAMPLE="${REPO_ROOT}/scripts/.env.ports.example"

[[ -f "${COMPOSE_FILE}" ]] || { echo "Missing compose file: ${COMPOSE_FILE}" >&2; exit 1; }

DOCKER_BIN="$(command -v docker 2>/dev/null || true)"
[[ -n "${DOCKER_BIN}" && -x "${DOCKER_BIN}" ]] || {
  echo "Docker CLI not found in PATH. Install Docker and ensure 'docker' is executable." >&2
  exit 127
}

compose_args=(
  --project-name valueos
  --project-directory "${REPO_ROOT}"
  -f "${COMPOSE_FILE}"
)

if [[ -f "${LOCAL_ENV_FILE}" ]]; then
  compose_args+=(--env-file "${LOCAL_ENV_FILE}")
fi

if [[ -f "${ROOT_PORTS_ENV_FILE}" ]]; then
  compose_args+=(--env-file "${ROOT_PORTS_ENV_FILE}")
elif [[ -f "${LEGACY_PORTS_ENV_FILE}" ]]; then
  compose_args+=(--env-file "${LEGACY_PORTS_ENV_FILE}")
elif [[ -f "${ROOT_PORTS_ENV_EXAMPLE}" ]]; then
  compose_args+=(--env-file "${ROOT_PORTS_ENV_EXAMPLE}")
elif [[ -f "${LEGACY_PORTS_ENV_EXAMPLE}" ]]; then
  compose_args+=(--env-file "${LEGACY_PORTS_ENV_EXAMPLE}")
fi

exec "${DOCKER_BIN}" compose "${compose_args[@]}" "$@"
