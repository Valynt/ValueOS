#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
COMPOSE_FILE="$REPO_ROOT/scripts/docker-compose.yml"
PORTS_ENV_FILE="$REPO_ROOT/scripts/.env.ports"
PORTS_ENV_EXAMPLE="$REPO_ROOT/scripts/.env.ports.example"

compose_args=(
  --project-name valueos
  --project-directory "$REPO_ROOT"
  -f "$COMPOSE_FILE"
)

if [ -f "$PORTS_ENV_FILE" ]; then
  compose_args+=(--env-file "$PORTS_ENV_FILE")
elif [ -f "$PORTS_ENV_EXAMPLE" ]; then
  compose_args+=(--env-file "$PORTS_ENV_EXAMPLE")
fi

exec docker compose "${compose_args[@]}" "$@"
