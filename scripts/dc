#!/usr/bin/env bash
set -euo pipefail

# Docker Compose wrapper for ValueOS infrastructure orchestration only.
# Application services should run via package scripts unless explicitly using the legacy stack.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

COMPOSE_FILE="${ROOT}/ops/compose/compose.yml"
APP_ENV_FILE="${ROOT}/ops/env/.env.local"
SUPABASE_PROFILE_COMPOSE_FILE="${ROOT}/ops/compose/profiles/supabase.yml"
OBSERVABILITY_PROFILE_COMPOSE_FILE="${ROOT}/ops/compose/profiles/observability.yml"

# Optional profile overlays (profile => compose file).
# These files add services and/or settings that are not present in the base compose file.
declare -A PROFILE_COMPOSE_FILES=(
  [caddy]="${ROOT}/ops/compose/profiles/caddy.yml"
  [devcontainer]="${ROOT}/ops/compose/profiles/devcontainer.yml"
  [observability]="${OBSERVABILITY_PROFILE_COMPOSE_FILE}"
  [runtime-docker]="${ROOT}/ops/compose/profiles/runtime-docker.yml"
  [studio]="${ROOT}/ops/compose/profiles/studio.yml"
  [supabase]="${SUPABASE_PROFILE_COMPOSE_FILE}"
  [tools]="${ROOT}/ops/compose/profiles/tools.yml"
)

ENV_FILE="${ROOT}/ops/env/.env.ports"
LEGACY_ENV_FILE="${ROOT}/.env.ports"

[[ -f "${COMPOSE_FILE}" ]] || { echo "Missing compose file: ${COMPOSE_FILE}" >&2; exit 1; }

DOCKER_BIN="$(command -v docker 2>/dev/null || true)"
[[ -n "${DOCKER_BIN}" && -x "${DOCKER_BIN}" ]] || {
  echo "Docker CLI not found in PATH. Install Docker and ensure 'docker' is executable." >&2
  exit 127
}

show_usage() {
  cat <<'EOF'
Usage: dc [docker compose args]

Wrapper around `docker compose` using:
  --project-name valueos
  --project-directory <repo-root>
  -f ops/compose/compose.yml

Env files:
  * ops/env/.env.local      (optional app-level env vars)
  * ops/env/.env.ports      (preferred deterministic port bindings)
  * .env.ports              (legacy fallback)

Profiles:
  * No implicit default profile is added.
  * You may pass `--profile <name>` directly; those flags are forwarded unchanged.
  * If VALUEOS_PROFILES is set, its comma-separated values are forwarded as
    `--profile` flags (unless CLI `--profile` is already present).

Supported profile names and compose-file mapping:
  * supabase       -> ops/compose/profiles/supabase.yml
  * observability  -> ops/compose/profiles/observability.yml
  * studio         -> ops/compose/profiles/studio.yml
  * tools          -> ops/compose/profiles/tools.yml
  * caddy          -> ops/compose/profiles/caddy.yml
  * devcontainer   -> ops/compose/profiles/devcontainer.yml
  * runtime-docker -> ops/compose/profiles/runtime-docker.yml
  * validate       -> passed through as docker compose profile (no extra overlay file)

Compose overlays:
  * Overlay files are auto-added when their profile appears in VALUEOS_PROFILES
    or is passed via CLI `--profile`.

Examples:
  dc up -d
  VALUEOS_PROFILES=observability dc up -d
  dc --profile validate up -d
  VALUEOS_PROFILES=supabase,observability dc up -d
EOF
}

if [[ "${1:-}" == "help" || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  show_usage
  exit 0
fi

compose_args=(
  --project-name valueos
  --project-directory "${ROOT}"
  -f "${COMPOSE_FILE}"
)

# Gather profiles from CLI args first.
has_profile_arg=false
explicit_profiles=()
expect_profile_value=false
for arg in "$@"; do
  if [[ "${expect_profile_value}" == "true" ]]; then
    explicit_profiles+=("${arg}")
    expect_profile_value=false
    continue
  fi

  if [[ "${arg}" == "--profile" || "${arg}" == --profile=* ]]; then
    has_profile_arg=true
    if [[ "${arg}" == "--profile" ]]; then
      expect_profile_value=true
    else
      explicit_profiles+=("${arg#--profile=}")
    fi
  fi
done

env_profiles=()
if [[ -n "${VALUEOS_PROFILES:-}" ]]; then
  IFS=',' read -r -a env_profiles <<< "${VALUEOS_PROFILES}"
fi

# Add optional overlay compose files based on profile names from CLI and env.
profiles_for_overlay=("${explicit_profiles[@]}" "${env_profiles[@]}")
added_overlays=()
for profile in "${profiles_for_overlay[@]}"; do
  profile="$(echo "${profile}" | xargs)"
  [[ -n "${profile}" ]] || continue

  overlay_file="${PROFILE_COMPOSE_FILES[${profile}]:-}"
  if [[ -n "${overlay_file}" && -f "${overlay_file}" ]]; then
    already_added=false
    for added in "${added_overlays[@]}"; do
      if [[ "${added}" == "${overlay_file}" ]]; then
        already_added=true
        break
      fi
    done

    if [[ "${already_added}" == "false" ]]; then
      compose_args+=( -f "${overlay_file}" )
      added_overlays+=("${overlay_file}")
    fi
  fi
done

# If the caller explicitly sets a profile flag, don't auto-add profile flags from env.
if [[ "${has_profile_arg}" == "false" ]]; then
  for profile in "${env_profiles[@]}"; do
    profile="$(echo "${profile}" | xargs)"
    if [[ -n "${profile}" ]]; then
      compose_args+=(--profile "${profile}")
    fi
  done
fi

# Optional app-level env vars (non-port settings).
if [[ -f "${APP_ENV_FILE}" ]]; then
  compose_args+=(--env-file "${APP_ENV_FILE}")
fi

# Preferred deterministic port bindings for this repo (with legacy fallback).
if [[ -f "${ENV_FILE}" ]]; then
  compose_args+=(--env-file "${ENV_FILE}")
elif [[ -f "${LEGACY_ENV_FILE}" ]]; then
  compose_args+=(--env-file "${LEGACY_ENV_FILE}")
fi

exec "${DOCKER_BIN}" compose "${compose_args[@]}" "$@"
