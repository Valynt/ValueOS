#!/usr/bin/env bash
set -euo pipefail

# Docker Compose wrapper for ValueOS infrastructure orchestration only.
# Application services should run via package scripts unless explicitly using the legacy stack.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

COMPOSE_FILE="${ROOT}/ops/compose/compose.yml"
APP_ENV_FILE="${ROOT}/ops/env/.env.local"
SUPABASE_PROFILE_COMPOSE_FILE="${ROOT}/ops/compose/profiles/supabase.yml"
OBSERVABILITY_PROFILE_COMPOSE_FILE="${ROOT}/ops/compose/profiles/observability.yml"

ENV_FILE="${ROOT}/ops/env/.env.ports"
LEGACY_ENV_FILE="${ROOT}/.env.ports"
ENV_EXAMPLE_FILE="${ROOT}/ops/env/.env.ports.example"

[[ -f "${COMPOSE_FILE}" ]] || { echo "Missing compose file: ${COMPOSE_FILE}" >&2; exit 1; }

DOCKER_BIN="$(command -v docker 2>/dev/null || true)"
[[ -n "${DOCKER_BIN}" && -x "${DOCKER_BIN}" ]] || {
  echo "Docker CLI not found in PATH. Install Docker and ensure 'docker' is executable." >&2
  exit 127
}

compose_args=(
  --project-name valueos
  --project-directory "${ROOT}"
  -f "${COMPOSE_FILE}"
)

if [[ ",${VALUEOS_PROFILES:-}," == *",supabase,"* ]]; then
  compose_args+=( -f "${SUPABASE_PROFILE_COMPOSE_FILE}" )
fi

if [[ ",${VALUEOS_PROFILES:-}," == *",observability,"* ]]; then
  compose_args+=( -f "${OBSERVABILITY_PROFILE_COMPOSE_FILE}" )
fi

has_profile_arg=false
for arg in "$@"; do
  if [[ "${arg}" == "--profile" || "${arg}" == --profile=* ]]; then
    has_profile_arg=true
    break
  fi
done

if [[ "${has_profile_arg}" == "false" ]]; then
  profiles=()
  if [[ -n "${VALUEOS_PROFILES:-}" ]]; then
    IFS=',' read -r -a profiles <<< "${VALUEOS_PROFILES}"
  elif [[ -n "${DEVCONTAINER:-}" || -n "${REMOTE_CONTAINERS:-}" || -n "${CODESPACES:-}" ]]; then
    profiles=("devcontainer")
  elif [[ -f "/.dockerenv" && -d "${ROOT}/.devcontainer" ]]; then
    profiles=("devcontainer")
  else
    profiles=("dev")
  fi

  for profile in "${profiles[@]}"; do
    if [[ -n "${profile}" ]]; then
      compose_args+=(--profile "${profile}")
    fi
  done
fi

# Optional app-level env vars (non-port settings).
if [[ -f "${APP_ENV_FILE}" ]]; then
  compose_args+=(--env-file "${APP_ENV_FILE}")
fi

# Preferred deterministic port bindings for this repo (with legacy + example fallbacks).
if [[ -f "${ENV_FILE}" ]]; then
  compose_args+=(--env-file "${ENV_FILE}")
elif [[ -f "${LEGACY_ENV_FILE}" ]]; then
  compose_args+=(--env-file "${LEGACY_ENV_FILE}")
elif [[ -f "${ENV_EXAMPLE_FILE}" ]]; then
  compose_args+=(--env-file "${ENV_EXAMPLE_FILE}")
fi

exec "${DOCKER_BIN}" compose "${compose_args[@]}" "$@"
