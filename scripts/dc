#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

COMPOSE_FILE="${PROJECT_ROOT}/scripts/docker-compose.yml"
ENV_FILE="${PROJECT_ROOT}/scripts/.env.ports"

[[ -f "${COMPOSE_FILE}" ]] || { echo "Missing compose file: ${COMPOSE_FILE}" >&2; exit 1; }

DOCKER_BIN="$(command -v docker 2>/dev/null || true)"
[[ -n "${DOCKER_BIN}" && -x "${DOCKER_BIN}" ]] || {
  echo "Docker CLI not found in PATH. Install Docker and ensure 'docker' is executable." >&2
  exit 127
}

if [[ ! -f "${ENV_FILE}" ]]; then
  if [[ -f "${ENV_FILE}.example" ]]; then
    ENV_FILE="${ENV_FILE}.example"
  else
    ENV_FILE=""
  fi
fi

args=(
  --project-name valueos
  --project-directory "${PROJECT_ROOT}"
  -f "${COMPOSE_FILE}"
)

if [[ -n "${ENV_FILE}" && -f "${ENV_FILE}" ]]; then
  args+=(--env-file "${ENV_FILE}")
fi

DOCKER_BIN="${DOCKER_BIN:-docker}"
exec "${DOCKER_BIN}" compose "${args[@]}" "$@"

