#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
COMPOSE_FILE="${PROJECT_ROOT}/scripts/docker-compose.yml"
PRIMARY_ENV_FILE="${PROJECT_ROOT}/scripts/.env.ports"
FALLBACK_ENV_FILE="${PROJECT_ROOT}/scripts/.env.ports.example"

if [[ -f "$PRIMARY_ENV_FILE" ]]; then
  ENV_FILE="$PRIMARY_ENV_FILE"
else
  ENV_FILE="$FALLBACK_ENV_FILE"
fi

DOCKER_ARGS=(
  compose
  --project-name valueos
  -f "$COMPOSE_FILE"
  --env-file "$ENV_FILE"
)

if [[ -f "${PROJECT_ROOT}/.env.local" ]]; then
  DOCKER_ARGS+=(--env-file "${PROJECT_ROOT}/.env.local")
fi

exec docker "${DOCKER_ARGS[@]}" "$@"
