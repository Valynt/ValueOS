{
  "name": "valuecanvas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:openapi": "node scripts/validate-openapi.mjs",
    "lint:console": "bash scripts/cleanup-console-logs.sh",
    "preview": "serve dist -s -l 5173",
    "test": "vitest run --coverage --passWithNoTests",
    "bias:probes": "tsx scripts/run-bias-probes.ts",
    "typecheck": "tsc --noEmit",
    "test:rls": "supabase test db supabase/tests/database/rls_policies.test.sql supabase/tests/database/multi_tenant_rls.test.sql",
    "test:watch": "vitest run --passWithNoTests --watch",
    "test:perf": "vitest run --config vitest.config.ts --include \"test/performance/**/*.test.ts\" --passWithNoTests",
    "test:testcafe": "testcafe chrome:headless test/testcafe/**/*.test.js",
    "sdk:generate": "openapi-typescript openapi.yaml --output src/api/client/generated-types.ts",
    "db:setup": "bash infra/supabase/setup.sh",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:repair": "supabase migration repair",
    "db:link": "supabase link --project-ref ${SUPABASE_PROJECT_ID}",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > src/types/supabase.ts",
    "db:types:remote": "supabase gen types typescript --linked > src/types/supabase.ts",
    "db:test": "supabase test db",
    "db:test:init": "tsx scripts/test-db-init.ts",
    "db:test:seed": "tsx scripts/test-db-seed.ts",
    "db:test:setup": "pnpm run db:test:init && pnpm run db:test:seed",
    "test:rls:leakage": "tsx scripts/test-rls-leakage.ts",
    "test:load": "k6 run test/performance/load-test.js",
    "test:a11y": "pnpm playwright test test/playwright/accessibility.spec.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:up:build": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "docker:down:volumes": "docker-compose down -v",
    "docker:logs": "docker-compose logs -f",
    "docker:prod:build": "docker-compose -f docker-compose.prod.yml build",
    "docker:prod:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "analyze:deps": "tsx scripts/analyze-dependencies.ts",
    "analyze:impact": "tsx scripts/analyze-dependencies.ts && cat impact.json",
    "generate:codemap": "tsx scripts/generate-codemap.ts",
    "policy:check": "tsx scripts/architectural-rules.ts",
    "ci:local": "bash .devcontainer/scripts/local-ci.sh",
    "db:validate": "tsx scripts/run-sql-file.ts supabase/tests/database/validate_all_fixes.sql",
    "db:validate-tenant-rls": "bash scripts/validate-tenant-rls.sh",
    "security:scan": "npm audit --audit-level=high",
    "security:scan:snyk": "snyk test --severity-threshold=high",
    "security:scan:all": "pnpm run security:scan && pnpm run security:scan:snyk",
    "storybook:snapshot": "storybook test --watch=false",
    "billing:aggregate": "node -r tsx/cjs src/services/metering/UsageAggregator.ts",
    "billing:submit": "node -r tsx/cjs src/services/metering/UsageSink.ts",
    "billing:setup-stripe": "./infra/billing/stripe-products-setup.sh",
    "billing:test-flow": "./infra/testing/test-billing-flow.sh",
    "backend:dev": "tsx watch src/backend/server.ts",
    "backend:start": "node dist/backend/server.js",
    "test:saml": "playwright test test/playwright/saml-compliance.spec.ts test/playwright/saml-slo.spec.ts",
    "test:saml:compliance": "playwright test test/playwright/saml-compliance.spec.ts",
    "test:saml:slo": "playwright test test/playwright/saml-slo.spec.ts",
    "test:saml:headed": "playwright test test/playwright/saml-compliance.spec.ts test/playwright/saml-slo.spec.ts --headed",
    "test:saml:report": "playwright show-report",
    "saml:start": "docker-compose -f infra/docker/compose.saml-test.yml up -d",
    "saml:stop": "docker-compose -f infra/docker/compose.saml-test.yml down",
    "saml:logs": "docker-compose -f infra/docker/compose.saml-test.yml logs -f",
    "saml:certs": "cd test/saml/certs && ./generate-test-certs.sh",
    "test:chaos": "ts-node scripts/chaos-test.ts",
    "chaos:enable": "CHAOS_ENABLED=true pnpm run dev",
    "chaos:pipeline": "tsx scripts/chaos-engineering-pipeline.ts full",
    "chaos:scheduled": "tsx scripts/chaos-engineering-pipeline.ts scheduled",
    "dev:fix": "bash scripts/dev-automation/fix-port-forwarding.sh",
    "dev:diagnose": "bash scripts/dev-automation/diagnose-network.sh",
    "dev:test-ports": "bash scripts/dev-automation/test-ports.sh",
    "dev:health": "bash scripts/dev-automation/dev-health-check.sh",
    "dev:auto-fix": "bash scripts/dev-automation/auto-fix.sh",
    "ci:bias-probes": "node -r tsx/cjs scripts/run-bias-probes.ts",
    "prepare": "husky",
    "beta:provision": "node -r tsx/cjs scripts/beta-provision.ts",
    "monitor:golden-path": "pnpm playwright test --config=playwright.monitor.config.ts --reporter=list",
    "staging:build": "NODE_ENV=staging vite build",
    "staging:dev": "NODE_ENV=staging vite",
    "staging:preview": "NODE_ENV=staging vite preview",
    "staging:start": "NODE_ENV=staging docker-compose -f infra/docker/compose.stage.yml up --build",
    "staging:stop": "docker-compose -f infra/docker/compose.stage.yml down",
    "staging:logs": "docker-compose -f infra/docker/compose.stage.yml logs -f",
    "staging:backend": "NODE_ENV=staging tsx watch src/backend/server.ts",
    "staging:test": "NODE_ENV=staging vitest run",
    "staging:deploy": "NODE_ENV=staging pnpm run build && docker-compose -f infra/docker/compose.stage.yml up -d --build",
    "staging:clean": "docker-compose -f infra/docker/compose.stage.yml down -v --remove-orphans",
    "deploy:validate": "bash scripts/validate-deployment.sh",
    "deploy:pre-check": "bash scripts/pre-deployment-checklist.sh",
    "db:backup": "bash scripts/backup-restore.sh backup",
    "db:restore": "bash scripts/backup-restore.sh restore",
    "db:backup:list": "bash scripts/backup-restore.sh list",
    "verify:llm-instrumentation": "node -r tsx/cjs scripts/verify-llm-instrumentation.ts",
    "verify:trace-reconstruction": "node -r tsx/cjs scripts/verify/trace_reconstruction.ts",
    "memory:gc": "tsx scripts/run-memory-gc.ts",
    "agent:dev": "tsx scripts/agentic-dev/run-agent-team.ts",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "lint:inline-check": "node scripts/check-inline-styles.cjs",
    "lint:all": "pnpm run lint && pnpm run lint:css && pnpm run lint:inline-check",
    "check:tw-config": "node scripts/validate-tailwind-config.js",

    "🔥 NEW EPIC-006 SCRIPTS 🔥",

    "test:coverage:enhance": "vitest run --coverage --reporter=verbose --passWithNoTests",
    "test:mutation": "pnpm stryker run",
    "test:property": "vitest run --config vitest.config.property.ts --passWithNoTests",
    "test:benchmark": "tsx scripts/performance/run-benchmarks.ts",
    "test:load:agent": "k6 run test/performance/agent-load-test.js",
    "test:load:ui": "k6 run test/performance/ui-load-test.js",
    "test:load:full": "k6 run test/performance/full-load-test.js",

    "chaos:full": "tsx scripts/chaos-engineering-pipeline.ts full",
    "chaos:daily": "tsx scripts/chaos-engineering-pipeline.ts scheduled daily",
    "chaos:weekly": "tsx scripts/chaos-engineering-pipeline.ts scheduled weekly",
    "chaos:monthly": "tsx scripts/chaos-engineering-pipeline.ts scheduled monthly",

    "compliance:evidence": "bash scripts/compliance/collect-evidence.sh",
    "compliance:validate": "tsx scripts/compliance/validate-controls.ts",
    "compliance:report": "tsx scripts/compliance/generate-report.ts",
    "compliance:full": "pnpm run compliance:evidence && pnpm run compliance:validate && pnpm run compliance:report",

    "soc2:prepare": "tsx scripts/soc2/prepare-audit.ts",
    "soc2:checklist": "tsx scripts/soc2/checklist.ts",
    "soc2:evidence": "bash scripts/compliance/collect-evidence.sh",

    "performance:baseline": "tsx scripts/performance/baseline.ts",
    "performance:regression": "tsx scripts/performance/regression-check.ts",
    "performance:monitor": "tsx scripts/performance/monitor.ts",

    "security:compliance": "pnpm run security:scan:all && pnpm run compliance:validate",

    "audit:all": "pnpm run test:coverage:enhance && pnpm run chaos:full && pnpm run performance:baseline && pnpm run compliance:full",

    "report:quality": "tsx scripts/reports/quality-metrics.ts",
    "report:performance": "tsx scripts/reports/performance-metrics.ts",
    "report:security": "tsx scripts/reports/security-metrics.ts",
    "report:compliance": "tsx scripts/reports/compliance-metrics.ts",
    "report:all": "pnpm run report:quality && pnpm run report:performance && pnpm run report:security && pnpm run report:compliance"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@playwright/test": "^1.57.0",
    "@supabase/supabase-js": "^2.57.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dompurify": "^3.3.1",
    "express": "^4.18.2",
    "html2canvas": "^1.4.1",
    "isomorphic-dompurify": "^2.34.0",
    "lucide-react": "^0.344.0",
    "lz-string": "^1.5.0",
    "p-queue": "^9.0.1",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^9.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.20.0",
    "redis": "^4.6.11",
    "serve": "^14.2.3",
    "stripe": "^14.7.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^9.0.1",
    "winston": "^3.18.3",
    "winston-cloudwatch": "^6.3.0",
    "ws": "^8.18.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@aws-sdk/client-secrets-manager": "^3.943.0",
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.9.1",
    "@testcontainers/postgresql": "^11.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.27",
    "@types/pg": "^8.15.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/runner": "^4.0.15",
    "autoprefixer": "^10.4.18",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "express-rate-limit": "^8.2.1",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "jsdom": "^24.1.1",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.4",
    "node-vault": "^0.10.9",
    "openapi-typescript": "^7.10.1",
    "opossum": "^9.0.0",
    "pg": "^8.16.3",
    "postcss": "^8.4.35",
    "prettier": "^3.7.4",
    "rate-limit-redis": "^4.3.1",
    "snyk": "^1.1275.0",
    "storybook": "^8.4.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "supabase": "^2.65.6",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.1",
    "testcontainers": "^11.9.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.2.6",
    "vitest": "^4.0.15",

    "🔥 NEW EPIC-006 DEPENDENCIES 🔥",

    "fast-check": "^3.15.0",
    "@stryker-mutator/core": "^6.4.0",
    "@stryker-mutator/vitest": "^6.4.0",
    "k6": "^0.46.0",
    "prom-client": "^15.1.3",
    "grafana-sdk": "^0.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "node ./node_modules/eslint/bin/eslint.js --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  }
}
