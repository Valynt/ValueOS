# Production Environment Variables Template
# Copy this file to .env.production and fill in your actual values

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
VITE_APP_NAME=VALYNT
VITE_APP_URL=https://valynt.xyz
VITE_ENVIRONMENT=production

# =============================================================================
# API CONFIGURATION
# =============================================================================
VITE_API_BASE_URL=https://api.valynt.xyz
VITE_API_TIMEOUT=30000

# =============================================================================
# FEATURE FLAGS
# =============================================================================
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# =============================================================================
# OAUTH PROVIDERS (Configure in Supabase Dashboard)
# =============================================================================
# Google OAuth - Configure at: https://console.cloud.google.com
# Apple Sign In - Configure at: https://developer.apple.com
# GitHub OAuth - Configure at: https://github.com/settings/developers

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Sentry (Error Reporting)
VITE_SENTRY_DSN=your-sentry-dsn-here
VITE_SENTRY_ENVIRONMENT=production

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# SECURITY
# =============================================================================
# Session timeout (in milliseconds)
VITE_SESSION_TIMEOUT=3600000

# Rate limiting
VITE_RATE_LIMIT_ENABLED=true
VITE_RATE_LIMIT_MAX_REQUESTS=100
VITE_RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# PERFORMANCE
# =============================================================================
# CDN URL (if using a CDN)
VITE_CDN_URL=https://cdn.valynt.xyz

# Asset optimization
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_PWA=false

# =============================================================================
# DEVELOPMENT OVERRIDES (Remove in production)
# =============================================================================
# VITE_DEBUG=false
# VITE_MOCK_API=false
DEV_MOCKS_ENABLED=false
