# Bolt.new context slimming for frontend UI/UX work
# Strategy: ignore everything, then re-include only what UI work needs.

*

# Keep this config folder/file
!.bolt/
!.bolt/ignore

# Keep minimal workspace/tooling files
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!tsconfig.json
!tsconfig.app.json
!tsconfig.node.json
!vite.config.ts
!vitest.config.ts
!postcss.config.js
!tailwind.config.js
!eslint.config.js
!prettier.config.cjs
!.npmrc
!.nvmrc
!.env.example
!README.md

# Keep the frontend app you care about
!apps/
apps/*
!apps/ValyntApp/
!apps/ValyntApp/**

# Strip heavy/non-UI content inside ValyntApp
apps/ValyntApp/node_modules/
apps/ValyntApp/dist/
apps/ValyntApp/build/
apps/ValyntApp/coverage/
apps/ValyntApp/.storybook/
apps/ValyntApp/src/**/__tests__/
apps/ValyntApp/src/**/*.test.*
apps/ValyntApp/src/**/*.spec.*
apps/ValyntApp/src/**/*.stories.*
apps/ValyntApp/src/mcp-*/
apps/ValyntApp/src/backend/

# Keep shared types/utilities commonly imported by frontend
!packages/
packages/*
!packages/shared/
!packages/shared/**
!packages/sdui-types/
!packages/sdui-types/**

# Exclude common large/generated/sensitive files globally
**/node_modules/
**/.pnpm-store/
**/.turbo/
**/dist/
**/build/
**/coverage/
**/.cache/
**/*.log
**/.DS_Store
**/.env
**/.env.*
!**/.env.example

# Exclude backend/ops/docs-heavy areas by default (root only)
/.git/
/.github/
/.devcontainer/
/.vscode/
/.storybook/
/docs/
/infra/
/ops/
/deploy/
/scripts/
/supabase/
/tests/
/pragmatic-reproducibility/
/ValueOS/
/config/
/public/
