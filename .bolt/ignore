# Ultra-slim Bolt context for Valynt frontend UI work.
# Ignore everything, then include only minimal frontend files.

*

# Keep bolt config itself
!.bolt/
!.bolt/ignore

# Keep only Valynt app
!apps/
apps/*
!apps/ValyntApp/
apps/ValyntApp/*

# Minimal app config/runtime files
!apps/ValyntApp/package.json
!apps/ValyntApp/tsconfig.json
!apps/ValyntApp/tsconfig.node.json
!apps/ValyntApp/vite.config.ts
!apps/ValyntApp/tailwind.config.js
!apps/ValyntApp/postcss.config.cjs
!apps/ValyntApp/index.html

# Frontend source and public assets
!apps/ValyntApp/src/
!apps/ValyntApp/src/**
!apps/ValyntApp/public/
!apps/ValyntApp/public/**

# Drop heavy/non-UI content inside app
apps/ValyntApp/node_modules/
apps/ValyntApp/dist/
apps/ValyntApp/build/
apps/ValyntApp/coverage/
apps/ValyntApp/.storybook/
apps/ValyntApp/src/**/__tests__/
apps/ValyntApp/src/**/*.test.*
apps/ValyntApp/src/**/*.spec.*
apps/ValyntApp/src/**/*.stories.*
apps/ValyntApp/src/backend/
apps/ValyntApp/src/mcp-*/

# Global excludes (safety)
**/node_modules/
**/dist/
**/build/
**/coverage/
**/.cache/
**/*.log
.turbo/
.changeset/
.windsurf/
.jules/
**/.env
**/.env.*
!**/.env.example
