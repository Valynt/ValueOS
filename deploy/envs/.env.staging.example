# ============================================================================
# ValueOS Staging Environment Configuration
# ============================================================================
# This file defines the staging environment configuration with centralized secrets
# Copy to .env.staging for actual deployment
# ============================================================================

# Application Environment
NODE_ENV=staging
VITE_HOST=0.0.0.0
VITE_PORT=5173
VITE_HMR_PORT=24678

# ============================================================================
# Secrets Management Configuration
# ============================================================================
# Enable secret volume watching for Kubernetes CSI driver integration
SECRETS_VOLUME_WATCH_ENABLED=true
SECRETS_MOUNT_PATH=/mnt/secrets
SECRETS_WATCH_POLL_INTERVAL=5000
SECRETS_HEALTH_CHECK_INTERVAL=30000

# Secret provider configuration (vault, aws, or file)
SECRET_PROVIDER=vault
VAULT_ADDR=https://vault.staging.valueos.com:8200
VAULT_ROLE=valueos-staging
VAULT_MOUNT=secret
AWS_REGION=us-east-1

# ============================================================================
# Application Configuration
# ============================================================================
APP_DOMAIN=staging.valueos.com
ACME_EMAIL=staging@valueos.com
ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
TLS_MODE=

# API Configuration
API_PORT=3001
API_UPSTREAM=http://backend:3001
CORS_ALLOWED_ORIGINS=https://staging.valueos.com,https://api.staging.valueos.com

# Frontend Configuration
VITE_APP_URL=https://staging.valueos.com
VITE_API_BASE_URL=/api

# ============================================================================
# Database Configuration (from Secret Provider)
# ============================================================================
VITE_SUPABASE_URL=${SECRET:supabase_url}
SUPABASE_URL=${SECRET:supabase_url}
VITE_SUPABASE_ANON_KEY=${SECRET:supabase_anon_key}
SUPABASE_ANON_KEY=${SECRET:supabase_anon_key}
SUPABASE_SERVICE_KEY=${SECRET:supabase_service_key}
DATABASE_URL=${SECRET:database_url}
REDIS_URL=${SECRET:redis_url}

# ============================================================================
# LLM API Configuration (from Secret Provider)
# ============================================================================
VITE_LLM_PROVIDER=together
TOGETHER_API_KEY=${SECRET:together_api_key}
OPENAI_API_KEY=${SECRET:openai_api_key}
ANTHROPIC_API_KEY=${SECRET:anthropic_api_key}

# ============================================================================
# Security & Authentication (from Secret Provider)
# ============================================================================
JWT_SECRET=${SECRET:jwt_secret}
ENCRYPTION_KEY=${SECRET:encryption_key}
WEBAUTHN_RP_ID=staging.valueos.com

# ============================================================================
# Monitoring & Observability
# ============================================================================
SENTRY_DSN=${SECRET:sentry_dsn}
PROMETHEUS_METRICS_ENABLED=true
METRICS_INTERVAL=30000

# ============================================================================
# Staging-Specific Settings
# ============================================================================
# Enable additional debugging in staging
VITE_DEV_TOOLS=false
VITE_SOURCE_MAPS=false

# Security settings (relaxed for staging)
VITE_ENABLE_CIRCUIT_BREAKER=true
VITE_ENABLE_RATE_LIMITING=true
VITE_ENABLE_AUDIT_LOGGING=true

# Performance settings
UV_THREADPOOL_SIZE=4
PG_POOL_MIN=2
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000

# ============================================================================
# Caddy Edge Configuration
# ============================================================================
DEV_DOMAIN=staging.valueos.com
FRONTEND_UPSTREAM=http://frontend:5173
CADDY_ADMIN=0.0.0.0:2019
CADDY_LOG_LEVEL=INFO
AUTO_HTTPS=on

# ============================================================================
# Staging Deployment Notes
# ============================================================================
# 1. This configuration uses centralized secrets management
# 2. All sensitive values are loaded from Vault/AWS Secrets Manager
# 3. Staging environment mimics production configuration
# 4. Additional logging and monitoring enabled for debugging
# 5. Rate limiting and circuit breakers enabled for testing
