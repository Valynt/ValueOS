# Staging environment for Caddy edge
NODE_ENV=staging
APP_DOMAIN=staging.example.com
ACME_EMAIL=staging@example.com
ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
# TLS_MODE can be left empty for ACME or set to "internal" for local validation
TLS_MODE=

API_PORT=3001
API_UPSTREAM=http://backend:3001
CORS_ALLOWED_ORIGINS=https://staging.example.com

VITE_APP_URL=https://staging.example.com
VITE_API_BASE_URL=/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here
DATABASE_URL=postgresql://user:password@db.example.com:5432/valueos
