# ============================================================================
# ValueCanvas Environment Configuration Template
# ============================================================================
# Copy this file to .env.local for local development
#
# IMPORTANT: This template references the centralized secrets management system.
# In production, secrets should be loaded from Vault/AWS Secrets Manager.
# For local development, you may use placeholder values.
# ============================================================================

# Application Environment
NODE_ENV=development
VITE_HOST=0.0.0.0
# Ports are sourced from config/ports.json and synced to .env.ports
VITE_PORT=5173
VITE_HMR_PORT=24678

# ============================================================================
# Secrets Management Configuration
# ============================================================================
# Enable secret volume watching for Kubernetes CSI driver integration
SECRETS_VOLUME_WATCH_ENABLED=true
SECRETS_MOUNT_PATH=/mnt/secrets
SECRETS_WATCH_POLL_INTERVAL=5000
SECRETS_HEALTH_CHECK_INTERVAL=30000

# Secret provider configuration (vault, aws, or file)
SECRET_PROVIDER=vault
VAULT_ADDR=https://vault.example.com:8200
VAULT_ROLE=valueos-${NODE_ENV}
VAULT_MOUNT=secret
AWS_REGION=us-east-1

# ============================================================================
# Supabase Configuration
# ============================================================================
# In production, these should be loaded from your secret provider
# Local development setup - pointing to Supabase service
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=${SECRET:supabase_url}
SUPABASE_URL=${SECRET:supabase_url}
VITE_SUPABASE_ANON_KEY=${SECRET:supabase_anon_key}
SUPABASE_ANON_KEY=${SECRET:supabase_anon_key}

# Service Role Key (server-side only - NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=${SECRET:supabase_service_key}

# ============================================================================
# LLM API Configuration
# ============================================================================
# Configure your LLM provider (together, openai, anthropic, etc.)
# These should be loaded from your secret provider in production
VITE_LLM_PROVIDER=together
TOGETHER_API_KEY=${SECRET:together_api_key}
OPENAI_API_KEY=${SECRET:openai_api_key}
ANTHROPIC_API_KEY=${SECRET:anthropic_api_key}

# ============================================================================
# Database Configuration
# ============================================================================
# In production, use connection strings from your secret provider
DATABASE_URL=${SECRET:database_url}
REDIS_URL=${SECRET:redis_url}

# Connection Pool & Threading (Performance Tuning)
# Increase the libuv thread pool and Postgres pool for load testing the 2-pod baseline
UV_THREADPOOL_SIZE=8
PG_POOL_MIN=4
PG_POOL_MAX=40
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000

# Prisma Connection Pooling
# DATABASE_URL: Used for queries (can be pooled via PgBouncer/Supabase pooler)
# DIRECT_DATABASE_URL: Used for migrations (must be direct connection)
# In production with Supabase, use port 6543 for pooled, 5432 for direct
# Example pooled: postgresql://user:pass@db.project.supabase.co:6543/postgres?pgbouncer=true
# Example direct: postgresql://user:pass@db.project.supabase.co:5432/postgres

# ============================================================================
# Security & Authentication
# ============================================================================
# These should be loaded from your secret provider in production
JWT_SECRET=${SECRET:jwt_secret}
ENCRYPTION_KEY=${SECRET:encryption_key}
WEBAUTHN_RP_ID=${SECRET:webauthn_rp_id}

# ============================================================================
# Monitoring & Observability
# ============================================================================
# Configure monitoring services (optional but recommended)
SENTRY_DSN=${SECRET:sentry_dsn}
PROMETHEUS_METRICS_ENABLED=true
METRICS_INTERVAL=30000

# ============================================================================
# Development Tools (Development Only)
# ============================================================================
# These are disabled/relaxed for development
# They are enabled and enforced in production
VITE_ENABLE_CIRCUIT_BREAKER=false
VITE_ENABLE_RATE_LIMITING=false
VITE_ENABLE_AUDIT_LOGGING=true

VITE_DEV_TOOLS=true
VITE_SOURCE_MAPS=true

# ============================================================================
# Application URLs (Development)
# ============================================================================
VITE_APP_URL=http://localhost:5173

# API base URL guidance:
# - Local dev (npm run dx):           Use /api (relative) or http://localhost:3001
# - Caddy edge (dev-caddy compose):   Use /api (relative, same-origin)
# - Full Docker (npm run dx:docker):  Use /api (relative, same-origin)
# Prefer relative /api for portability. Absolute URLs only for cross-origin setups.
VITE_API_BASE_URL=/api

# ============================================================================
# Caddy Edge (Development Defaults)
# ============================================================================
DEV_DOMAIN=localhost
API_UPSTREAM=http://backend:3001
FRONTEND_UPSTREAM=http://frontend:5173
CADDY_ADMIN=0.0.0.0:2019
CADDY_LOG_LEVEL=DEBUG
AUTO_HTTPS=off

# ============================================================================
# Critical Security Notes
# ============================================================================
# 1. Never commit .env.local to version control
# 2. All secrets should be loaded from Vault/AWS Secrets Manager in production
# 3. Use strong, unique passwords in production (minimum 16 characters)
# 4. Keep API keys secret and rotate regularly
# 5. Enable all security features in production
# 6. Use environment-specific configuration files
# 7. Validate all environment variables at startup using SecretValidator
# ============================================================================

# API Configuration
API_PORT=3001
