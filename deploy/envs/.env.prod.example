# Production environment for Caddy edge
NODE_ENV=production
APP_DOMAIN=app.example.com
ACME_EMAIL=security@example.com
ACME_CA=https://acme-v02.api.letsencrypt.org/directory
# TLS_MODE supports external certs when set to "</etc/certs/tls.crt> </etc/certs/tls.key>"
TLS_MODE=

API_PORT=3001
API_UPSTREAM=http://backend:3001
CORS_ALLOWED_ORIGINS=https://app.example.com

DEV_MOCKS_ENABLED=false

# ============================================================================
# Sprint 0: Security Feature Flags
# ============================================================================
# Value Commitment Service - disabled until fully implemented
VITE_ENABLE_VALUE_COMMITMENT_SERVICE=false
# Agent placeholder mode - MUST be false in production
VITE_ENABLE_AGENT_PLACEHOLDER_MODE=false
# Client-side LLM streaming - disabled until breaker integration complete
VITE_ENABLE_CLIENT_LLM_STREAMING=false

# ============================================================================
# Sprint 1: Service Identity (REQUIRED in production)
# ============================================================================
# Generate with: openssl rand -hex 32
SERVICE_IDENTITY_TOKEN=<generate-secure-token>

VITE_APP_URL=https://app.example.com
VITE_API_BASE_URL=/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
DATABASE_URL=postgresql://user:password@db.example.com:5432/valueos
REDIS_PASSWORD=change-me
