# ValueCanvas Environment Configuration - P0 Production Readiness
# Copy this file to .env.local for local development
# Copy to .env.production for production deployment

# ============================================================================
# Application
# ============================================================================
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3001
VITE_APP_VERSION=1.0.0

# ============================================================================
# Supabase Configuration
# ============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# IMPORTANT: Service role key should ONLY be set in server-side environments
# NEVER prefix server secrets with VITE_ (exposes to client bundle)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection
DATABASE_URL=postgresql://user:password@host:port/database

# ============================================================================
# Sentry Error Tracking (P0-1)
# ============================================================================
# Enable Sentry error tracking
VITE_SENTRY_ENABLED=true

# Sentry DSN (Data Source Name)
# Get from: https://sentry.io/settings/[org]/projects/[project]/keys/
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Environment name for Sentry
VITE_SENTRY_ENVIRONMENT=development

# Sample rate for error events (0.0 to 1.0)
# 1.0 = 100% of errors are sent
VITE_SENTRY_SAMPLE_RATE=1.0

# Sample rate for performance traces (0.0 to 1.0)
# Lower in production to reduce costs
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0

# ============================================================================
# Redis Cache (P1-7)
# ============================================================================
# Enable Redis caching
REDIS_ENABLED=true

# Redis connection URL
# Format: redis://[username]:[password]@[host]:[port]
# For local: redis://localhost:6379
# For production: redis://user:pass@redis.example.com:6379
REDIS_URL=redis://localhost:6379

# Default cache TTL in seconds
CACHE_TTL=300

# ============================================================================
# LLM Configuration
# ============================================================================
VITE_LLM_PROVIDER=together
VITE_LLM_GATING_ENABLED=true

# Together.ai API Key (REQUIRED)
# WARNING: Do NOT prefix with VITE_ (server-side only)
TOGETHER_API_KEY=your-together-api-key-here

# ============================================================================
# Authentication & Security
# ============================================================================
# JWT Secret (CRITICAL: Generate secure secret)
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET

VITE_SESSION_TIMEOUT=3600000
VITE_MFA_ENABLED=false

# ============================================================================
# Feature Flags
# ============================================================================
VITE_SDUI_DEBUG=true
VITE_AGENT_FABRIC_ENABLED=true
VITE_WORKFLOW_ENABLED=true
VITE_COMPLIANCE_ENABLED=true
VITE_MULTI_TENANT_ENABLED=true
VITE_USAGE_TRACKING_ENABLED=true
VITE_BILLING_ENABLED=false

# ============================================================================
# Agent Configuration
# ============================================================================
VITE_AGENT_API_URL=http://localhost:3001/api/agents
VITE_AGENT_API_TIMEOUT=30000
VITE_AGENT_CIRCUIT_BREAKER_ENABLED=true
VITE_AGENT_CIRCUIT_BREAKER_THRESHOLD=5
VITE_AGENT_CIRCUIT_BREAKER_COOLDOWN=60000
VITE_AGENT_LOGGING_ENABLED=true
VITE_AGENT_WEBSOCKET_URL=ws://localhost:3001/ws/agents

# ============================================================================
# Security
# ============================================================================
VITE_HTTPS_ONLY=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
RATE_LIMIT_PER_MINUTE=60
CSRF_PROTECTION_ENABLED=true
CSP_ENABLED=true

# ============================================================================
# Monitoring & Observability
# ============================================================================
# Datadog (Optional)
DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_APP_KEY=

# Prometheus (Optional)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ============================================================================
# Email (Optional)
# ============================================================================
EMAIL_ENABLED=false
EMAIL_FROM=noreply@valuecanvas.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================================================
# Storage (Optional)
# ============================================================================
S3_ENABLED=false
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ============================================================================
# Vault (Optional - Advanced)
# ============================================================================
VAULT_ENABLED=false
VAULT_ADDR=
VAULT_NAMESPACE=valuecanvas
VAULT_TOKEN=

# ============================================================================
# Development
# ============================================================================
VITE_HMR_ENABLED=true
VITE_SOURCE_MAPS=true
VITE_REACT_DEVTOOLS=true
LOG_LEVEL=info

# ============================================================================
# Testing
# ============================================================================
TEST_MODE=false
VITE_MOCK_AGENTS=false

# ============================================================================
# P0 PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
# 
# CRITICAL (P0):
# [ ] VITE_SUPABASE_URL points to production Supabase project
# [ ] VITE_SUPABASE_ANON_KEY is from production project
# [ ] SUPABASE_SERVICE_ROLE_KEY is from production (server-side only)
# [ ] DATABASE_URL points to production database
# [ ] TOGETHER_API_KEY is valid and has sufficient quota
# [ ] JWT_SECRET is cryptographically secure (32+ bytes)
# [ ] VITE_SENTRY_ENABLED=true with valid DSN
# [ ] VITE_SENTRY_ENVIRONMENT=production
# [ ] REDIS_URL points to production Redis instance
# [ ] VITE_APP_URL matches production domain
# [ ] VITE_HTTPS_ONLY=true
# 
# IMPORTANT (P1):
# [ ] All feature flags are set appropriately
# [ ] Email service is configured (if enabled)
# [ ] Monitoring is enabled (Sentry, Datadog, Prometheus)
# [ ] CORS_ALLOWED_ORIGINS includes production domain
# [ ] Rate limiting is configured appropriately
# [ ] S3 storage is configured (if enabled)
# 
# SECURITY:
# [ ] No secrets are committed to version control
# [ ] All API keys are rotated from development
# [ ] JWT_SECRET is unique per environment
# [ ] Database credentials are secure
# [ ] Redis password is set (if applicable)
# 
# TESTING:
# [ ] All P0 tests pass
# [ ] Security tests pass
# [ ] Integration tests pass
# [ ] Load tests completed
# [ ] Penetration testing completed
# 
# MONITORING:
# [ ] Sentry is receiving test errors
# [ ] Database connection is verified
# [ ] Redis connection is verified
# [ ] All health checks pass
# [ ] Alerts are configured
# 
# COMPLIANCE:
# [ ] Audit logging is enabled
# [ ] PII redaction is working
# [ ] Tenant isolation is verified
# [ ] RBAC is enforced
# [ ] SOC2 requirements met

# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# For production deployment, create .env.production with:
#
# VITE_APP_ENV=production
# VITE_APP_URL=https://app.yourcompany.com
# VITE_HTTPS_ONLY=true
# VITE_SENTRY_ENABLED=true
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# REDIS_ENABLED=true
# LOG_LEVEL=warn
# VITE_REACT_DEVTOOLS=false
# VITE_SOURCE_MAPS=false
# DEV_MOCKS_ENABLED=false
#
# And ensure all secrets are properly configured!
