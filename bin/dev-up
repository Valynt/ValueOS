#!/bin/bash
set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${GREEN}рЯЪА Starting ValueOS Ephemeral Environment...${NC}"
echo "============================================="

# Configuration
COMPOSE_FILE="docker-compose.unified.yml"
PROJECT_NAME="valueos"

# 1. Environment Check
echo -e "${BLUE}рЯФН Checking environment...${NC}"

# Check if docker-compose is available
if ! command -v docker-compose &> /dev/null; then
    echo -e "${RED}вЭМ docker-compose not found. Please install Docker.${NC}"
    exit 1
fi

# Check if Docker is running
if ! docker info &> /dev/null; then
    echo -e "${RED}вЭМ Docker is not running. Please start Docker.${NC}"
    exit 1
fi

echo -e "${GREEN}вЬЕ Docker environment ready${NC}"

# 2. Secret Management
echo -e "${BLUE}рЯФР Setting up secrets...${NC}"

if [ -f ".env.local" ]; then
    echo -e "${GREEN}вЬЕ Using existing .env.local${NC}"
else
    echo -e "${YELLOW}вЪ†пЄП No .env.local found${NC}"

    # Try Doppler if available
    if command -v doppler &> /dev/null && doppler whoami &> /dev/null; then
        echo -e "${BLUE}вШБпЄП Fetching secrets from Doppler...${NC}"
        if doppler secrets download --project valueos-dev --config dev --no-file --format env > .env.local 2>/dev/null; then
            echo -e "${GREEN}вЬЕ Secrets loaded from Doppler${NC}"
        else
            echo -e "${YELLOW}вЪ†пЄП Doppler secrets not configured, creating template...${NC}"
            cp .env.example .env.local
        fi
    else
        echo -e "${YELLOW}рЯУЛ Creating template .env.local from .env.example${NC}"
        cp .env.example .env.local
        echo -e "${YELLOW}рЯТ° Consider setting up Doppler for secret management${NC}"
    fi
fi

# 3. Port Management
echo -e "${BLUE}рЯФМ Checking port availability...${NC}"

# Load ports from .env.ports or use defaults
VITE_PORT=$(grep "^VITE_PORT=" .env.ports 2>/dev/null | cut -d'=' -f2 || echo "5173")
API_PORT=$(grep "^API_PORT=" .env.ports 2>/dev/null | cut -d'=' -f2 || echo "3001")
POSTGRES_PORT=$(grep "^POSTGRES_PORT=" .env.ports 2>/dev/null | cut -d'=' -f2 || echo "5432")
REDIS_PORT=$(grep "^REDIS_PORT=" .env.ports 2>/dev/null | cut -d'=' -f2 || echo "6379")

# Function to check if port is in use
check_port() {
    local port=$1
    local service=$2

    if lsof -i :$port &> /dev/null; then
        echo -e "${YELLOW}вЪ†пЄП Port $port ($service) is already in use${NC}"
        echo -e "${YELLOW}рЯТ° Run: lsof -i :$port | grep LISTEN to see what's using it${NC}"
        return 1
    else
        return 0
    fi
}

# Check critical ports
port_conflicts=0
check_port $VITE_PORT "Frontend" || port_conflicts=$((port_conflicts + 1))
check_port $API_PORT "Backend API" || port_conflicts=$((port_conflicts + 1))
check_port $POSTGRES_PORT "PostgreSQL" || port_conflicts=$((port_conflicts + 1))
check_port $REDIS_PORT "Redis" || port_conflicts=$((port_conflicts + 1))

if [ $port_conflicts -gt 0 ]; then
    echo -e "${RED}вЭМ $port_conflicts port conflicts detected${NC}"
    echo -e "${YELLOW}рЯТ° Resolve conflicts or use DX_ALLOW_PORT_IN_USE=1 to force start${NC}"

    if [ "$DX_ALLOW_PORT_IN_USE" = "1" ]; then
        echo -e "${YELLOW}вЪ†пЄП Starting despite port conflicts (DX_ALLOW_PORT_IN_USE=1)${NC}"
    else
        exit 1
    fi
else
    echo -e "${GREEN}вЬЕ All required ports are available${NC}"
fi

# 4. Container Orchestration
echo -e "${BLUE}рЯР≥ Starting containers...${NC}"

# Stop any existing containers
echo -e "${YELLOW}рЯФД Stopping existing containers...${NC}"
docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME down --remove-orphans 2>/dev/null || true

# Start the services
echo -e "${YELLOW}рЯЪА Bringing up services...${NC}"
if docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME up -d --remove-orphans; then
    echo -e "${GREEN}вЬЕ Containers started successfully${NC}"
else
    echo -e "${RED}вЭМ Failed to start containers${NC}"
    exit 1
fi

# 5. Health Check Wait
echo -e "${BLUE}вП≥ Waiting for services to be healthy...${NC}"

# Function to wait for service health
wait_for_service() {
    local service_name=$1
    local max_attempts=30
    local attempt=1

    echo -n "  Waiting for $service_name..."

    while [ $attempt -le $max_attempts ]; do
        if docker-compose -f $COMPOSE_FILE -p $PROJECT_NAME ps -q $service_name | xargs -r docker inspect --format='{{.State.Health.Status}}' 2>/dev/null | grep -q "healthy"; then
            echo -e " ${GREEN}вЬЕ${NC}"
            return 0
        fi

        echo -n "."
        sleep 2
        attempt=$((attempt + 1))
    done

    echo -e " ${RED}вЭМ Timeout${NC}"
    return 1
}

# Wait for core services
services_failed=0
wait_for_service "postgres" || services_failed=$((services_failed + 1))
wait_for_service "redis" || services_failed=$((services_failed + 1))
wait_for_service "backend" || services_failed=$((services_failed + 1))

if [ $services_failed -gt 0 ]; then
    echo -e "${RED}вЭМ $services_failed services failed to become healthy${NC}"
    echo -e "${YELLOW}рЯТ° Check logs: docker-compose -f $COMPOSE_FILE logs${NC}"
else
    echo -e "${GREEN}вЬЕ All services are healthy${NC}"
fi

# 6. Database Setup
echo -e "${BLUE}рЯЧДпЄП Setting up database...${NC}"

# Wait a bit more for database to be fully ready
sleep 5

# Check if database is accessible
if docker exec ${PROJECT_NAME}-postgres-1 pg_isready -U postgres -d valuecanvas_dev &> /dev/null; then
    echo -e "${GREEN}вЬЕ Database is ready${NC}"

    # Run migrations if they exist
    if [ -f "package.json" ] && grep -q "db:push" package.json; then
        echo -e "${YELLOW}рЯФД Running database migrations...${NC}"
        if npm run db:push &> /dev/null; then
            echo -e "${GREEN}вЬЕ Migrations completed${NC}"
        else
            echo -e "${YELLOW}вЪ†пЄП Migration failed (may be normal for first run)${NC}"
        fi
    fi

    # Seed data if script exists
    if [ -f "scripts/seed-development-data.sh" ]; then
        echo -e "${YELLOW}рЯМ± Seeding development data...${NC}"
        if bash scripts/seed-development-data.sh &> /dev/null; then
            echo -e "${GREEN}вЬЕ Development data seeded${NC}"
        else
            echo -e "${YELLOW}вЪ†пЄП Data seeding failed${NC}"
        fi
    fi
else
    echo -e "${RED}вЭМ Database is not accessible${NC}"
fi

# 7. Final Health Check
echo -e "${BLUE}рЯП• Running final health check...${NC}"

# Function to check HTTP endpoint
check_endpoint() {
    local url=$1
    local name=$2
    local max_attempts=10
    local attempt=1

    echo -n "  Checking $name..."

    while [ $attempt -le $max_attempts ]; do
        if curl -f -s $url > /dev/null 2>&1; then
            echo -e " ${GREEN}вЬЕ${NC}"
            return 0
        fi

        echo -n "."
        sleep 2
        attempt=$((attempt + 1))
    done

    echo -e " ${RED}вЭМ${NC}"
    return 1
}

# Check endpoints
check_endpoint "http://localhost:$API_PORT/health" "Backend API"
check_endpoint "http://localhost:$VITE_PORT" "Frontend"

# 8. Success Summary
echo ""
echo -e "${GREEN}в≠Р ValueOS is ready!${NC}"
echo "=================="
echo -e "${BLUE}рЯМР Services:${NC}"
echo "  Frontend:    http://localhost:$VITE_PORT"
echo "  Backend:     http://localhost:$API_PORT"
echo "  Database:    localhost:$POSTGRES_PORT"
echo "  Redis:       localhost:$REDIS_PORT"
echo ""
echo -e "${BLUE}рЯФІ Management commands:${NC}"
echo "  dev-down     - Stop all services"
echo "  dev-logs     - View service logs"
echo "  dev-ps       - Show service status"
echo "  health-check - Run health check"
echo ""
echo -e "${BLUE}рЯФЧ Useful links:${NC}"
echo "  API Health:  http://localhost:$API_PORT/health"
echo "  API Docs:    http://localhost:$API_PORT/api-docs"
echo ""
echo -e "${GREEN}рЯОЙ Happy coding!${NC}"
