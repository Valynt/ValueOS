# ValueOS secrets template
# Copy to .env.local and fill real values.

DATABASE_URL=
REDIS_URL=
SUPABASE_INTERNAL_URL=http://kong:8000
SUPABASE_PUBLIC_URL=http://localhost:${SUPABASE_API_PORT}
SUPABASE_URL=${SUPABASE_INTERNAL_URL}
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=${SUPABASE_PUBLIC_URL}
VITE_SUPABASE_ANON_KEY=

# Optional provider secrets
TOGETHER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
JWT_SECRET=
ENCRYPTION_KEY=
E2B_API_KEY=

# SecurityMonitor alert channels (optional — alerts log to console when unset)
# SECURITY_EMAIL_WEBHOOK_URL=        # POST endpoint that delivers email alerts
# SECURITY_SLACK_WEBHOOK_URL=        # Slack Incoming Webhook URL for security alerts
# SECURITY_TEAM_WEBHOOK_URL=         # Slack webhook for security-team escalations (falls back to SECURITY_SLACK_WEBHOOK_URL)
# SECURITY_MANAGEMENT_WEBHOOK_URL=   # Webhook for management-level escalations
# SECURITY_PAGERDUTY_ROUTING_KEY=    # PagerDuty Events API v2 routing key

# Kafka (optional — disabled by default)
# KAFKA_ENABLED=true
# KAFKA_BROKERS=localhost:9092
