# NOTE: This file is for the local Docker Compose development path only.
# It is NOT the primary setup path for this repo.
#
# Primary path (cloud-dev / Gitpod): see ops/env/README.md
# Local Docker Compose path: see docs/environments/local-development.md
#
# ValueOS secrets template
# Copy to .env.local and fill real values.

DATABASE_URL=
REDIS_URL=
SUPABASE_INTERNAL_URL=http://kong:8000
SUPABASE_PUBLIC_URL=http://localhost:${SUPABASE_API_PORT}
SUPABASE_URL=${SUPABASE_INTERNAL_URL}
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=${SUPABASE_PUBLIC_URL}
VITE_SUPABASE_ANON_KEY=

# Optional provider secrets
TOGETHER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Copy from Supabase dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=
JWT_SECRET=
ENCRYPTION_KEY=
# Set to true when the host's disk encryption is confirmed active (e.g. LUKS, FileVault, AWS EBS encryption).
# Controls the encryption_at_rest_coverage compliance metric. False in local dev is expected.
ENCRYPTION_AT_REST_ENABLED=false
E2B_API_KEY=

# SecurityMonitor alert channels (optional — alerts log to console when unset)
# SECURITY_EMAIL_WEBHOOK_URL=        # POST endpoint that delivers email alerts
# SECURITY_SLACK_WEBHOOK_URL=        # Slack Incoming Webhook URL for security alerts
# SECURITY_TEAM_WEBHOOK_URL=         # Slack webhook for security-team escalations (falls back to SECURITY_SLACK_WEBHOOK_URL)
# SECURITY_MANAGEMENT_WEBHOOK_URL=   # Webhook for management-level escalations
# SECURITY_PAGERDUTY_ROUTING_KEY=    # PagerDuty Events API v2 routing key

# Kafka (optional — disabled by default)
# KAFKA_ENABLED=true
# KAFKA_BROKERS=localhost:9092

# CORS — comma-separated list of allowed origins (no wildcards in production)
# CORS_ORIGINS=https://app.yourdomain.com

# Logging
LOG_LEVEL=info

# Error tracking (optional — errors log to console when unset)
# SENTRY_DSN=

# MFA — set to true in production
MFA_ENABLED=false

# Industry benchmark API keys (optional — IndustryBenchmarkModule)
# BLS_API_KEY=
# CENSUS_API_KEY=
