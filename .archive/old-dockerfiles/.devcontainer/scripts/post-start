#!/bin/bash
set -e

# Ensure pnpm is always activated and hash is refreshed
corepack enable
corepack prepare pnpm@9.15.0 --activate
hash -r

# Ensure nvm is loaded and Node.js 20.19.0 is used in every shell
if [ -d "$HOME/.nvm" ]; then
	export NVM_DIR="$HOME/.nvm"
	[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
	nvm install 20.19.0
	nvm alias default 20.19.0
	nvm use 20.19.0
fi
