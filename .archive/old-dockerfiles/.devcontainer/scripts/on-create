#!/usr/bin/env bash
set -euo pipefail
echo "[on-create] ok"

# Ensure Supabase CLI is installed (no sudo required)
mkdir -p "$HOME/.local/bin"
if ! command -v supabase >/dev/null 2>&1; then
	curl -fsSL https://github.com/supabase/cli/releases/latest/download/supabase_linux_amd64.tar.gz \
		| tar -xz -C "$HOME/.local/bin" supabase
	chmod +x "$HOME/.local/bin/supabase"
fi

# Ensure ~/.local/bin is on PATH for future shells
if ! grep -q 'export PATH="$HOME/.local/bin:$PATH"' "$HOME/.bashrc" 2>/dev/null; then
	echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$HOME/.bashrc"
fi
export PATH="$HOME/.local/bin:$PATH"

# Optionally persist Docker API version for interactive shells
if ! grep -q 'export DOCKER_API_VERSION=1.43' "$HOME/.bashrc" 2>/dev/null; then
	echo 'export DOCKER_API_VERSION=1.43' >> "$HOME/.bashrc"
fi
