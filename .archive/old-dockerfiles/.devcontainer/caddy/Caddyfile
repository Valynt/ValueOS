# Caddyfile for ValueOS Development Environment
# Reverse proxy configuration for routing traffic to services

{
    # Global options
    admin 0.0.0.0:2019
    auto_https off
    log {
        output stdout
        format json
        level INFO
    }
}

# Frontend Application
:80 {
    # Health check endpoint
    handle /health {
        respond "OK" 200
    }

    # Frontend routes
    handle /* {
        reverse_proxy frontend:3001 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            
            health_uri /
            health_interval 30s
            health_timeout 10s
        }
    }

    # Logging
    log {
        output stdout
        format json
    }
}

# API Gateway (Kong)
:8000 {
    reverse_proxy kong:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
        
        health_uri /
        health_interval 30s
        health_timeout 10s
    }

    log {
        output stdout
        format json
    }
}

# Supabase Studio
:54324 {
    reverse_proxy studio:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    log {
        output stdout
        format json
    }
}

# Agent Fabric Monitoring (optional)
:8222 {
    reverse_proxy nats:8222 {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }

    log {
        output stdout
        format json
    }
}
