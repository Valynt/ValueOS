# CI-only: optimized agent Dockerfile (used in CI). Do NOT build this in the interactive devcontainer
ARG NODE_VERSION=18

# Base image with Python and Node
FROM node:${NODE_VERSION}-alpine AS base

# Create non-privileged builder user for ownership consistency
ARG USER_ID=1000
ARG USER_GID=1000
RUN addgroup -g ${USER_GID} -S valueos || true \
    && adduser -u ${USER_ID} -G valueos -S valueos || true

# Stage 1: Dependencies
FROM base AS deps
WORKDIR /app
COPY --chown=valueos:valueos package*.json ./
RUN npm ci --omit=dev --cache=/tmp/.npm \
    && rm -rf /tmp/.npm

# Optional: copy ports config for validation
COPY --chown=valueos:valueos config/ports.json ./config/ports.json
ARG EXPOSE_PORT=3000
RUN if [ -n "${EXPOSE_PORT}" ]; then \
      node -e "const fs=require('fs');const p=JSON.parse(fs.readFileSync('config/ports.json'));const vals=Object.values(p).flatMap(o=>Object.values(o)); if(!vals.some(x=>Number(x)===Number(process.env.EXPOSE_PORT))){console.error('ERROR: EXPOSE_PORT not listed in config/ports.json'); process.exit(1);}"; \
    fi

# Stage 2: Build
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --chown=valueos:valueos . .
RUN npm run build

# Stage 3: Runtime (minimal, drop build toolchains)
FROM node:${NODE_VERSION}-alpine AS runtime
WORKDIR /app
# Create runtime non-privileged user
ARG USER_ID=1000
ARG USER_GID=1000
RUN addgroup -g ${USER_GID} -S valueos || true \
    && adduser -u ${USER_ID} -G valueos -S valueos || true

# Copy only production dependencies and build artifacts and set ownership to non-root user
COPY --from=deps --chown=valueos:valueos /app/node_modules ./node_modules
COPY --from=builder --chown=valueos:valueos /app/dist ./dist
COPY --from=builder --chown=valueos:valueos /app/package.json .

USER valueos

ARG EXPOSE_PORT=3000
EXPOSE ${EXPOSE_PORT}
HEALTHCHECK --interval=30s --timeout=5s \
  CMD curl --fail http://localhost:${EXPOSE_PORT}/health || exit 1

CMD ["node", "dist/main.js"]
