{
  "orchestrator": "KimiK2.5",
  "version": "1.0.0",
  "parallelism": {
    "maxConcurrentAgents": 20,
    "maxFilesPerAgent": 10,
    "maxErrorsPerBatch": 50,
    "batchCooldownSeconds": 30
  },
  "constraints": {
    "noAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "preserveTenantIsolation": true,
    "noRuntimeChanges": true,
    "enforceSkillCompliance": true
  },
  "agentRoles": [
    {
      "id": "ts-inference",
      "name": "Type Inference Specialist",
      "skillPath": ".windsurf/skills/ts-type-inference/SKILL.md",
      "errorCodes": [
        "TS7006",
        "TS7019",
        "TS7023"
      ],
      "priority": 1,
      "autoFixable": true
    },
    {
      "id": "ts-null-safety",
      "name": "Null Safety Guardian",
      "skillPath": ".windsurf/skills/ts-null-safety/SKILL.md",
      "errorCodes": [
        "TS18047",
        "TS18048",
        "TS2532",
        "TS2531",
        "TS2345-null"
      ],
      "priority": 2,
      "autoFixable": true
    },
    {
      "id": "ts-property",
      "name": "Property Definition Architect",
      "skillPath": ".windsurf/skills/ts-property-definition/SKILL.md",
      "errorCodes": [
        "TS2339",
        "TS2339-never",
        "TS2304"
      ],
      "priority": 3,
      "autoFixable": false
    },
    {
      "id": "ts-compatibility",
      "name": "Assignment Compatibility Engineer",
      "skillPath": ".windsurf/skills/ts-compatibility/SKILL.md",
      "errorCodes": [
        "TS2322",
        "TS2345",
        "TS2769",
        "TS2741"
      ],
      "priority": 4,
      "autoFixable": false
    },
    {
      "id": "ts-supabase",
      "name": "Supabase Type Specialist",
      "skillPath": ".windsurf/skills/ts-supabase-types/SKILL.md",
      "errorCodes": [
        "TS2345-supabase",
        "TS2339-supabase",
        "TS2322-db"
      ],
      "filePatterns": [
        "*supabase*",
        "*.db.ts",
        "*database*"
      ],
      "priority": 2,
      "autoFixable": false
    },
    {
      "id": "ts-agent-fabric",
      "name": "Agent Fabric Type Expert",
      "skillPath": ".windsurf/skills/ts-agent-fabric/SKILL.md",
      "errorCodes": [
        "TS-agent*"
      ],
      "filePatterns": [
        "*agent*",
        "*fabric*",
        "*MessageBus*",
        "*runtime*"
      ],
      "priority": 2,
      "autoFixable": false
    }
  ],
  "packages": [
    {
      "name": "@valueos/backend",
      "path": "packages/backend",
      "priority": 1,
      "agents": 2,
      "errorBudget": 29,
      "target": 0,
      "ratchet": 10,
      "strictZones": [
        "src/lib/agent-fabric",
        "src/runtime",
        "src/api",
        "src/services/tenant"
      ],
      "entryPoints": [
        "src/index.ts",
        "src/app.ts"
      ]
    },
    {
      "name": "valynt-app",
      "path": "apps/ValyntApp",
      "priority": 2,
      "agents": 6,
      "errorBudget": 1054,
      "target": 0,
      "ratchet": 50,
      "strictZones": [
        "src/services",
        "src/security",
        "src/api"
      ],
      "entryPoints": [
        "src/main.tsx",
        "src/App.tsx"
      ]
    },
    {
      "name": "@valueos/sdui",
      "path": "packages/sdui",
      "priority": 3,
      "agents": 2,
      "errorBudget": 0,
      "target": 0,
      "ratchet": 0,
      "strictZones": [
        "src/registry.tsx",
        "src/components"
      ],
      "entryPoints": [
        "src/index.ts"
      ]
    },
    {
      "name": "@valueos/shared",
      "path": "packages/shared",
      "priority": 0,
      "agents": 4,
      "errorBudget": 200,
      "target": 0,
      "ratchet": 50,
      "strictZones": [
        "src/domain"
      ],
      "entryPoints": [
        "src/index.ts"
      ],
      "note": "Must complete first - other packages depend on shared types"
    },
    {
      "name": "@valueos/infra",
      "path": "packages/infra",
      "priority": 4,
      "agents": 3,
      "errorBudget": 150,
      "target": 0,
      "ratchet": 30
    },
    {
      "name": "@valueos/memory",
      "path": "packages/memory",
      "priority": 3,
      "agents": 3,
      "errorBudget": 180,
      "target": 0,
      "ratchet": 30
    }
  ],
  "execution": {
    "phases": [
      {
        "name": "phase-1-isolated-errors",
        "week": 1,
        "description": "Fix non-conflicting error categories in parallel",
        "streams": [
          {
            "role": "ts-inference",
            "errors": 300,
            "agents": 6,
            "days": 2
          },
          {
            "role": "ts-null-safety",
            "errors": 2700,
            "agents": 12,
            "days": 4
          },
          {
            "role": "ts-supabase",
            "errors": 1500,
            "agents": 8,
            "days": 5
          },
          {
            "role": "ts-property",
            "errors": 800,
            "agents": 6,
            "days": 3,
            "dependency": false
          }
        ]
      },
      {
        "name": "phase-2-dependency-chains",
        "week": 2,
        "description": "Fix dependency-ordered packages",
        "waves": [
          {
            "package": "@valueos/shared",
            "agents": 4,
            "days": 2
          },
          {
            "package": "@valueos/backend",
            "services": 800,
            "agents": 8,
            "days": 4
          },
          {
            "package": "@valueos/backend",
            "routes": 1200,
            "agents": 8,
            "days": 5
          },
          {
            "package": "valynt-app",
            "data-layer": 1500,
            "agents": 8,
            "days": 5
          }
        ]
      },
      {
        "name": "phase-3-ui-components",
        "week": 3,
        "description": "Frontend UI and SDUI components",
        "waves": [
          {
            "role": "ts-compatibility",
            "errors": 2000,
            "agents": 10,
            "days": 5
          },
          {
            "role": "ts-agent-fabric",
            "errors": 400,
            "agents": 4,
            "days": 3,
            "sync": true
          }
        ]
      },
      {
        "name": "phase-4-cleanup",
        "week": 4,
        "description": "Final sweep and hardening",
        "tasks": [
          {
            "type": "ratchet-check",
            "target": 100
          },
          {
            "type": "strict-zone-verify"
          },
          {
            "type": "ci-gate-update"
          }
        ]
      }
    ]
  },
  "qualityGates": {
    "preCommit": [
      "tsc --noEmit",
      "pnpm run test:unit --run --changed",
      "pnpm run test:rls"
    ],
    "postBatch": [
      "pnpm run typecheck:full",
      "pnpm run test:smoke"
    ],
    "daily": [
      "error-count-diff",
      "test-pass-rate",
      "tenant-isolation-verify"
    ]
  }
}
