+export const createMockStripeService = () => ({
+  createCustomer: vi.fn(() => Promise.resolve({ id: "cus_test", email: "test@example.com" })),
+  createSubscription: vi.fn(() => Promise.resolve({ id: "sub_test", status: "active" })),
