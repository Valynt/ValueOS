-  const messageId = generateId();
-  const words = text.split(' ');
-  
-  for (let i = 0; i < words.length; i++) {
-    const word = words[i] + (i < words.length - 1 ? ' ' : '');
-    onEvent(createMessageDelta(runId, messageId, word, false));
-    await delay(charDelay * 2);
-  }
