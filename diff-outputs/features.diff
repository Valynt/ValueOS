-
-// Assumption template
-export interface AssumptionTemplate {
-  id: string;
-  label: string;
-  description?: string;
-  type: 'number' | 'currency' | 'percent';
-  defaultValue: number;
-  min: number;
-  max: number;
-  step: number;
-  unit: string;
-  impactMultiplier: number;
