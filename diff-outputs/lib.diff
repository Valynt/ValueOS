+            parseInt(this.calculateExecutionDuration(input).match(/\d+/)?.[0] || "60") *
+              24 *
+              60 *
+              60 *
+              60 *
+              1000
+        )
+          .toISOString()
+          .split("T")[0],
+        criteria: ["50% of target achieved", "No major blockers", "On track timeline"],
+      },
+      {
+        milestone: "Target Achievement",
