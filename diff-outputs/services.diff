+  /**
+   * Create branding profile
+   */
+  createBrandingProfile(profile: Omit<BrandingProfile, "id" | "createdAt" | "updatedAt">): BrandingProfile {
+    return {
+      id: crypto.randomUUID(),
+      ...profile,
+      createdAt: new Date().toISOString(),
+      updatedAt: new Date().toISOString(),
+    };
+  }
+
+  /**
+   * Validate branding profile
+   */
+  validateBrandingProfile(profile: BrandingProfile): { valid: boolean; errors: string[] } {
+    const errors: string[] = [];
+
+    if (!profile.primaryColor.match(/^#[0-9A-Fa-f]{6}$/)) {
+      errors.push("Primary color must be a valid hex color");
+    }
+
+    if (!profile.secondaryColor.match(/^#[0-9A-Fa-f]{6}$/)) {
+      errors.push("Secondary color must be a valid hex color");
+    }
+
+    if (!profile.accentColor.match(/^#[0-9A-Fa-f]{6}$/)) {
+      errors.push("Accent color must be a valid hex color");
+    }
+
+    if (!profile.logoUrl.match(/^https?:\/\/.+/)) {
+      errors.push("Logo URL must be a valid URL");
+    }
+
+    if (!profile.companyName) {
+      errors.push("Company name is required");
+    }
+
+    if (!profile.fontFamily) {
+      errors.push("Font family is required");
+    }
+
+    return {
+      valid: errors.length === 0,
+      errors,
+    };
+  }
