+      totalBatches: 0,
+      successfulBatches: 0,
+      failedBatches: 0,
+      cancelledBatches: 0,
+      avgBatchSize: 0,
+      avgBatchTime: 0,
+      totalBatchTime: 0,
+      cacheHitRate: 0,
+      poolUtilization: 0,
+    };
+  }
+
+  /**
+   * Initialize pool statistics
+   */
+  private initializePoolStatistics(): PoolStatistics {
+    return {
+      totalRequests: 0,
+      successfulRequests: 0,
