+        memoryReduction *= compressionRatio;
+        performanceImpact = "moderate";
+      }
+
+      // Determine performance impact
+      if (memoryReduction > 50 * 1024 * 1024) {
+        // 50MB
+        performanceImpact = "significant";
+      } else if (memoryReduction > 10 * 1024 * 1024) {
+        // 10MB
+        performanceImpact = "moderate";
