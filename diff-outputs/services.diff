+        style: {
+          fontSize: 16,
+        },
+      },
+      {
+        id: "strategic_implications",
+        type: "text",
+        title: "Strategic Implications",
+        content: valueCase.business_case?.strategic_implications || "No strategic implications available",
+        style: {
+          fontSize: 16,
+        },
+      },
+      {
+        id: "recommendations",
+        type: "list",
+        title: "Recommendations",
+        content: valueCase.business_case?.recommendations || [],
+        style: {
+          fontSize: 16,
+        },
+      },
+      {
+        id: "next_steps",
+        type: "list",
+        title: "Next Steps",
+        content: valueCase.business_case?.next_steps || [],
+        style: {
