+  /**
+   * Get template by type
+   */
+  getTemplate(type: ArtifactType): ArtifactTemplate | undefined {
+    return this.templates.get(type);
+  }
+
+  /**
+   * List all templates
+   */
+  listTemplates(): ArtifactTemplate[] {
+    return Array.from(this.templates.values());
+  }
+
+  /**
+   * Register custom template
+   */
+  registerTemplate(template: ArtifactTemplate): void {
+    this.templates.set(template.type, template);
+  }
+
+  // ============================================================================
+  // PDF Generation
+  // ============================================================================
+
+  /**
+   * Generate PDF from template
+   */
+  async generatePDF(
+    content: PDFContent,
+    options: PDFGenerationOptions = {}
+  ): Promise<Blob> {
+    try {
+      // Get template
+      let template: ArtifactTemplate | undefined;
+      if (options.templateId) {
+        template = Array.from(this.templates.values()).find(t => t.id === options.templateId);
+      }
+
+      if (!template && content.metadata?.type) {
+        template = this.templates.get(content.metadata.type as ArtifactType);
+      }
+
+      // Apply branding
+      const brandedContent = this.applyBranding(content, options.brandingProfile);
+
+      // Generate PDF structure
+      const pdfStructure = this.generatePDFStructure(brandedContent, template);
+
+      // Create PDF blob (simulated - in real implementation, use jsPDF or similar)
+      const pdfBlob = await this.createPDFBlob(pdfStructure, options);
+
+      return pdfBlob;
+    } catch (error) {
+      throw new Error(`Failed to generate PDF: ${error instanceof Error ? error.message : "Unknown error"}`);
+    }
+  }
+
+  /**
+   * Apply branding to content
+   */
+  private applyBranding(content: PDFContent, brandingProfile?: BrandingProfile): PDFContent {
+    if (!brandingProfile) {
+      return content;
+    }
+
+    const brandedContent: PDFContent = {
+      ...content,
+      sections: content.sections.map(section => ({
+        ...section,
+        style: {
+          ...section.style,
+          color: section.style?.color || brandingProfile.primaryColor,
+        },
+      })),
+      metadata: {
+        ...content.metadata,
+        branding: {
+          logo: brandingProfile.logoUrl,
+          primaryColor: brandingProfile.primaryColor,
+          secondaryColor: brandingProfile.secondaryColor,
+          accentColor: brandingProfile.accentColor,
+          fontFamily: brandingProfile.fontFamily,
+          companyName: brandingProfile.companyName,
+          tagline: brandingProfile.tagline,
+        },
+      },
+    };
+
+    return brandedContent;
+  }
+
+  /**
+   * Generate PDF structure
+   */
+  private generatePDFStructure(content: PDFContent, template?: ArtifactTemplate): any {
+    const structure = {
+      metadata: {
+        title: content.title,
+        author: content.metadata?.branding?.companyName || "ValueOS",
+        creator: "ValueOS PDF Generator",
+        created: new Date().toISOString(),
+        branding: content.metadata?.branding,
+      },
+      sections: content.sections.map(section => ({
+        ...section,
+        style: {
+          ...this.config.defaultMargins,
+          fontSize: section.style?.fontSize || this.config.defaultFontSize,
+          ...section.style,
+        },
+      })),
+    };
+
+    // Apply template structure if available
+    if (template?.structure) {
+      structure.sections = this.mergeWithTemplate(structure.sections, template.structure);
+    }
+
+    return structure;
+  }
+
+  /**
+   * Merge content with template structure
+   */
+  private mergeWithTemplate(sections: any[], templateStructure: any): any[] {
+    if (templateStructure.sections) {
+      // Map template sections to content sections
+      return templateStructure.sections.map((templateSection: any) => {
+        const contentSection = sections.find(s => s.id === templateSection.id);
+        return {
+          ...templateSection,
+          ...contentSection,
+          style: {
+            ...templateSection.style,
+            ...contentSection?.style,
+          },
+        };
+      });
+    }
+
+    if (templateStructure.slides) {
+      return templateStructure.slides.map((templateSlide: any) => {
+        const contentSection = sections.find(s => s.id === templateSlide.id);
+        return {
+          ...templateSlide,
+          ...contentSection,
+          style: {
+            ...templateSlide.style,
+            ...contentSection?.style,
+          },
+        };
+      });
+    }
+
+    return sections;
+  }
+
+  /**
+   * Create PDF blob (simulated)
+   */
+  private async createPDFBlob(structure: any, options: PDFGenerationOptions): Promise<Blob> {
+    // In a real implementation, this would use jsPDF or similar library
+    // For now, we'll create a simulated PDF blob with the structure as JSON
+    const pdfContent = {
+      version: "1.0",
+      metadata: structure.metadata,
+      sections: structure.sections,
+      generatedAt: new Date().toISOString(),
+      options: {
+        compress: options.compress || false,
+        quality: options.quality || "medium",
+        includePageNumbers: options.includePageNumbers || false,
+        includeTableOfContents: options.includeTableOfContents || false,
+      },
+    };
+
+    const jsonStr = JSON.stringify(pdfContent, null, 2);
+    return new Blob([jsonStr], { type: "application/pdf" });
+  }
