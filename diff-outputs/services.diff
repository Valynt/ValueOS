+    format: ArtifactFormat,
+    data: any
+  ): Promise<ArtifactStorageMetadata> {
+    // Convert data to appropriate format
+    let content: Blob;
+    let mimeType: string;
+
+    switch (format) {
+      case "pdf":
+        content = new Blob([JSON.stringify(data)], { type: "application/pdf" });
+        mimeType = "application/pdf";
+        break;
+      case "pptx":
+        content = new Blob([JSON.stringify(data)], { type: "application/vnd.openxmlformats-officedocument.presentationml.presentation" });
+        mimeType = "application/vnd.openxmlformats-officedocument.presentationml.presentation";
+        break;
+      case "html":
+        content = new Blob([JSON.stringify(data)], { type: "text/html" });
+        mimeType = "text/html";
+        break;
+      case "csv":
+        content = new Blob([JSON.stringify(data)], { type: "text/csv" });
+        mimeType = "text/csv";
+        break;
+      case "json":
+        content = new Blob([JSON.stringify(data)], { type: "application/json" });
+        mimeType = "application/json";
+        break;
+      default:
+        throw new Error(`Unsupported format: ${format}`);
+    }
+
+    const sizeBytes = content.size;
+    const checksum = await this.generateChecksum(content);
+
+    // Upload to storage
+    const filePath = `artifacts/${artifactId}/${versionId}.${format}`;
+    const { error } = await this.supabase.storage
+      .from(this.config.storageBucket)
+      .upload(filePath, content, {
+        contentType: mimeType,
+        upsert: true,
+      });
+
+    if (error) {
+      throw new Error(`Failed to store artifact: ${error.message}`);
