+
+      await seedTestData(supabase, { customers: [customer] });
+
+      const { data } = await supabase
+        .from("billing_customers")
+        .select("*")
+        .eq("id", customer.id)
+        .single();
+
+      const dataString = JSON.stringify(data);
+
+      // Should not contain CVV-like patterns
