+  private constructor() {
+    this.thresholds = this.getDefaultThresholds();
+    logger.info("AgentMetricsCollector initialized");
+  }
+
+  /**
+   * Get singleton instance
+   */
+  static getInstance(): AgentMetricsCollector {
+    if (!AgentMetricsCollector.instance) {
