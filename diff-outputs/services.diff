+  /** Cache tags */
+  tags: string[];
+}
+
+export interface CacheMetadata {
+  /** Agent type */
+  agentType: AgentType;
+  /** Request hash */
+  requestHash: string;
+  /** Response generation time */
+  generationTime: number;
+  /** Response confidence */
+  confidence: string;
+  /** Cache source */
+  source: "agent" | "fallback" | "synthetic";
+  /** Cache version */
+  version: string;
