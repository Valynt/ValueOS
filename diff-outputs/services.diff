+      state: breaker.canExecute()
+        ? 'closed'
+        : Date.now() - lastFailureTs > this.config.cooldownPeriod
+        ? 'half-open'
+        : 'open',
+      failureCount: breaker.getFailureCount(),
+      lastFailureTime: lastFailureTime,
