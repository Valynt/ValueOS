+/**
+ * Audit log statistics
+ */
+export interface AuditLogStats {
+  /**
+   * Total requests
+   */
+  totalRequests: number;
+
+  /**
+   * Successful requests
+   */
+  successfulRequests: number;
+
+  /**
+   * Failed requests
+   */
+  failedRequests: number;
+
+  /**
+   * Average duration (ms)
+   */
+  averageDuration: number;
+
+  /**
+   * Average confidence
+   */
+  averageConfidence: number;
+
+  /**
+   * Requests by agent
+   */
+  byAgent: Record<AgentType, number>;
+
