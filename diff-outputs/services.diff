+
+    it('should return false when no session exists', async () => {
+      // Arrange
+      mocks.mockSupabaseAuth.getSession.mockResolvedValue({
+        data: { session: null },
+        error: null,
+      });
+
+      // Act
+      const result = await service.isAuthenticated();
+
+      // Assert
+      expect(result).toBe(false);
+    });
+  });
+});
