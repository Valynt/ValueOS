+  }
+
+  private getErrorSDUI(): SDUIPageDefinition {
+    return {
+      type: "page",
+      version: 1,
+      sections: [
+        {
+          type: "component",
+          component: "AgentResponseCard",
+          version: 1,
+          props: {
+            response: {
+              id: "err",
