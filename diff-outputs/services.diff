+    }
+
+    const state = this.getOrCreateDegradationState(agentType);
+    const targetLevelObj = policy.levels.find((l) => l.name === targetLevel);
+
+    if (!targetLevelObj) {
+      logger.warn("Invalid degradation level", { agentType, targetLevel });
+      return false;
+    }
