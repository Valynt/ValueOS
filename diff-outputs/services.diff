+
+    const storageMetadata: ArtifactStorageMetadata = {
+      artifactId,
+      versionId,
+      storagePath: filePath,
+      format,
+      sizeBytes,
+      mimeType,
+      checksum,
+      uploadedAt: new Date().toISOString(),
