+    const content: PDFContent = {
+      title: `${template.name} - ${valueCase.companyName}`,
+      sections: [],
+      metadata: {
+        type: templateType,
+        valueCaseId: valueCase.id,
+        companyName: valueCase.companyName,
+        generatedAt: new Date().toISOString(),
+      },
+    };
+
+    // Populate sections based on template type
+    switch (templateType) {
+      case "executive_summary":
+        content.sections = this.createExecutiveSummarySections(valueCase);
+        break;
+      case "cfo_brief":
+        content.sections = this.createCFOBriefSections(valueCase);
+        break;
+      case "board_deck":
+        content.sections = this.createBoardDeckSections(valueCase);
+        break;
+      default:
