+    const cleanedCount = beforeSize - this.cache.size;
+
+    if (cleanedCount > 0) {
+      logger.debug("Cache cleanup completed", {
+        cleanedCount,
+        remainingEntries: this.cache.size,
+        currentSize: this.currentSize,
+      });
+    }
+  }
