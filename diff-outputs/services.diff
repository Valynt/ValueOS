+/**
+ * Vite Configuration for WebSocket Support
+ *
+ * Ensure Vite is configured properly for WebSocket connections.
+ */
+export const viteWebSocketConfig = {
+  server: {
+    hmr: {
+      port: 24678,
+      host: 'localhost',
+      protocol: 'ws',
+      timeout: 30000,
+      overlay: true,
+    },
