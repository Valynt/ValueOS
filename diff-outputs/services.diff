+
+  private readonly anomalyPatterns: AnomalyPattern[] = [
+    {
+      id: 'login_spike',
+      name: 'Login Spike Anomaly',
+      description: 'Unusual spike in login attempts',
+      baseline: { mean: 50, stdDev: 10, threshold: 3 },
