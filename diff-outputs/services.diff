+      organization_id: 'org-123',
+      period: '2023-10',
+      users: 5,
+      teams: 2,
+      projects: 10,
+      storage: 1000,
+      api_calls: 50,
+      agent_calls: 5,
+      last_updated: new Date().toISOString(),
