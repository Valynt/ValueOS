+    const previousLevel = state.currentLevel;
+    state.currentLevel = targetLevel;
+    state.levelStartTime = new Date();
+
+    // Record degradation event
+    const event: DegradationEvent = {
+      id: uuidv4(),
+      timestamp: new Date(),
+      type: "level_change",
+      previousLevel,
+      newLevel: targetLevel,
