+        { event_type: 'test2', timestamp: new Date().toISOString() },
+        { event_type: 'test3', timestamp: new Date().toISOString() }
+      ];
+
+      mockDB.insert.mockResolvedValue({ data: batch, error: null });
+
+      expect(batch.length).toBe(3);
+    });
+  });
+});
