+                data: [{
+                  id: 'vt-1',
+                  compliance_metadata: {
+                    results: [{ rule_id: 'r1', passed: true, message: 'passed' }]
+                  }
+                }],
+                error: null
+              }))
+            }))
+          } as any;
+        }
+        if (table === 'roi_models') {
+           return {
+            select: vi.fn(() => ({
+              in: vi.fn(() => ({
+                data: [{
+                  id: 'roi-1',
