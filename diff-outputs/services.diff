+}
+
+// ============================================================================
+// Singleton Instance
+// ============================================================================
+
+let pdfTemplateServiceInstance: PDFTemplateService | null = null;
+
+export function getPDFTemplateService(config?: Partial<PDFTemplateConfig>): PDFTemplateService {
+  if (!pdfTemplateServiceInstance) {
+    pdfTemplateServiceInstance = new PDFTemplateService(config);
