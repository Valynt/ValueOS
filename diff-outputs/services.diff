+    await this.auditLogService.logAudit({
+      userId: actor.id,
+      userName: actor.name,
+      userEmail: actor.email,
+      action: "admin.user.remove",
+      resourceType: "user",
+      resourceId: payload.userId,
+      details: {
+        tenantId: payload.tenantId,
+      },
+      status: "success",
+    });
+  }
+}
