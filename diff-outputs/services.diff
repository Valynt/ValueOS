+  /** Condition operator */
+  operator: "equals" | "not_equals" | "greater_than" | "less_than" | "contains" | "matches";
+  /** Condition value */
+  value: unknown;
+  /** Condition parameters */
+  parameters?: Record<string, unknown>;
+}
+
