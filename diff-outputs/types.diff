+
+export interface Subscription {
+  id: string;
+  billing_customer_id: string;
+  tenant_id: string;
+  stripe_subscription_id: string;
+  stripe_customer_id: string;
+  plan_tier: PlanTier;
+  billing_period: 'monthly' | 'yearly';
+  status: 'active' | 'past_due' | 'canceled' | 'unpaid' | 'incomplete' | 'trialing';
