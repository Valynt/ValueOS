+  | 'user.theme'
+  | 'user.language'
+  | 'user.timezone'
+  | 'user.dateFormat'
+  | 'user.timeFormat'
+  // Notifications
+  | 'user.notifications.email'
+  | 'user.notifications.push'
+  | 'user.notifications.slack'
+  | 'user.notifications.inApp'
+  // Accessibility
+  | 'user.accessibility.highContrast'
