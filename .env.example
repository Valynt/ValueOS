# ValueOS Environment Configuration (Example)
# Copy to .env.local or run: pnpm run dx:env --mode local --force

# =============================================================================
# Core
# =============================================================================
NODE_ENV=development

# =============================================================================
# URLs
# =============================================================================
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3001

# =============================================================================
# Ports
# =============================================================================
VITE_PORT=5173
VITE_HOST=0.0.0.0
VITE_HMR_HOST=localhost
VITE_HMR_PORT=24678
VITE_HMR_CLIENT_PORT=24678
API_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379
SUPABASE_API_PORT=54321
SUPABASE_STUDIO_PORT=54323
SUPABASE_DB_PORT=54322
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
CADDY_ADMIN_PORT=2019

# =============================================================================
# Supabase (local defaults)
# =============================================================================
VITE_SUPABASE_URL=http://localhost:54321
SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-or-dev-key
SUPABASE_ANON_KEY=replace-with-local-or-dev-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-or-dev-key

# =============================================================================
# Data Stores
# =============================================================================
# CRITICAL: sslmode=disable required - local postgres has no TLS
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres?sslmode=disable
DB_URL=postgresql://postgres:postgres@localhost:54322/postgres?sslmode=disable
REDIS_URL=redis://localhost:6379

# =============================================================================
# Optional integrations
# =============================================================================
VITE_LLM_PROVIDER=together
TOGETHER_API_KEY=
OPENAI_API_KEY=

# =============================================================================
# Development
# =============================================================================
VITE_DEV_EMAIL=
VITE_DEV_PASSWORD=
