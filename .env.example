# ValueOS Environment Configuration (Example)
# Copy to .env.local for local secrets/overrides, or run: pnpm run dx:env --mode local --force
# Ports live in .env.ports; keep any URL port values in sync with that file.

# =============================================================================
# Core
# =============================================================================
NODE_ENV=development

# =============================================================================
# URLs
# =============================================================================
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3001
# Dev-only Vite proxy target. Keep VITE_API_BASE_URL as the canonical client API base.
VITE_API_PROXY_TARGET=http://localhost:3001

# =============================================================================
# Supabase (local defaults)
# =============================================================================
VITE_SUPABASE_URL=http://localhost:54321
SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-or-dev-key
SUPABASE_ANON_KEY=replace-with-local-or-dev-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-or-dev-key

# =============================================================================
# Data Stores
# =============================================================================
# CRITICAL: sslmode=disable required - local postgres has no TLS
# Canonical local DB contract
DB_HOST=localhost
DB_NAME=valuecanvas_dev
DB_USER=postgres
DB_PASSWORD=dev_password
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev?sslmode=disable
DB_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev?sslmode=disable
REDIS_URL=redis://localhost:6379

# =============================================================================
# Optional integrations
# =============================================================================
VITE_LLM_PROVIDER=together
TOGETHER_API_KEY=
OPENAI_API_KEY=

# =============================================================================
# Development
# =============================================================================
VITE_DEV_EMAIL=
VITE_DEV_PASSWORD=
