# ValueOS non-secret defaults
# Source of truth for ports: config/ports.json -> generated .env.ports

NODE_ENV=development
DX_MODE=local

# Frontend behavior
VITE_HOST=0.0.0.0
VITE_API_BASE_URL=/api
VITE_APP_URL=http://localhost:5173
VITE_LLM_PROVIDER=together
VITE_ENABLE_CIRCUIT_BREAKER=false
VITE_ENABLE_RATE_LIMITING=false
VITE_ENABLE_AUDIT_LOGGING=true
VITE_DEV_TOOLS=true
VITE_SOURCE_MAPS=true

# Runtime behavior
SECRETS_VOLUME_WATCH_ENABLED=false
SHUTDOWN_TIMEOUT_MS=120000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Observability defaults
PROMETHEUS_METRICS_ENABLED=true
METRICS_INTERVAL=30000

# Dev domain/proxy defaults
DEV_DOMAIN=localhost
CADDY_LOG_LEVEL=DEBUG
AUTO_HTTPS=off

# Secrets are intentionally NOT defined here.
# Put secrets only in .env.local (see .env.local.example).
