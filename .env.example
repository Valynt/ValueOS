# ValueOS application defaults (non-secret, non-port values only)
#
# Port variables are intentionally excluded from this file.
# Source port mappings from .env.ports (or .env.ports.example), e.g.:
#   set -a; source .env.example; source .env.ports; source .env.local; set +a
#
# Keep secrets in .env.local only (see .env.local.example).

NODE_ENV=development
MFA_ENABLED=false
MIGRATIONS_DIR=infra/supabase/supabase/migrations

# Supabase URL routing
SUPABASE_INTERNAL_URL=http://kong:8000
SUPABASE_PUBLIC_URL=http://localhost:${SUPABASE_API_PORT}

# Runtime defaults
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_MAX_ATTEMPTS=1
LLM_RETRY_BACKOFF_MS=200
UV_THREADPOOL_SIZE=8
PG_POOL_MIN=4
PG_POOL_MAX=40
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_TLS_CA_CERT_PATH=/run/secrets/redis-ca.crt
REDIS_TLS_SERVERNAME=redis.example.com

# Kafka (optional — disabled by default)
# Enable to use Kafka-backed agent execution, event sourcing, and sagas.
# When disabled, agent API routes return 503 for Kafka-dependent endpoints.
# KAFKA_ENABLED=true
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=valueos-event-producer
# KAFKA_SSL_ENABLED=false
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SASL_MECHANISM=
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
