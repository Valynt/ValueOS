# ============================================================================
# ValueCanvas Development Environment Variables
# ============================================================================
# Copy this file to .env.local for local development
# WARNING: These are development-only defaults. DO NOT use in production!
# ============================================================================

# Application Environment
NODE_ENV=development
VITE_HOST=0.0.0.0
VITE_PORT=5173
VITE_HMR_PORT=24678

# ============================================================================
# Supabase Configuration
# ============================================================================
# Local Supabase development setup
VITE_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ============================================================================
# LLM API Configuration
# ============================================================================
# Configure your LLM provider (together, openai, anthropic, etc.)
VITE_LLM_API_KEY=your-llm-api-key-here
VITE_LLM_PROVIDER=together

# ============================================================================
# Database Configuration (Local PostgreSQL)
# ============================================================================
# WARNING: Change these passwords before deploying!
# These are weak passwords for LOCAL DEVELOPMENT ONLY
POSTGRES_DB=valuecanvas_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password
DATABASE_URL=postgresql://postgres:dev_password@localhost:54322/valuecanvas_dev
DB_URL=postgresql://postgres:dev_password@localhost:54322/valuecanvas_dev

# Connection Pool & Threading (Performance Tuning)
# Increase the libuv thread pool and Postgres pool for load testing the 2-pod baseline
UV_THREADPOOL_SIZE=8
PG_POOL_MIN=4
PG_POOL_MAX=40
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000

# ============================================================================
# Redis Configuration (Local)
# ============================================================================
# WARNING: Change this password before deploying!
# Weak password for LOCAL DEVELOPMENT ONLY
REDIS_PASSWORD=redis_dev_password_CHANGE_ME
REDIS_URL=redis://redis:6379

# ============================================================================
# Security Settings (Development)
# ============================================================================
# These are disabled/relaxed for development
# They are enabled and enforced in production
VITE_ENABLE_CIRCUIT_BREAKER=false
VITE_ENABLE_RATE_LIMITING=false
VITE_ENABLE_AUDIT_LOGGING=true

# ============================================================================
# Development Tools
# ============================================================================
VITE_DEV_TOOLS=true
VITE_SOURCE_MAPS=true

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. Never commit .env.local to version control
# 2. Change all passwords before any deployment
# 3. Use strong, unique passwords in production
# 4. Keep API keys secret and rotate regularly
# 5. Enable all security features in production
# ============================================================================

# Scalekit Authentication - PRODUCTION CREDENTIALS
# Add these to your .env.local file (NEVER commit to git)

# Scalekit Configuration
SCALEKIT_ENVIRONMENT_URL=https://your-env.scalekit.dev
SCALEKIT_CLIENT_ID=your-scalekit-client-id
SCALEKIT_CLIENT_SECRET=your-scalekit-client-secret

# Application URLs (Development)
SCALEKIT_REDIRECT_URI=http://localhost:3001/api/auth/callback
SCALEKIT_POST_LOGOUT_URI=http://localhost:5173/login?logged_out=true

# API Configuration
API_PORT=3001
NODE_ENV=development

# Application URLs
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3001/api