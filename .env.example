# ValueOS Environment Configuration (Example)
# Copy to .env.local or run: pnpm run dx:env --mode local --force

# =============================================================================
# Core
# =============================================================================
NODE_ENV=development

# =============================================================================
# URLs
# =============================================================================
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3001
# Dev-only Vite proxy target. Keep VITE_API_BASE_URL as the canonical client API base.
VITE_API_PROXY_TARGET=http://localhost:3001

# =============================================================================
# Ports
# =============================================================================
WEB_PORT=5173
API_PORT=3001
DB_PORT=5432

# Legacy aliases (backward compatibility)
VITE_PORT=5173
VITE_HOST=0.0.0.0
VITE_HMR_HOST=localhost
VITE_HMR_PORT=24678
VITE_HMR_CLIENT_PORT=24678
POSTGRES_PORT=5432
REDIS_PORT=6379
SUPABASE_API_PORT=54321
SUPABASE_STUDIO_PORT=54323
SUPABASE_DB_PORT=54322
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
CADDY_ADMIN_PORT=2019

# =============================================================================
# Supabase (local defaults)
# =============================================================================
SUPABASE_INTERNAL_URL=http://kong:8000
SUPABASE_PUBLIC_URL=http://localhost:${SUPABASE_API_PORT}
VITE_SUPABASE_URL=${SUPABASE_PUBLIC_URL}
SUPABASE_URL=${SUPABASE_INTERNAL_URL}
VITE_SUPABASE_ANON_KEY=replace-with-local-or-dev-key
SUPABASE_ANON_KEY=replace-with-local-or-dev-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-or-dev-key

# =============================================================================
# Data Stores
# =============================================================================
# CRITICAL: sslmode=disable required - local postgres has no TLS
# Canonical local DB contract
DB_HOST=localhost
DB_PORT=5432
DB_NAME=valuecanvas_dev
DB_USER=postgres
DB_PASSWORD=dev_password
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev?sslmode=disable
DB_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev?sslmode=disable
REDIS_URL=redis://localhost:6379

# =============================================================================
# Optional integrations
# =============================================================================
VITE_LLM_PROVIDER=together
TOGETHER_API_KEY=
OPENAI_API_KEY=

# =============================================================================
# Development
# =============================================================================
VITE_DEV_EMAIL=
VITE_DEV_PASSWORD=
