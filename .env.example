# ValueOS non-secret defaults
# Source of truth for ports: config/ports.json -> generated .env.ports

NODE_ENV=development
DX_MODE=local

# Frontend behavior
VITE_HOST=0.0.0.0
VITE_API_BASE_URL=/api
VITE_APP_URL=http://localhost:5173
VITE_LLM_PROVIDER=together
VITE_ENABLE_CIRCUIT_BREAKER=false
VITE_ENABLE_RATE_LIMITING=false
VITE_ENABLE_AUDIT_LOGGING=true
VITE_DEV_TOOLS=true
VITE_SOURCE_MAPS=true

# Runtime behavior
SECRETS_VOLUME_WATCH_ENABLED=false
SHUTDOWN_TIMEOUT_MS=120000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Observability defaults
PROMETHEUS_METRICS_ENABLED=true
METRICS_INTERVAL=30000

# Dev domain/proxy defaults
DEV_DOMAIN=localhost
CADDY_LOG_LEVEL=DEBUG
AUTO_HTTPS=off

# Secrets are intentionally NOT defined here.
# Put secrets only in .env.local (see .env.local.example).
# ============================================================================
# Critical Security Notes
# ============================================================================
# 1. Never commit .env.local to version control
# 2. All secrets should be loaded from Vault/AWS Secrets Manager in production
# 3. Use strong, unique passwords in production (minimum 16 characters)
# 4. Keep API keys secret and rotate regularly
# 5. Enable all security features in production
# 6. Use environment-specific configuration files
# 7. Validate all environment variables at startup using SecretValidator
# ============================================================================

# API Configuration
API_PORT=3001
SESSION_SECRET=your-session-secret
