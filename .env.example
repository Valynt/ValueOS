# ============================================================================
# ValueCanvas Development Environment Variables Template
# ============================================================================
# Copy this file to .env.local for local development
# WARNING: These are development-only defaults. DO NOT use in production!
# ============================================================================

# Application Environment
NODE_ENV=development
VITE_HOST=0.0.0.0
# Ports are sourced from config/ports.json and synced to .env.ports
VITE_PORT=5173
VITE_HMR_PORT=24678

# ============================================================================
# Supabase Configuration
# ============================================================================
# Local Docker development setup - pointing to Supabase service
# For production, replace with your actual Supabase project URLs
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# DX_SUPABASE_LOCAL=1 forces DX doctor to require the Supabase CLI even if VITE_SUPABASE_URL is remote.
VITE_SUPABASE_URL=http://localhost:54321
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-supabase-anon-key-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Service Role Key (server-side only - NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# LLM API Configuration
# ============================================================================
# Configure your LLM provider (together, openai, anthropic, etc.)
# Get API keys from respective provider dashboards
VITE_LLM_API_KEY=your-llm-api-key-here
VITE_LLM_PROVIDER=together
TOGETHER_API_KEY=your-together-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================================================
# Database Configuration (Local PostgreSQL)
# ============================================================================
# WARNING: Change these passwords before deploying!
# These are weak passwords for LOCAL DEVELOPMENT ONLY
POSTGRES_DB=valuecanvas_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password

# Connection Pool & Threading (Performance Tuning)
# Increase the libuv thread pool and Postgres pool for load testing the 2-pod baseline
UV_THREADPOOL_SIZE=8
PG_POOL_MIN=4
PG_POOL_MAX=40
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000

# ============================================================================
# Redis Configuration (Local)
# ============================================================================
# WARNING: Change this password before deploying!
# Weak password for LOCAL DEVELOPMENT ONLY
REDIS_PASSWORD=redis_dev_password_CHANGE_ME

# ============================================================================
# Security Settings (Development)
# ============================================================================
# These are disabled/relaxed for development
# They are enabled and enforced in production
VITE_ENABLE_CIRCUIT_BREAKER=false
VITE_ENABLE_RATE_LIMITING=false
VITE_ENABLE_AUDIT_LOGGING=true

# ============================================================================
# Development Tools
# ============================================================================
VITE_DEV_TOOLS=true
VITE_SOURCE_MAPS=true

# ============================================================================
# Application URLs (Development)
# ============================================================================
VITE_APP_URL=http://localhost:5173
# API base URL:
# - Direct/local dev: http://localhost:${API_PORT}
# - Caddy/edge (docker-compose.dev.yml): /api
VITE_API_BASE_URL=http://localhost:${API_PORT}

# ============================================================================
# Caddy Edge (Development Defaults)
# ============================================================================
DEV_DOMAIN=localhost
API_UPSTREAM=http://backend:3001
FRONTEND_UPSTREAM=http://frontend:5173
CADDY_ADMIN=0.0.0.0:2019
CADDY_LOG_LEVEL=DEBUG
AUTO_HTTPS=off

# ============================================================================
# Authentication Configuration
# ============================================================================
# Scalekit Authentication (if using Scalekit)
# SCALEKIT_ENVIRONMENT_URL=https://your-tenant.scalekit.dev
# SCALEKIT_CLIENT_ID=your-scalekit-client-id
# SCALEKIT_CLIENT_SECRET=your-scalekit-client-secret
# SCALEKIT_REDIRECT_URI=http://localhost:3001/api/auth/callback
# SCALEKIT_POST_LOGOUT_URI=http://localhost:5173/login?logged_out=true

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. Never commit .env.local to version control
# 2. Change all passwords before any deployment
# 3. Use strong, unique passwords in production (minimum 16 characters)
# 4. Keep API keys secret and rotate regularly
# 5. Enable all security features in production
# 6. Use environment-specific configuration files
# 7. Validate all environment variables at startup
# ============================================================================

# Database connection URLs (constructed from above)
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev
DB_URL=postgresql://postgres:dev_password@localhost:5432/valuecanvas_dev
REDIS_URL=redis://redis:6379

# API Configuration
API_PORT=3001
