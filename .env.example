NODE_ENV=development
# Corrected ports
API_PORT=8000
FRONTEND_PORT=5173

# Upstream targets
API_UPSTREAM=http://backend:8000
FRONTEND_UPSTREAM=http://frontend:3001

# Supabase (server-side)
SUPABASE_URL=https://wfhdrrpijqygytvoaafc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# DB (direct for migrations)
DIRECT_DATABASE_URL=postgresql://postgres:<PASSWORD>@db.wfhdrrpijqygytvoaafc.supabase.co:5432/postgres?sslmode=require
PGSSLMODE=require
MIGRATIONS_DIR=infra/supabase/supabase/migrations

# Redis (optional)
REDIS_URL=<rediss-url>
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_TLS_CA_CERT_PATH=/run/secrets/redis-ca.crt
REDIS_TLS_SERVERNAME=redis.example.com

# LLM (server-side)
TOGETHER_API_KEY=<together-key>
TOGETHER_PRIMARY_MODEL_NAME=moonshotai/Kimi-K2-Thinking
TOGETHER_SECONDARY_MODEL_NAME=openai/gpt-oss-120b
# Automatic fallback controls (backend): enable, retry attempts, and retry backoff in ms
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_MAX_ATTEMPTS=1
LLM_RETRY_BACKOFF_MS=200

# Security (server-side)
JWT_SECRET=<dev-secret>
ENCRYPTION_KEY=<dev-secret>

# Pool tuning (server-side)
UV_THREADPOOL_SIZE=8
PG_POOL_MIN=4
PG_POOL_MAX=40
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000
