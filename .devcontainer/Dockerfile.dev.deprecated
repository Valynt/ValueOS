# Two-stage devcontainer: keep heavy toolchains in build stage, runtime runs as a non-privileged user
FROM node:20-slim AS build-deps

# Create a non-privileged user and group first
ARG USER_ID=65532
ARG USER_GID=65532
RUN groupadd -g ${USER_GID} valueos || true \
    && useradd -m -u ${USER_ID} -g ${USER_GID} valueos || true

# Install build tools and python to compile native modules during dependency install
# These are confined to the build stage and will not be in the final image
ARG INSTALL_PLAYWRIGHT_DEPS=0
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git build-essential python3 python3-dev \
    && if [ "${INSTALL_PLAYWRIGHT_DEPS}" = "1" ]; then \
      apt-get install -y --no-install-recommends libgtk-3-0 libasound2 libnss3 libxss1 libx11-6 libx11-xcb1 libgconf-2-4 libgbm1 libglib2.0-0 libxrandr2 libappindicator3-1 libatk-bridge2.0-0 libatk1.0-0; \
    fi \
    && rm -rf /var/lib/apt/lists/*

# Install pnpm via corepack (build stage)
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# Install workspace deps (optional - helps caching). This runs as root in the build stage
WORKDIR /workspaces/ValueOS
COPY --chown=valueos:valueos package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
RUN corepack enable && pnpm install --frozen-lockfile || true

# Final runtime: minimal image without developer toolchains, runs as non-root `valueos`
FROM node:20-slim AS runtime
ARG USER_ID=65532
ARG USER_GID=65532
RUN groupadd -g ${USER_GID} valueos || true \
    && useradd -m -u ${USER_ID} -g ${USER_GID} valueos || true

WORKDIR /workspaces/ValueOS

# Install lightweight runtime client tools needed by setup scripts
RUN apt-get update && apt-get install -y --no-install-recommends \
    postgresql-client \
    python3-pip \
    curl \
    git \
    libatomic1 \
  && rm -rf /var/lib/apt/lists/*

# Ensure pnpm is available (enable corepack as root)
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

USER valueos

# Set user-specific pnpm home
ENV PNPM_HOME=/home/valueos/.local/share/pnpm
ENV PATH=${PATH}:/home/valueos/.local/share/pnpm

# Expose ports defined in config/ports.json for network isolation
EXPOSE 5173
EXPOSE 24678
EXPOSE 3001
EXPOSE 5432
EXPOSE 6379
EXPOSE 54321
EXPOSE 54323
EXPOSE 54322
EXPOSE 8080
EXPOSE 8443
EXPOSE 2019
EXPOSE 9090
EXPOSE 3000
EXPOSE 16686
EXPOSE 3100
EXPOSE 3200

# Note: Keep the container running so editors can attach; this is intentionally minimal
CMD ["sleep", "infinity"]
// DEPRECATED: Use Dockerfile.optimized only
