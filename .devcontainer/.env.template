# ValueOS Fully Containerized Development Environment Variables
# WSL2 serves only as a lightweight Linux kernel host
# All services run inside Docker containers
#
# Copy this file to .env and adjust values as needed:
#   cp .devcontainer/.env.template .devcontainer/.env

# =============================================================================
# NODE.JS & PNPM
# =============================================================================
NODE_ENV=development
APP_ENV=local

# =============================================================================
# PORTS
# =============================================================================
# Frontend
FRONTEND_PORT=5173
VITE_HMR_PORT=24678

# Backend
BACKEND_PORT=3001
API_PORT=3001

# Database
PGPORT=5432

# Supabase Services
KONG_PROXY_PORT=54321
KONG_ADMIN_PORT=8001
KONG_GUI_PORT=8002
AUTH_PORT=9999
REST_PORT=3000
STUDIO_PORT=54324
REALTIME_PORT=4000

# Redis
REDIS_PORT=6379

# =============================================================================
# DATABASE
# =============================================================================
PGDATABASE=valueos
PGUSER=postgres
# REQUIRED: Set a strong password. Do not use the default "postgres".
# The compose file uses ${PGPASSWORD:?...} — startup will fail if this is unset.
# Generate one with: openssl rand -base64 24
PGPASSWORD=change-me-before-starting

# Full connection string (internal compose network)
# Update the password here to match PGPASSWORD above.
DATABASE_URL=postgresql://postgres:change-me-before-starting@postgres:5432/valueos

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# SUPABASE
# =============================================================================
# Internal compose network URL
SUPABASE_URL=http://kong:8000

# Required Supabase project keys. Leave blank in git-tracked templates and set
# real local-only values in .devcontainer/.env or the project root .env before startup.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret for Supabase services (must be unique and at least 32 characters)
JWT_SECRET=

# Site URL for auth redirects
SITE_URL=http://localhost:5173
API_EXTERNAL_URL=http://localhost:9999

# =============================================================================
# SECURITY
# =============================================================================
# Local development only - disable encryption at rest
ENCRYPTION_AT_REST_ENABLED=false

# TCT Secret (required, unique, minimum 32 characters)
TCT_SECRET=

# Web Scraper Encryption Key (required 32-byte hex / 64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEB_SCRAPER_ENCRYPTION_KEY=

# =============================================================================
# FRONTEND/BACKEND ORIGINS
# =============================================================================
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:3001
API_BASE_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:5173

# =============================================================================
# VITE CONFIGURATION
# =============================================================================
VITE_API_BASE_URL=http://localhost:3001
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=
VITE_HOST=0.0.0.0
VITE_HMR_HOST=localhost

# =============================================================================
# NETWORK
# =============================================================================
VALUEOS_NETWORK=valueos-dev

# =============================================================================
# REALTIME (Supabase)
# =============================================================================
# Required Phoenix secret (minimum 32 characters)
SECRET_KEY_BASE=

# =============================================================================
# NATS (if needed in future)
# =============================================================================
NATS_URL=nats://nats:4222
