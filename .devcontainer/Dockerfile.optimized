# syntax=docker/dockerfile:1.7

ARG BASE_IMAGE=mcr.microsoft.com/devcontainers/base:ubuntu-22.04
ARG NODE_VERSION=20.19.5
ARG PNPM_VERSION=10.4.1
ARG KUBECTL_VERSION=1.32.2
ARG TERRAFORM_VERSION=1.10.5
ARG NODE_DOWNLOAD_SHA256=315046739a513a70e03a4a55a8afda8cf979f30852e576075c340084e3f8ac0f

FROM ${BASE_IMAGE}

ARG NODE_VERSION
ARG PNPM_VERSION
ARG KUBECTL_VERSION
ARG TERRAFORM_VERSION
ARG NODE_DOWNLOAD_SHA256
ARG USERNAME=vscode
ARG USER_UID=1000
ARG USER_GID=${USER_UID}

ENV DEBIAN_FRONTEND=noninteractive
ENV NODE_DISTRO=node-v${NODE_VERSION}-linux-x64
ENV NODE_DOWNLOAD_URL=https://nodejs.org/dist/v${NODE_VERSION}/${NODE_DISTRO}.tar.xz

# Install base dependencies
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      fdupes \
      git \
      less \
      lsb-release \
      nano \
      openssh-client \
      python3-pip \
      sudo \
      unzip \
      wget \
      xz-utils \
      # Additional dev tools for full containerization
      build-essential \
      pkg-config \
      libssl-dev \
      postgresql-client \
      redis-tools \
      ripgrep \
      jq \
      htop \
      tree \
      # Windsurf server runtime requirements
      libstdc++6 \
      libgcc-s1 \
      libatomic1 \
      procps \
      net-tools; \
    rm -rf /var/lib/apt/lists/*

# Install Node.js from upstream (deterministic, reproducible)
RUN set -eux; \
    curl -fsSLo /tmp/node.tar.xz "${NODE_DOWNLOAD_URL}"; \
    echo "${NODE_DOWNLOAD_SHA256}  /tmp/node.tar.xz" | sha256sum -c -; \
    tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 --no-same-owner; \
    rm -f /tmp/node.tar.xz; \
    npm install -g "pnpm@${PNPM_VERSION}"; \
    node --version; \
    npm --version; \
    pnpm --version

# Install pnpm global packages into the vscode user's PNPM_HOME
RUN set -eux; \
    mkdir -p /home/vscode/.local/share/pnpm; \
    export PNPM_HOME="/home/vscode/.local/share/pnpm"; \
    export PATH="$PNPM_HOME:$PATH"; \
    pnpm add -g \
      turbo \
      ts-node \
      tsx \
      @anthropic-ai/claude-code \
      supabase; \
    chown -R 1000:1000 /home/vscode/.local

# Install Kubernetes and Terraform tools
RUN set -eux; \
    curl -fsSLo /usr/local/bin/kubectl "https://dl.k8s.io/release/v${KUBECTL_VERSION}/bin/linux/amd64/kubectl"; \
    chmod +x /usr/local/bin/kubectl; \
    kubectl version --client=true --output=yaml >/dev/null; \
    curl -fsSLo /tmp/terraform.zip "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip"; \
    unzip -q /tmp/terraform.zip -d /usr/local/bin; \
    rm -f /tmp/terraform.zip; \
    terraform version | head -n 1

# Install Docker CLI (for Docker-in-Docker workflow)
RUN set -eux; \
    install -m 0755 -d /etc/apt/keyrings; \
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg; \
    chmod a+r /etc/apt/keyrings/docker.gpg; \
    echo "deb [arch="$(dpkg --print-architecture)" signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu \
      "$(. /etc/os-release && echo "$VERSION_CODENAME")" stable" > /etc/apt/sources.list.d/docker.list; \
    apt-get update; \
    apt-get install -y --no-install-recommends docker-ce-cli docker-buildx-plugin docker-compose-plugin; \
    rm -rf /var/lib/apt/lists/*

# Setup user with proper permissions
RUN set -eux; \
    if ! getent group "${USERNAME}" >/dev/null 2>&1; then groupadd --gid "${USER_GID}" "${USERNAME}"; fi; \
    if ! id -u "${USERNAME}" >/dev/null 2>&1; then useradd --uid "${USER_UID}" --gid "${USER_GID}" -m "${USERNAME}"; fi; \
    echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" > "/etc/sudoers.d/${USERNAME}"; \
    chmod 0440 "/etc/sudoers.d/${USERNAME}"; \
    # Add user to docker group for Docker socket access
    groupadd -f docker; \
    usermod -aG docker ${USERNAME}; \
    # Create VS Code and Windsurf server directories with proper ownership
    mkdir -p /home/${USERNAME}/.vscode-server/bin; \
    chown -R ${USER_UID}:${USER_GID} /home/${USERNAME}/.vscode-server; \
    mkdir -p /home/${USERNAME}/.windsurf-server/bin; \
    chown -R ${USER_UID}:${USER_GID} /home/${USERNAME}/.windsurf-server; \
    rm -rf /tmp/* /var/tmp/*; \
    corepack enable

# Health check for container readiness
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node --version && pnpm --version || exit 1

USER ${USERNAME}
WORKDIR /workspaces/ValueOS

# Setup pnpm home and path
ENV PNPM_HOME=/home/vscode/.local/share/pnpm
ENV PATH=${PNPM_HOME}:/usr/local/bin:${PATH}

# NOTE: Do NOT set NODE_OPTIONS=--no-experimental-fetch in this image or in
# devcontainer.json containerEnv. The Windsurf remote server (windsurf-reh)
# uses the Node built-in fetch API; disabling it prevents Cascade and all
# Windsurf AI services from starting inside the container.
