{
  "name": "ValueOS Dev Container",
  "dockerComposeFile": "docker-compose.devcontainer.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/ValueOS",
  "remoteUser": "app",
  "containerUser": "app",
  "shutdownAction": "stopCompose",




  "postCreateCommand": "bash -euo pipefail -c 'bash scripts/dev/setup.sh && bash scripts/check-env.sh' > /tmp/setup.log 2>&1",
  "postStartCommand": "bash scripts/dev/healthcheck-services.sh > /tmp/healthcheck.log 2>&1",

  "remoteEnv": {
    "PNPM_HOME": "/home/app/.local/share/pnpm",
    "PATH": "${containerEnv:PATH}:/home/app/.local/share/pnpm",
    "DOCKER_BUILDKIT": "1",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",

    "SUPABASE_URL": "http://kong:8000",

    "DATABASE_URL": "postgresql://postgres:postgres@db:5432/postgres?sslmode=disable",
    "REDIS_URL": "redis://redis:6379"
  },

  "customizations": {
    "vscode": {
      "settings": {
        "telemetry.telemetryLevel": "off",
        "redhat.telemetry.enabled": false,
        "git.telemetry.telemetryLevel": "off",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "files.trimTrailingWhitespace": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "git.autofetch": true
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "msjsdiag.debugger-for-chrome",
        "eamodio.gitlens",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  }
}
