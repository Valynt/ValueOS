{
  "name": "ValueOS Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "BUILDKIT_INLINE_CACHE": "1"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "workspaceFolder": "/workspaces/ValueOS",
  "remoteUser": "vscode",
  "runArgs": ["--security-opt=seccomp=unconfined", "--security-opt=apparmor=unconfined"],
  "mounts": ["source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"],
  "postCreateCommand": "pnpm install --frozen-lockfile",
  "remoteEnv": {
    "PNPM_HOME": "/home/vscode/.local/share/pnpm",
    "PATH": "${containerEnv:PATH}:/home/vscode/.local/share/pnpm",
    "DOCKER_BUILDKIT": "1",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "telemetry.telemetryLevel": "off",
        "redhat.telemetry.enabled": false,
        "git.telemetry.telemetryLevel": "off"
      }
    }
  }
}
