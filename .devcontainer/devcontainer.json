{
  "name": "ValueOS Development Environment",
  "dockerComposeFile": [
    "../ops/compose/compose.yml",
    "../ops/compose/devcontainer.yml"
  ],
  "service": "dev",
  "shutdownAction": "stopCompose",
  "workspaceFolder": "/workspaces/ValueOS",
  "forwardPorts": [3001, 5173, 5432, 6379, 54323, 54324],
  "portsAttributes": {
    "3001": { "label": "Backend API", "onAutoForward": "notify" },
    "5173": { "label": "Frontend (Vite)", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" },
    "6379": { "label": "Redis", "onAutoForward": "silent" },
    "54323": { "label": "Supabase API", "onAutoForward": "silent" },
    "54324": { "label": "Supabase Studio", "onAutoForward": "silent" }
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "NODE_ENV": "development",
    "NPM_CONFIG_UPDATE_NOTIFIER": "false",
    "NPM_CONFIG_FUND": "false"
  }
}
