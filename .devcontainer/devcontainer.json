{
  "name": "ValueOS",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "workspaceFolder": "/workspaces/ValueOS",
  "forwardPorts": [
    5173,
    5174,
    3001,
    54321,
    54324,
    8025
  ],
  "portsAttributes": {
    "5173": {
      "label": "Frontend (Vite)",
      "onAutoForward": "notify"
    },
    "5174": {
      "label": "VOSAcademy (Vite)",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Backend API",
      "onAutoForward": "notify"
    },
    "54321": {
      "label": "Supabase Kong",
      "onAutoForward": "silent"
    },
    "54324": {
      "label": "Supabase Studio",
      "onAutoForward": "silent"
    },
    "8025": {
      "label": "MailHog Web",
      "onAutoForward": "silent"
    }
  },
  "containerEnv": {
    "NODE_ENV": "development",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0"
  },
  "remoteUser": "node",
  "features": {}
}
