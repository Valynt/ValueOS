{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "ValueOS",
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile",
    "args": {
      "NODE_VERSION": "20.19.5",
      "NODE_SHA256": "315046739a513a70e03a4a55a8afda8cf979f30852e576075c340084e3f8ac0f",
      "PNPM_VERSION": "10.4.1",
      "KUBECTL_VERSION": "1.32.2",
      "KUBECTL_SHA256": "4f6a959dcc5b702135f8354cc7109b542a2933c46b808b248a214c1f69f817ea",
      "TERRAFORM_VERSION": "1.10.5",
      "TERRAFORM_SHA256": "0566a24f5332098b15716ebc394be503f4094acba5ba529bf5eb0698ed5e2a90"
    }
  },
  "workspaceFolder": "/workspaces/ValueOS",
  "remoteUser": "vscode",
  "forwardPorts": [
    5173,
    3001,
    54321,
    54324,
    8025
  ],
  "portsAttributes": {
    "5173": {
      "label": "ValyntApp (Vite)",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Backend API",
      "onAutoForward": "notify"
    },
    "54321": {
      "label": "Supabase Kong",
      "onAutoForward": "silent"
    },
    "54324": {
      "label": "Supabase Studio",
      "onAutoForward": "silent"
    },
    "8025": {
      "label": "MailHog",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "vitest.explorer",
        "redhat.vscode-yaml",
        "cweijan.vscode-postgresql-client2"
      ],
      "settings": {
        "remote.containers.defaultExtensionsIfInstalledLocally": []
      }
    }
  },
  "mounts": [
    "source=valueos-windsurf-server,target=/home/vscode/.windsurf-server,type=volume",
    "source=valueos-vscode-server,target=/home/vscode/.vscode-server,type=volume"
  ],
  "containerEnv": {
    "NODE_ENV": "development",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0"
  },
  "onCreateCommand": "sudo apt-get update -qq && sudo apt-get install -y --no-install-recommends libstdc++6 libgcc-s1 libatomic1 procps net-tools dnsutils && sudo rm -rf /var/lib/apt/lists/*",
  "postCreateCommand": "rm -f ~/.windsurf-server/.installation_lock 2>/dev/null; find ~/.windsurf-server/bin -maxdepth 1 -type d 2>/dev/null | tail -n +2 | head -n -1 | xargs rm -rf 2>/dev/null; echo 'Windsurf server cache pruned'",
  "postStartCommand": "curl -fsS --max-time 5 https://windsurf-stable.codeiumdata.com > /dev/null && echo '[devcontainer] Windsurf CDN reachable' || echo '[devcontainer] WARNING: Windsurf CDN unreachable'"
}
