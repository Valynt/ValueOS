{
  "name": "ValueOS",
  "build": {
    "context": "..",
    "dockerfile": ".devcontainer/Dockerfile.optimized"
  },
  "workspaceFolder": "/workspaces/ValueOS",
  "remoteUser": "vscode",
  "containerEnv": {
    "NODE_ENV": "development",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
    "PNPM_HOME": "/home/vscode/.local/share/pnpm"
  },
  "forwardPorts": [
    5173,
    5174,
    3001
  ],
  "portsAttributes": {
    "5173": {
      "label": "Frontend (Vite)",
      "onAutoForward": "notify"
    },
    "5174": {
      "label": "VOSAcademy (Vite)",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Backend API",
      "onAutoForward": "notify"
    }
  },
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "vitest.explorer",
        "redhat.vscode-yaml",
        "eamodio.gitlens"
      ]
    }
  },
  "mounts": [
    "source=valueos-pnpm-store,target=/home/vscode/.local/share/pnpm,type=volume"
  ]
}
