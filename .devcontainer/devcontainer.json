{
  "name": "ValueCanvas",
  "build": {
    "dockerfile": "Dockerfile.optimized",
    "context": "..",
    "args": {
      "NODE_VERSION": "20",
      "VARIANT": "ubuntu-22.04"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "true"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "remoteUser": "valueos",
  "containerEnv": {
    "NODE_ENV": "development",
    "ENVIRONMENT": "development",
    "NPM_CONFIG_UPDATE_NOTIFIER": "false",
    "NPM_CONFIG_FUND": "false"
  },
  "workspaceFolder": "/workspaces/ValueOS",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/ValueOS,type=bind,consistency=cached",
  "forwardPorts": [
    3000,
    5432,
    54321,
    54323,
    9229
  ],
  "portsAttributes": {
    "3000": {
      "label": "Web (Vite/Next)"
    },
    "5432": {
      "label": "Postgres"
    },
    "54321": {
      "label": "Supabase API/Kong"
    },
    "54323": {
      "label": "Supabase Studio"
    },
    "9229": {
      "label": "Node Debug"
    }
  },
  "onCreateCommand": "bash -lc 'if [ -f .devcontainer/scripts/on-create ]; then bash .devcontainer/scripts/on-create; else echo \"on-create script not found; skipping\"; fi'",
  "postStartCommand": "bash .devcontainer/scripts/post-start"
}
