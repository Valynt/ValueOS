# Base Dockerfile for ValueOS LLM Agents
# Provides common foundation for all agent containers with security hardening

# =============================================================================
# Stage 1: Dependencies
# =============================================================================
FROM node:20.19.0-alpine AS deps
WORKDIR /app

# Install system dependencies
RUN apk add --no-cache \
    libc6-compat \
    python3 \
    python3-dev \
    build-base \
    git \
    make \
    g++ && \
    ln -sf /usr/bin/python3 /usr/bin/python

# Copy workspace package files
COPY package.json pnpm-lock.yaml* pnpm-workspace.yaml ./
COPY packages/agents/package.json ./packages/agents/

# Install dependencies
RUN corepack enable && \
    corepack prepare pnpm@latest --activate && \
    pnpm install --frozen-lockfile --prod=false

# =============================================================================
# Stage 2: Builder
# =============================================================================
FROM node:20.19.0-alpine AS builder
WORKDIR /app

ARG AGENT_NAME
ARG NODE_VERSION=20.19.0

ENV NODE_ENV=production

# Copy dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages ./packages

# Copy agent source
COPY packages/agents/${AGENT_NAME} ./packages/agents/${AGENT_NAME}
COPY packages/shared ./packages/shared

# Build the agent
WORKDIR /app/packages/agents/${AGENT_NAME}
RUN corepack enable && \
    corepack prepare pnpm@latest --activate && \
    pnpm run build

# =============================================================================
# Stage 3: Runtime
# =============================================================================
FROM node:20.19.0-alpine AS runtime
WORKDIR /app

ARG AGENT_NAME
ARG EXPOSE_PORT=8080

ENV NODE_ENV=production \
    AGENT_NAME=${AGENT_NAME} \
    PORT=${EXPOSE_PORT}

# Install runtime dependencies only
RUN apk add --no-cache \
    curl \
    wget \
    tini

# Create non-root user
RUN addgroup -g 1001 -S agent && \
    adduser -S agent -u 1001 -G agent && \
    mkdir -p /app/logs /app/data && \
    chown -R agent:agent /app

# Copy built application
COPY --from=builder --chown=agent:agent /app/packages/agents/${AGENT_NAME}/dist ./dist
COPY --from=builder --chown=agent:agent /app/packages/agents/${AGENT_NAME}/package.json ./
COPY --from=deps --chown=agent:agent /app/node_modules ./node_modules

# Switch to non-root user
USER agent

# Expose port
EXPOSE ${EXPOSE_PORT}

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=60s \
  CMD curl --fail http://localhost:${EXPOSE_PORT}/health || exit 1

# Use tini as entrypoint for proper signal handling
ENTRYPOINT ["/sbin/tini", "--"]

# Start the agent
CMD ["node", "dist/index.js"]
