# Caddyfile for ValueOS Development Environment
# Single ingress entrypoint with path-based routing to internal services.
# Devcontainer-only exception: HTTP is intentionally retained for this local-only
# profile because the stack is exposed on localhost for development and does not
# provision or trust certificates inside the devcontainer.

{
    # Global options
    admin 0.0.0.0:2019
    auto_https off
    log {
        output stdout
        format json
        level INFO
    }
}

# Primary ingress (devcontainer-local only; host-exposed via localhost ports)
:80, :443 {
    # Health check endpoint
    handle /health {
        respond "OK" 200
    }

    # Supabase API via Kong
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy kong:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Supabase Studio
    handle /studio/* {
        uri strip_prefix /studio
        reverse_proxy studio:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Frontend routes
    handle {
        reverse_proxy frontend:3001 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}

            health_uri /
            health_interval 30s
            health_timeout 10s
        }
    }

    # Logging
    log {
        output stdout
        format json
    }
}
