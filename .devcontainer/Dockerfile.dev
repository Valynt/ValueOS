# syntax=docker/dockerfile:1
ARG NODE_VERSION=20.19.0
ARG PNPM_VERSION=9.15.0
ARG KUBECTL_VERSION=1.32.2
ARG TERRAFORM_VERSION=1.11.2

FROM mcr.microsoft.com/devcontainers/base:ubuntu-22.04

ARG NODE_VERSION
ARG PNPM_VERSION
ARG KUBECTL_VERSION
ARG TERRAFORM_VERSION

# Core dev tools (runtime)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    git \
    ca-certificates \
    openssh-client \
    less \
    nano \
    unzip \
    wget \
    lsb-release \
    sudo \
    python3-pip \
    fdupes \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# Node.js (pinned binary + checksum verification)
# NOTE: You must keep NODE_DOWNLOAD_SHA256 in sync with NODE_VERSION.
ENV NODE_VERSION=${NODE_VERSION}
ENV NODE_DISTRO=node-v${NODE_VERSION}-linux-x64
ENV NODE_DOWNLOAD_URL=https://nodejs.org/dist/v${NODE_VERSION}/${NODE_DISTRO}.tar.xz

# Provide a default SHA for the default version. Override at build time if you change NODE_VERSION.
# Example override: --build-arg NODE_DOWNLOAD_SHA256=...
ARG NODE_DOWNLOAD_SHA256=b4e336584d62abefad31baecff7af167268be9bb7dd11f1297112e6eed3ca0d5

ENV PNPM_HOME=/home/vscode/.local/share/pnpm
ENV COREPACK_HOME=/home/vscode/.cache/corepack
ENV XDG_CACHE_HOME=/home/vscode/.cache
ENV PATH=${PNPM_HOME}:${PATH}

RUN set -eux; \
    curl -fsSLo /tmp/node.tar.xz "$NODE_DOWNLOAD_URL"; \
    echo "$NODE_DOWNLOAD_SHA256  /tmp/node.tar.xz" | sha256sum -c -; \
    tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 --no-same-owner; \
    rm -f /tmp/node.tar.xz; \
    node --version; \
    npm --version; \
    corepack enable; \
    corepack prepare "pnpm@${PNPM_VERSION}" --activate; \
    pnpm --version

# Install reproducible infra CLIs
RUN set -eux; \
    curl -fsSLo /usr/local/bin/kubectl "https://dl.k8s.io/release/v${KUBECTL_VERSION}/bin/linux/amd64/kubectl"; \
    chmod +x /usr/local/bin/kubectl; \
    kubectl version --client=true --output=yaml >/dev/null; \
    curl -fsSLo /tmp/terraform.zip "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip"; \
    unzip -q /tmp/terraform.zip -d /usr/local/bin; \
    rm -f /tmp/terraform.zip; \
    terraform version | head -n 1

# Copy ensure-pnpm.js for preinstall
COPY scripts/dx/ensure-pnpm.js ./scripts/dx/ensure-pnpm.js

# Set up user (devcontainer standard: vscode)
ARG USERNAME=vscode
ARG USER_UID=1000
ARG USER_GID=$USER_UID
RUN groupadd --gid $USER_GID $USERNAME \
    && useradd --uid $USER_UID --gid $USER_GID -m $USERNAME \
    && echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME \
    && mkdir -p /home/$USERNAME/.local/share/pnpm /home/$USERNAME/.cache/corepack /home/$USERNAME/.cache \
    && chown -R $USERNAME:$USERNAME /home/$USERNAME/.local /home/$USERNAME/.cache

USER $USERNAME
WORKDIR /workspaces/ValueOS

