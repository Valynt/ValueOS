# Ensure docker group exists and add user to docker group for socket access
RUN if ! getent group docker; then groupadd -g 998 docker; fi \
  && usermod -aG docker node || true
# Optimized Deterministic Dockerfile for ValueOS DevContainers

# =====================
# ValueOS DevContainer Build (with verbose logging)
# =====================
FROM node:20.18.0-bookworm-slim

# Install specific Node.js version 20.18.0
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash
ENV NVM_DIR /root/.nvm
RUN . $NVM_DIR/nvm.sh && nvm install 20.18.0 && nvm use 20.18.0 && nvm alias default 20.18.0
ENV PATH $NVM_DIR/versions/node/v20.18.0/bin:$PATH

# Print base image and environment info
RUN echo "[BUILD-LOG] Base image: mcr.microsoft.com/devcontainers/typescript-node:20" \
  && node --version \
  && npm --version \
  && echo "[BUILD-LOG] UID: $(id -u) GID: $(id -g)" \
  && uname -a


WORKDIR /workspaces/ValueOS


RUN set -ex; \
  echo "[BUILD-LOG] Installing pnpm globally..."; \
  npm install -g pnpm; \
  echo "[BUILD-LOG] pnpm version: $(pnpm --version)";


# Copy workspace definitions for dependency caching
RUN echo "[BUILD-LOG] Copying workspace definition files..." \
  && ls -l /workspaces/ValueOS
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages ./packages
COPY apps/ValyntApp/package.json ./apps/ValyntApp/
COPY scripts ./scripts


RUN set -ex; \
  echo "[BUILD-LOG] Running pnpm install..."; \
  pnpm install --frozen-lockfile; \
  echo "[BUILD-LOG] pnpm install completed with exit code $?";


# Note: Source code is not copied; volume mount handles live editing.
RUN echo "[BUILD-LOG] Build steps completed. Ready for live code mount."


EXPOSE 5173 24678 3001 54321 54323


HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD [ "node", "-e", "process.exit(0)" ]


CMD ["dumb-init", "sleep", "infinity"]
