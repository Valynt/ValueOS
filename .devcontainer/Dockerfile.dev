# syntax=docker/dockerfile:1
FROM mcr.microsoft.com/devcontainers/base:ubuntu-22.04 AS build

# Install build tools in build stage only (kept out of final image for hardening)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    build-essential && \
    rm -rf /var/lib/apt/lists/*

FROM mcr.microsoft.com/devcontainers/base:ubuntu-22.04

# Install core dev tools (runtime) — excludes build-essential which is installed in build stage
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    git \
    ca-certificates \
    openssh-client \
    less \
    nano \
    unzip \
    wget \
    lsb-release \
    sudo \
    python3-pip \
    fdupes \
    && rm -rf /var/lib/apt/lists/*

# Node.js (pinned binary + checksum verification)
ENV NODE_VERSION=20.19.0
ENV NODE_DISTRO=node-v${NODE_VERSION}-linux-x64
ENV NODE_DOWNLOAD_URL=https://nodejs.org/dist/v${NODE_VERSION}/${NODE_DISTRO}.tar.xz
ENV NODE_DOWNLOAD_SHA256=b4e336584d62abefad31baecff7af167268be9bb7dd11f1297112e6eed3ca0d5
RUN set -eux; \
    curl -fsSLo /tmp/node.tar.xz "$NODE_DOWNLOAD_URL"; \
    echo "$NODE_DOWNLOAD_SHA256  /tmp/node.tar.xz" | sha256sum -c -; \
    tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 --no-same-owner; \
    rm -f /tmp/node.tar.xz; \
    node --version; \
    npm --version; \
    npm install -g pnpm
# Copy ensure-pnpm.js for preinstall
COPY scripts/dx/ensure-pnpm.js ./scripts/dx/ensure-pnpm.js

# Set up user (devcontainer standard: vscode)
ARG USERNAME=vscode
ARG USER_UID=1000
ARG USER_GID=$USER_UID
RUN groupadd --gid $USER_GID $USERNAME \
    && useradd --uid $USER_UID --gid $USER_GID -m $USERNAME \
    && echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

USER $USERNAME
WORKDIR /workspaces/ValueOS
