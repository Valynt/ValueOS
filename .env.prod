# Example production environment variables template.
# Copy this file to `.env.prod` locally, fill in real values, and ensure `.env.prod` is gitignored.

PROD_DB_NAME=__PROD_DB_NAME__
PROD_DB_USER=__PROD_DB_USER__
PROD_DB_PASSWORD=__PROD_DB_PASSWORD__
PROD_DATABASE_URL=postgresql://${PROD_DB_USER}:${PROD_DB_PASSWORD}@prod-postgres:5432/${PROD_DB_NAME}

REDIS_PASSWORD=__REDIS_PASSWORD__
PROD_REDIS_URL=redis://:${REDIS_PASSWORD}@prod-redis:6379

PORT=8000
NODE_ENV=production
