# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf

# Declare files that will always have LF line endings on checkout
Dockerfile text eol=lf
*.dockerfile text eol=lf
Makefile text eol=lf
*.mk text eol=lf

# Source code
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.mdx text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Config files
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.env* text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
*.pdf binary
