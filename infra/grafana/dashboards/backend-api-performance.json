{
  "dashboard": {
    "title": "Backend API Performance",
    "tags": [
      "backend",
      "api",
      "observability",
      "latency-classes"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 2,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Requests per Second by Route",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum(rate(valuecanvas_http_requests_total[5m])) by (route, method)",
            "legendFormat": "{{route}} {{method}}",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "min": 0
          }
        }
      },
      {
        "id": 2,
        "title": "Latency Class p95",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "refId": "A",
            "expr": "histogram_quantile(0.95, sum(rate(valuecanvas_http_request_duration_ms_bucket{latency_class=\"interactive\"}[5m])) by (le))",
            "legendFormat": "interactive completion p95",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "refId": "B",
            "expr": "histogram_quantile(0.95, sum(rate(valuecanvas_http_request_duration_ms_bucket{latency_class=\"orchestration\",phase=\"acknowledgment\"}[5m])) by (le))",
            "legendFormat": "orchestration acknowledgment p95",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "refId": "C",
            "expr": "histogram_quantile(0.95, sum(rate(valuecanvas_http_request_duration_ms_bucket{latency_class=\"orchestration\",phase=\"completion\"}[5m])) by (le))",
            "legendFormat": "orchestration completion p95",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 200
                },
                {
                  "color": "red",
                  "value": 3000
                }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "4xx / 5xx Error Rate by Route",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum(rate(valuecanvas_http_requests_total{status_code=~\"4..\"}[5m])) by (route) / sum(rate(valuecanvas_http_requests_total[5m])) by (route)",
            "legendFormat": "{{route}} 4xx",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "refId": "B",
            "expr": "sum(rate(valuecanvas_http_requests_total{status_code=~\"5..\"}[5m])) by (route) / sum(rate(valuecanvas_http_requests_total[5m])) by (route)",
            "legendFormat": "{{route}} 5xx",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 1
          }
        }
      },
      {
        "id": 4,
        "title": "Latency Budget Status",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "refId": "A",
            "expr": "max(histogram_quantile(0.95, sum(rate(valuecanvas_http_request_duration_ms_bucket{latency_class=\"interactive\"}[5m])) by (le)) / 200, histogram_quantile(0.95, sum(rate(valuecanvas_http_request_duration_ms_bucket{latency_class=\"orchestration\",phase=\"acknowledgment\"}[5m])) by (le)) / 200, histogram_quantile(0.95, sum(rate(valuecanvas_http_request_duration_ms_bucket{latency_class=\"orchestration\",phase=\"completion\"}[5m])) by (le)) / 3000)",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 2
          }
        }
      },
      {
        "id": 5,
        "title": "Latency Class Targets",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "refId": "A",
            "expr": "vector(200)",
            "legendFormat": "Interactive completion p95 target (ms)",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "refId": "B",
            "expr": "vector(200)",
            "legendFormat": "Orchestration acknowledgment p95 target (ms)",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "refId": "C",
            "expr": "vector(3000)",
            "legendFormat": "Orchestration completion p95 target (ms)",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ]
      }
    ]
  },
  "folderId": 0,
  "overwrite": true
}
