{
  "dashboard": {
    "id": null,
    "uid": "customer-portal",
    "title": "Customer Portal Analytics",
    "tags": ["customer", "portal", "analytics"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "panels": [
      {
        "id": 1,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "type": "stat",
        "title": "Total Page Views (24h)",
        "targets": [
          {
            "expr": "sum(increase(portal_page_views_total[24h]))",
            "legendFormat": "Page Views",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 100 },
                { "color": "red", "value": 1000 }
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 2,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "type": "stat",
        "title": "Active Sessions",
        "targets": [
          {
            "expr": "count(portal_session_active == 1)",
            "legendFormat": "Active Sessions",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 50 }
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
        "type": "stat",
        "title": "PDF Exports (24h)",
        "targets": [
          {
            "expr": "sum(increase(portal_export_pdf_total[24h]))",
            "legendFormat": "PDF Exports",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 4,
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
        "type": "stat",
        "title": "Excel Exports (24h)",
        "targets": [
          {
            "expr": "sum(increase(portal_export_excel_total[24h]))",
            "legendFormat": "Excel Exports",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 5,
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
        "type": "stat",
        "title": "Email Shares (24h)",
        "targets": [
          {
            "expr": "sum(increase(portal_share_email_total[24h]))",
            "legendFormat": "Email Shares",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 6,
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
        "type": "timeseries",
        "title": "Page Views Over Time",
        "targets": [
          {
            "expr": "rate(portal_page_views_total[5m])",
            "legendFormat": "{{page}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Views/sec",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": true
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 7,
        "gridPos": { "h": 10, "w": 12, "x": 0, "y": 26 },
        "type": "timeseries",
        "title": "Average Session Duration",
        "targets": [
          {
            "expr": "avg(portal_session_duration_seconds)",
            "legendFormat": "Avg Duration",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Seconds",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineInterpolation": "smooth",
              "lineWidth": 2
            },
            "unit": "s"
          }
        }
      },
      {
        "id": 8,
        "gridPos": { "h": 10, "w": 12, "x": 12, "y": 26 },
        "type": "timeseries",
        "title": "Average Time on Page",
        "targets": [
          {
            "expr": "avg(portal_page_duration_seconds) by (page)",
            "legendFormat": "{{page}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisLabel": "Seconds",
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineInterpolation": "smooth",
              "lineWidth": 2
            },
            "unit": "s"
          }
        }
      },
      {
        "id": 9,
        "gridPos": { "h": 10, "w": 12, "x": 0, "y": 36 },
        "type": "piechart",
        "title": "Export Format Distribution",
        "targets": [
          {
            "expr": "sum(portal_export_pdf_total)",
            "legendFormat": "PDF",
            "refId": "A"
          },
          {
            "expr": "sum(portal_export_excel_total)",
            "legendFormat": "Excel",
            "refId": "B"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          },
          "pieType": "pie",
          "tooltip": {
            "mode": "single"
          }
        }
      },
      {
        "id": 10,
        "gridPos": { "h": 10, "w": 12, "x": 12, "y": 36 },
        "type": "bargauge",
        "title": "Top Viewed KPIs",
        "targets": [
          {
            "expr": "topk(10, sum(portal_benchmark_view_total) by (kpi_name))",
            "legendFormat": "{{kpi_name}}",
            "refId": "A"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 11,
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 46 },
        "type": "table",
        "title": "Error Summary",
        "targets": [
          {
            "expr": "sum(increase(portal_error_total[1h])) by (error_code, error_message)",
            "legendFormat": "{{error_code}}: {{error_message}}",
            "refId": "A",
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {},
              "indexByName": {},
              "renameByName": {
                "error_code": "Error Code",
                "error_message": "Error Message",
                "Value": "Count"
              }
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 10 }
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 56 },
        "type": "stat",
        "title": "Token Validation Success Rate",
        "targets": [
          {
            "expr": "sum(increase(portal_token_validation_total{status=\"success\"}[24h])) / sum(increase(portal_token_validation_total[24h])) * 100",
            "legendFormat": "Success Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 90 },
                { "color": "green", "value": 95 }
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 13,
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 56 },
        "type": "stat",
        "title": "Expired Tokens (24h)",
        "targets": [
          {
            "expr": "sum(increase(portal_token_expired_total[24h]))",
            "legendFormat": "Expired Tokens",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 20 }
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 14,
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 56 },
        "type": "stat",
        "title": "Invalid Tokens (24h)",
        "targets": [
          {
            "expr": "sum(increase(portal_token_invalid_total[24h]))",
            "legendFormat": "Invalid Tokens",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 20 }
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 15,
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 64 },
        "type": "heatmap",
        "title": "Session Activity Heatmap",
        "targets": [
          {
            "expr": "sum(increase(portal_session_start_total[1h])) by (hour)",
            "legendFormat": "{{hour}}",
            "refId": "A"
          }
        ],
        "options": {
          "calculate": true,
          "calculation": {},
          "cellGap": 2,
          "color": {
            "exponent": 0.5,
            "fill": "dark-orange",
            "mode": "scheme",
            "reverse": false,
            "scale": "exponential",
            "scheme": "Spectral",
            "steps": 128
          },
          "exemplars": {
            "color": "rgba(255,0,255,0.7)"
          },
          "filterValues": {
            "le": 1e-9
          },
          "legend": {
            "show": true
          },
          "rowsFrame": {
            "layout": "auto"
          },
          "tooltip": {
            "show": true,
            "yHistogram": false
          },
          "yAxis": {
            "axisPlacement": "left",
            "reverse": false
          }
        }
      }
    ],
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": "-- Grafana --",
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    }
  },
  "overwrite": true
}
