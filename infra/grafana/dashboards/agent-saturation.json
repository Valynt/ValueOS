{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.5.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "Agent Saturation & Queue Tuning",
  "uid": "agent-saturation",
  "timezone": "browser",
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(kube_pod_info, namespace)",
        "current": { "text": "valynt-agents", "value": "valynt-agents" },
        "includeAll": false,
        "multi": false
      },
      {
        "name": "agent",
        "type": "custom",
        "query": "opportunity,target,expansion,integrity,realization,financial-modeling,research,company-intelligence,value-mapping,system-mapper,intervention-designer,outcome-engineer,coordinator,value-eval,communicator,benchmark,narrative,groundtruth",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Throttling Ratio (%)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * sum by (pod) (rate(container_cpu_cfs_throttled_periods_total{namespace=\"$namespace\",pod=~\"(${agent:regex})-agent.*\",container!=\"\",container!=\"POD\"}[5m])) / clamp_min(sum by (pod) (rate(container_cpu_cfs_periods_total{namespace=\"$namespace\",pod=~\"(${agent:regex})-agent.*\",container!=\"\",container!=\"POD\"}[5m])), 0.000001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Memory RSS (MiB)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_rss{namespace=\"$namespace\",pod=~\"(${agent:regex})-agent.*\",container!=\"\",container!=\"POD\"}) / 1024 / 1024",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Queue Depth by Agent",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (agent_type) (agent_queue_depth{queue=\"agent-tasks\",agent_type=~\"${agent:regex}\"}) or label_replace(sum by (consumer_group) (redis_stream_length{stream=\"valuecanvas.events\",consumer_group=~\"${agent:regex}\"}), \"agent_type\", \"$1\", \"consumer_group\", \"(.*)\")",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Execution Latency p95 (s)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_fabric_execution_duration_seconds_bucket{agent_type=~\"${agent:regex}\"}[5m])) by (le, agent_type))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
