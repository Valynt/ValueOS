{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "SLO Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": "${SLO_WARN_P95_LATENCY_MS}" },
              { "color": "red", "value": "${SLO_MAX_P95_LATENCY_MS}" }
            ]
          },
          "unit": "ms",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "P95 Latency (target: ${SLO_MAX_P95_LATENCY_MS}ms)",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(valuecanvas_http_request_duration_ms_bucket{service=~\"$service\"}[$interval])) by (le))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": "${SLO_WARN_ERROR_RATE}" },
              { "color": "red", "value": "${SLO_MAX_ERROR_RATE}" }
            ]
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Error Rate (target: < ${SLO_MAX_ERROR_RATE})",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(valuecanvas_http_requests_total{status_code=~\"5..\",service=~\"$service\"}[$interval])) / sum(rate(valuecanvas_http_requests_total{service=~\"$service\"}[$interval]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": "${SLO_WARN_MTTR_MINUTES}" },
              { "color": "red", "value": "${SLO_MAX_MTTR_MINUTES}" }
            ]
          },
          "unit": "m",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "MTTR (target: < ${SLO_MAX_MTTR_MINUTES}min)",
      "type": "stat",
      "targets": [
        {
          "expr": "avg_over_time(valuecanvas_incident_mttr_minutes[24h]) or vector(0)",
          "legendFormat": "MTTR",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "API Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(valuecanvas_http_request_duration_ms_bucket{service=~\"$service\"}[$interval])) by (le, route))",
          "legendFormat": "P50 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(valuecanvas_http_request_duration_ms_bucket{service=~\"$service\"}[$interval])) by (le, route))",
          "legendFormat": "P95 {{route}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(valuecanvas_http_request_duration_ms_bucket{service=~\"$service\"}[$interval])) by (le, route))",
          "legendFormat": "P99 {{route}}",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme", "schemeName": "Oranges" },
          "custom": {
            "fillOpacity": 80,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": {
        "calculate": true,
        "calculation": { "xBuckets": { "mode": "size" } },
        "cellGap": 1,
        "color": { "mode": "scheme", "scheme": "Oranges" },
        "yAxis": { "unit": "ms" }
      },
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "targets": [
        {
          "expr": "sum(increase(valuecanvas_http_request_duration_ms_bucket{service=~\"$service\"}[$interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Error Rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "errors/sec",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "5xx Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(valuecanvas_http_requests_total{status_code=~\"5..\",service=~\"$service\"}[$interval]))",
          "legendFormat": "5xx/sec",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Error Rate by Route",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(valuecanvas_http_requests_total{status_code=~\"5..\",service=~\"$service\"}[$interval])) by (route) / sum(rate(valuecanvas_http_requests_total{service=~\"$service\"}[$interval])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "Errors" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
      "id": 8,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Errors" }]
      },
      "title": "Top Error Routes (1h)",
      "type": "table",
      "targets": [
        {
          "expr": "topk(10, sum(increase(valuecanvas_http_requests_total{status_code=~\"5..\",service=~\"$service\"}[1h])) by (route, method))",
          "legendFormat": "{{method}} {{route}}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "System Resource Pressure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "line" }
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 26 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU Usage %",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$interval])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "line" }
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 26 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Memory Usage %",
      "type": "timeseries",
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "line" }
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 26 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Disk Usage %",
      "type": "timeseries",
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "bytes/sec",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 26 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Network I/O",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[$interval])",
          "legendFormat": "Receive {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[$interval])",
          "legendFormat": "Transmit {{device}}",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 104,
      "title": "Log Stream (Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 35 },
      "id": 13,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Recent Error/Warn Logs",
      "type": "logs",
      "targets": [
        {
          "expr": "{job=\"docker\"} |~ \"(?i)(error|warn)\" | json",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["valueos", "slo", "mission-control"],
  "templating": {
    "list": [
      {
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s",
        "current": { "selected": false, "text": "auto", "value": "$__auto_interval_interval" },
        "hide": 0,
        "label": "Interval",
        "name": "interval",
        "options": [
          { "selected": false, "text": "auto", "value": "$__auto_interval_interval" },
          { "selected": false, "text": "1m", "value": "1m" },
          { "selected": false, "text": "5m", "value": "5m" },
          { "selected": false, "text": "15m", "value": "15m" },
          { "selected": false, "text": "1h", "value": "1h" }
        ],
        "query": "1m,5m,15m,1h",
        "refresh": 2,
        "type": "interval"
      },
      {
        "current": { "selected": false, "text": "valueos-backend", "value": "valueos-backend" },
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": false,
        "name": "service",
        "options": [
          { "selected": true, "text": "valueos-backend", "value": "valueos-backend" }
        ],
        "query": "label_values(valuecanvas_http_requests_total, service)",
        "refresh": 2,
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      },
      {
        "current": { "selected": true, "text": "${SLO_MAX_P95_LATENCY_MS}", "value": "${SLO_MAX_P95_LATENCY_MS}" },
        "hide": 2,
        "label": "SLO Max P95 Latency (ms)",
        "name": "slo_max_p95_latency_ms",
        "query": "${SLO_MAX_P95_LATENCY_MS}",
        "type": "constant"
      },
      {
        "current": { "selected": true, "text": "${SLO_MAX_ERROR_RATE}", "value": "${SLO_MAX_ERROR_RATE}" },
        "hide": 2,
        "label": "SLO Max Error Rate",
        "name": "slo_max_error_rate",
        "query": "${SLO_MAX_ERROR_RATE}",
        "type": "constant"
      },
      {
        "current": { "selected": true, "text": "${SLO_MAX_MTTR_MINUTES}", "value": "${SLO_MAX_MTTR_MINUTES}" },
        "hide": 2,
        "label": "SLO Max MTTR (min)",
        "name": "slo_max_mttr_minutes",
        "query": "${SLO_MAX_MTTR_MINUTES}",
        "type": "constant"
      },
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 2,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "Loki", "value": "loki" },
        "hide": 2,
        "name": "DS_LOKI",
        "options": [],
        "query": "loki",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Mission Control",
  "uid": "valueos-mission-control",
  "version": 1
}
