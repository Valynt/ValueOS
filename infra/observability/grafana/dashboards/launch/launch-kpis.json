{
  "id": null,
  "uid": "launch-kpis",
  "title": "Launch KPIs",
  "tags": ["launch", "kpi", "onboarding", "mesh", "stripe"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Onboarding Success Rate (Provisioning)",
      "description": "Tracks tenant provisioning success vs failure and computes onboarding success rate. Runbook: https://docs.valueos.com/runbooks/onboarding-provisioning-success-rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.98 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(valueos_provisioning_attempts_total{result=\"success\"}[15m])) / clamp_min(sum(rate(valueos_provisioning_attempts_total[15m])), 0.001)",
          "legendFormat": "success rate"
        },
        {
          "refId": "B",
          "expr": "sum(rate(valueos_provisioning_attempts_total{result=\"failure\"}[15m]))",
          "legendFormat": "failure/s"
        },
        {
          "refId": "C",
          "expr": "sum(rate(valueos_provisioning_attempts_total{result=\"failure\"}[15m])) / clamp_min(sum(rate(valueos_provisioning_attempts_total[15m])), 0.001)",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Internal Call Latency (Mesh vs Direct)",
      "description": "Compares p95 internal RPC latency with mesh proxy vs without proxy and visualizes sidecar overhead. Runbook: https://docs.valueos.com/runbooks/internal-call-mesh-latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 15 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(valueos_internal_call_duration_seconds_bucket{proxy_mode=\"mesh\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95 with mesh"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(valueos_internal_call_duration_seconds_bucket{proxy_mode=\"direct\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95 without mesh"
        },
        {
          "refId": "C",
          "expr": "(histogram_quantile(0.95, sum(rate(valueos_internal_call_duration_seconds_bucket{proxy_mode=\"mesh\"}[5m])) by (le)) - histogram_quantile(0.95, sum(rate(valueos_internal_call_duration_seconds_bucket{proxy_mode=\"direct\"}[5m])) by (le))) * 1000",
          "legendFormat": "sidecar overhead"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Stripe Webhook ACK Latency (invoice.created)",
      "description": "Tracks Stripe invoice.created webhook acknowledge latency with 2s SLO threshold. Runbook: https://docs.valueos.com/runbooks/stripe-webhook-ack-latency",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(billing_webhook_ack_latency_seconds_bucket{event_type=\"invoice.created\"}[5m])) by (le))",
          "legendFormat": "p95 ack latency"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum(rate(billing_webhook_ack_latency_seconds_bucket{event_type=\"invoice.created\"}[5m])) by (le))",
          "legendFormat": "p50 ack latency"
        },
        {
          "refId": "C",
          "expr": "2",
          "legendFormat": "SLO threshold (2s)"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "interval",
        "type": "interval",
        "label": "Interval",
        "query": "30s,1m,5m,15m",
        "current": { "text": "5m", "value": "5m" }
      }
    ]
  },
  "annotations": {
    "list": []
  }
}
