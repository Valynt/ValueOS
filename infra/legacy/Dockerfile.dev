FROM node:20.19.0-slim

# Install basic dev tooling
RUN apt-get update && apt-get install -y \
    git \
    ca-certificates \
    curl \
    bash \
    fdupes \
    && rm -rf /var/lib/apt/lists/*

# Enable corepack + pnpm
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# Create non-root user (required by VS Code)
RUN useradd -ms /bin/bash vscode

WORKDIR /workspaces/ValueOS

# Copy devcontainer scripts to a location available before workspace mount
COPY .devcontainer/scripts /opt/devcontainer-scripts
RUN chmod +x /opt/devcontainer-scripts/*.sh

# Keep container alive for VS Code
CMD ["sleep", "infinity"]
