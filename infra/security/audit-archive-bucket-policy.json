{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDeleteAndOverwriteAuditArchive",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion",
        "s3:PutBucketPolicy",
        "s3:BypassGovernanceRetention"
      ],
      "Resource": [
        "arn:aws:s3:::valueos-security-audit-archive",
        "arn:aws:s3:::valueos-security-audit-archive/*"
      ]
    },
    {
      "Sid": "AllowArchiveWriterOnlyWithObjectLock",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::123456789012:role/valueos-audit-archive-writer"
      },
      "Action": [
        "s3:PutObject",
        "s3:PutObjectRetention",
        "s3:PutObjectLegalHold"
      ],
      "Resource": "arn:aws:s3:::valueos-security-audit-archive/immutable/*",
      "Condition": {
        "StringEquals": {
          "s3:object-lock-mode": "COMPLIANCE"
        }
      }
    }
  ]
}
