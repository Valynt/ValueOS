import ./Caddyfile

{$APP_DOMAIN:app.example.com} {
  tls {$TLS_MODE}
  import common_site
  import security_headers_base
  import security_headers_strict
  import access_log

  handle /healthz {
    import healthz
  }

  handle /api/* {
    import api_proxy
  }

  handle {
    import spa_static
  }
}

http://{$APP_DOMAIN:app.example.com} {
  import access_log

  handle /healthz {
    import healthz
  }

  redir https://{host}{uri} 308
}
