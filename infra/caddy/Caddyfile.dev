import ./Caddyfile

https://{$DEV_DOMAIN:localhost} {
  tls internal
  import common_site
  import security_headers_dev
  import access_log

  handle /healthz {
    import healthz
  }

  handle /api/* {
    import api_proxy
  }

  handle {
    import frontend_proxy
  }
}

http://{$DEV_DOMAIN:localhost} {
  import access_log

  handle /healthz {
    import healthz
  }

  redir https://{host}{uri} 308
}
