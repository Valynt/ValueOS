import ./Caddyfile

{
    auto_https off
    admin :2019
}

:80 {
    import common_observability
    import common_security_headers
    import common_compression
    import health_route

    header {
        X-Environment dev
    }

    handle_path /api/* {
        import api_proxy
    }

    handle_path /ws/* {
        import api_proxy
    }

    handle {
        import dev_frontend_proxy
    }

    import common_error_responses
}
