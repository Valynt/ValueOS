#!/usr/bin/env bash

# ValueOS Ops Verify Script
# Validation suite for build context, security, and compliance

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Logging functions
log_info() {
    echo -e "${BLUE}🔍 $1${NC}"
}

log_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

log_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

log_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Validate .dockerignore
validate_dockerignore() {
    log_info "Validating .dockerignore..."

    local dockerignore="$PROJECT_ROOT/.dockerignore"

    if [ ! -f "$dockerignore" ]; then
        log_error ".dockerignore file not found"
        return 1
    fi

    # Check for required exclusions
    local required_exclusions=(
        ".git"
        ".env*"
        "node_modules"
        "*.log"
        ".DS_Store"
        "secrets/"
        ".vscode/"
        ".windsurf/"
        "ops/locks/"
        "*.pem"
        "*.key"
        "*.crt"
    )

    local missing_exclusions=()

    for exclusion in "${required_exclusions[@]}"; do
        if ! grep -q "^${exclusion}" "$dockerignore" && ! grep -q "^${exclusion}/" "$dockerignore"; then
            missing_exclusions+=("$exclusion")
        fi
    done

    if [ ${#missing_exclusions[@]} -gt 0 ]; then
        log_warning "Missing recommended exclusions in .dockerignore:"
        for exclusion in "${missing_exclusions[@]}"; do
            echo "  - $exclusion"
        done
    else
        log_success ".dockerignore contains required exclusions"
    fi

    # Check for potential security issues
    if grep -q "\*\*" "$dockerignore"; then
        log_warning ".dockerignore contains '**' patterns - ensure they don't expose sensitive files"
    fi

    # Validate build context size
    log_info "Analyzing build context size..."

    # Create temporary docker build context simulation
    local temp_context="/tmp/docker-context-$$"
    mkdir -p "$temp_context"

    # Copy files that would be included (simulate docker build context)
    # This is a simplified check - in real docker build, .dockerignore is processed
    if command -v rsync > /dev/null 2>&1; then
        # Use rsync with --exclude-from to simulate docker ignore
        rsync -a --exclude-from="$dockerignore" "$PROJECT_ROOT/" "$temp_context/" 2>/dev/null || true
    else
        # Fallback: simple copy excluding obvious patterns
        cp -r "$PROJECT_ROOT"/* "$temp_context/" 2>/dev/null || true
        # Remove common exclusions manually
        rm -rf "$temp_context/.git" "$temp_context/node_modules" "$temp_context/.env"* 2>/dev/null || true
    fi

    # Calculate context size
    local context_size
    context_size=$(du -sm "$temp_context" 2>/dev/null | cut -f1 || echo "0")

    rm -rf "$temp_context"

    if [ "$context_size" -gt 500 ]; then
        log_warning "Build context is large (${context_size}MB) - consider optimizing .dockerignore"
    else
        log_success "Build context size is reasonable (${context_size}MB)"
    fi

    log_success ".dockerignore validation completed"
}

# Validate Dockerfile security
validate_dockerfile_security() {
    log_info "Validating Dockerfile security practices..."

    local dockerfile_backend="$PROJECT_ROOT/Dockerfile.backend"
    local dockerfile_frontend="$PROJECT_ROOT/Dockerfile.frontend"

    # Check backend Dockerfile
    if [ -f "$dockerfile_backend" ]; then
        # Check for USER directive (non-root)
        if ! grep -q "^USER" "$dockerfile_backend"; then
            log_warning "Dockerfile.backend missing USER directive for non-root execution"
        else
            log_success "Dockerfile.backend uses non-root user"
        fi

        # Check for HEALTHCHECK
        if ! grep -q "^HEALTHCHECK" "$dockerfile_backend"; then
            log_warning "Dockerfile.backend missing HEALTHCHECK directive"
        else
            log_success "Dockerfile.backend has healthcheck"
        fi
    fi

    # Check frontend Dockerfile
    if [ -f "$dockerfile_frontend" ]; then
        if ! grep -q "^USER" "$dockerfile_frontend"; then
            log_warning "Dockerfile.frontend missing USER directive for non-root execution"
        else
            log_success "Dockerfile.frontend uses non-root user"
        fi

        if ! grep -q "^HEALTHCHECK" "$dockerfile_frontend"; then
            log_warning "Dockerfile.frontend missing HEALTHCHECK directive"
        else
            log_success "Dockerfile.frontend has healthcheck"
        fi
    fi

    log_success "Dockerfile security validation completed"
}

# Validate no direct docker build usage in scripts
validate_no_direct_docker_build() {
    log_info "Checking for direct docker build usage in scripts..."

    local script_files
    mapfile -t script_files < <(find "$PROJECT_ROOT" -type f \( -name "*.sh" -o -name "*.bash" -o -name "*.mk" -o -name "Makefile" \) -not -path "*/node_modules/*" -not -path "*/.git/*")

    local found_docker_build=false

    for script in "${script_files[@]}"; do
        if grep -q "docker build" "$script"; then
            log_error "Direct 'docker build' usage found in: $script"
            log_info "  Please use './ops build' instead of direct docker build commands"
            found_docker_build=true
        fi
    done

    # Also check CI workflow files
    local ci_files
    mapfile -t ci_files < <(find "$PROJECT_ROOT/.github" -name "*.yml" -o -name "*.yaml" 2>/dev/null || true)

    for ci_file in "${ci_files[@]}"; do
        if grep -q "docker build" "$ci_file"; then
            log_error "Direct 'docker build' usage found in CI: $ci_file"
            log_info "  Please use './ops build' instead of direct docker build commands"
            found_docker_build=true
        fi
    done

    if [ "$found_docker_build" = false ]; then
        log_success "No direct docker build usage found in scripts and CI"
    else
        return 1
    fi
}

# Main execution
main() {
    local check_dockerignore=true
    local check_security=true
    local check_lockfile=true
    local check_ci_enforcement=true

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --no-dockerignore)
                check_dockerignore=false
                shift
                ;;
            --no-security)
                check_security=false
                shift
                ;;
            --no-lockfile)
                check_lockfile=false
                shift
                ;;
            --no-ci-enforcement)
                check_ci_enforcement=false
                shift
                ;;
            --help|-h)
                echo "Usage: $0 [options]"
                echo ""
                echo "Options:"
                echo "  --no-dockerignore      Skip .dockerignore validation"
                echo "  --no-security          Skip Dockerfile security validation"
                echo "  --no-lockfile           Skip lockfile validation"
                echo "  --no-ci-enforcement     Skip CI enforcement checks"
                echo "  --help, -h             Show this help"
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                echo "Use --help for usage information"
                exit 1
                ;;
        esac
    done

    echo "🔍 ValueOS Ops Verify - Validation Suite"
    echo ""

    local exit_code=0

    if [ "$check_dockerignore" = true ]; then
        if ! validate_dockerignore; then
            exit_code=1
        fi
        echo ""
    fi

    if [ "$check_security" = true ]; then
        if ! validate_dockerfile_security; then
            exit_code=1
        fi
        echo ""
    fi

    if [ "$check_lockfile" = true ]; then
        if ! validate_lockfile; then
            exit_code=1
        fi
        echo ""
    fi

    if [ "$check_ci_enforcement" = true ]; then
        if ! validate_no_direct_docker_build; then
            exit_code=1
        fi
        echo ""
    fi

    if [ $exit_code -eq 0 ]; then
        log_success "All validations passed!"
    else
        log_error "Some validations failed. Please fix the issues above."
    fi

    exit $exit_code
}

# Run if executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
