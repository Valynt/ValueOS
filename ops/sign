#!/usr/bin/env bash

# ValueOS Image Signing Script
# Signs container images with cosign for immutable verification

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging functions
log_info() {
    echo -e "${BLUE}🔐 $1${NC}"
}

log_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

log_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

log_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Load environment
load_env() {
    local env_file="$PROJECT_ROOT/deploy/envs/.env.cosign"
    if [ -f "$env_file" ]; then
        source "$env_file"
    fi

    # Set defaults
    export COSIGN_EXPERIMENTAL=${COSIGN_EXPERIMENTAL:-1}
}

# Show usage
show_usage() {
    echo "Usage: $0 <image> [options]"
    echo ""
    echo "Images:"
    echo "  backend    - Sign backend image"
    echo "  frontend   - Sign frontend image"
    echo "  all        - Sign both images"
    echo "  <custom>   - Sign custom image reference"
    echo ""
    echo "Options:"
    echo "  --verify   - Verify signature after signing"
    echo "  --attach   - Attach signature to image"
    echo "  --key <path> - Use specific key file"
    echo ""
    echo "Examples:"
    echo "  $0 backend"
    echo "  $0 ghcr.io/valueos/backend:latest"
    echo "  $0 all --verify"
}

# Sign image
sign_image() {
    local image_ref="$1"
    local verify_after="${2:-false}"
    local attach_signature="${3:-false}"
    local key_file="${4:-}"

    log_info "Signing image: $image_ref"

    # Check if image exists
    if ! docker image inspect "$image_ref" > /dev/null 2>&1; then
        log_error "Image not found: $image_ref"
        return 1
    fi

    # Prepare cosign command
    local cosign_cmd=("cosign" "sign")

    if [ -n "$key_file" ]; then
        cosign_cmd+=("--key" "$key_file")
    elif [ -n "${COSIGN_KEY_LOCATION:-}" ]; then
        cosign_cmd+=("--key" "$COSIGN_KEY_LOCATION")
    else
        cosign_cmd+=("--key" "$PROJECT_ROOT/ops/keys/cosign.key")
    fi

    if [ "$attach_signature" = true ]; then
        cosign_cmd+=("--attachment" "sbom")
    fi

    cosign_cmd+=("$image_ref")

    # Sign the image
    if "${cosign_cmd[@]}"; then
        log_success "Image signed successfully: $image_ref"

        # Verify if requested
        if [ "$verify_after" = true ]; then
            verify_image "$image_ref" "$key_file"
        fi

        return 0
    else
        log_error "Failed to sign image: $image_ref"
        return 1
    fi
}

# Verify image
verify_image() {
    local image_ref="$1"
    local key_file="${2:-}"

    log_info "Verifying image signature: $image_ref"

    # Prepare cosign verify command
    local cosign_cmd=("cosign" "verify")

    if [ -n "$key_file" ]; then
        cosign_cmd+=("--key" "$key_file")
    elif [ -n "${COSIGN_KEY_LOCATION:-}" ]; then
        cosign_cmd+=("--key" "$COSIGN_KEY_LOCATION")
    else
        cosign_cmd+=("--key" "$PROJECT_ROOT/ops/keys/cosign.key")
    fi

    cosign_cmd+=("$image_ref")

    # Verify the image
    if "${cosign_cmd[@]}"; then
        log_success "Image signature verified: $image_ref"
        return 0
    else
        log_error "Failed to verify image signature: $image_ref"
        return 1
    fi
}

# Get image reference
get_image_ref() {
    local target="$1"
    local version="${APP_VERSION:-latest}"

    case "$target" in
        backend)
            echo "valueos-backend:$version"
            ;;
        frontend)
            echo "valueos-frontend:$version"
            ;;
        *)
            echo "$target"
            ;;
    esac
}

# Main execution
main() {
    local target=""
    local verify_after=false
    local attach_signature=false
    local key_file=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            backend|frontend|all)
                target="$1"
                shift
                ;;
            --verify)
                verify_after=true
                shift
                ;;
            --attach)
                attach_signature=true
                shift
                ;;
            --key)
                key_file="$2"
                shift 2
                ;;
            --help|-h)
                show_usage
                exit 0
                ;;
            *)
                # Assume it's a custom image reference
                target="$1"
                shift
                ;;
        esac
    done

    if [ -z "$target" ]; then
        log_error "No target specified"
        show_usage
        exit 1
    fi

    # Load environment
    load_env

    echo "🔐 ValueOS Image Signing"
    echo "Target: $target"
    echo "Verify: $verify_after"
    echo "Attach: $attach_signature"
    echo ""

    # Check cosign
    if ! command -v cosign > /dev/null 2>&1; then
        log_error "cosign is not installed. Run './ops/scripts/cosign-setup.sh' first."
        exit 1
    fi

    case "$target" in
        all)
            sign_image "$(get_image_ref backend)" "$verify_after" "$attach_signature" "$key_file"
            echo ""
            sign_image "$(get_image_ref frontend)" "$verify_after" "$attach_signature" "$key_file"
            ;;
        *)
            sign_image "$(get_image_ref "$target")" "$verify_after" "$attach_signature" "$key_file"
            ;;
    esac

    echo ""
    log_success "Signing completed!"
}

# Run if executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
