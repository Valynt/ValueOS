# ValueOS canonical local env template
# Copy to:
#   - ops/env/.env.local  (for local mode)
#   - ops/env/.env.docker (for docker mode, if you need docker-specific overrides)
#
# Precedence (highest -> lowest):
#   1) Shell environment variables at runtime
#   2) Mode env file (ops/env/.env.local or ops/env/.env.docker)
#   3) Generated ports file (ops/env/.env.ports)
#   4) Inline defaults in compose / app code
#
# Mode file loading:
#   - dx local mode:  ops/env/.env.local
#   - dx docker mode: ops/env/.env.docker (falls back to inline defaults when absent)

# ------------------------------
# Runtime mode + app ports
# ------------------------------
DX_MODE=local
NODE_ENV=development
API_PORT=8000
VITE_PORT=5173
VITE_HMR_PORT=24678

# Browser-facing frontend URL (used by docs/health checks)
VITE_APP_URL=http://localhost:${VITE_PORT}
# Browser-facing backend URL (used by frontend direct calls in some flows)
BACKEND_URL=http://localhost:${API_PORT}

# CORS origins consumed by backend runtime
# Comma-separated list; include all browser origins that should call the API.
CORS_ALLOWED_ORIGINS=http://localhost:${VITE_PORT}
CORS_ORIGINS=${CORS_ALLOWED_ORIGINS}

# ------------------------------
# Supabase cloud connectivity (required)
# ------------------------------
# Backend/service URL (server-to-server).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Optional explicit internal URL. For Supabase Cloud this usually equals SUPABASE_URL.
SUPABASE_INTERNAL_URL=${SUPABASE_URL}
# Browser/public URL for frontend clients.
SUPABASE_PUBLIC_URL=${SUPABASE_URL}
# Frontend URL used by Vite app.
VITE_SUPABASE_URL=${SUPABASE_PUBLIC_URL}

# Required keys
SUPABASE_ANON_KEY=
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------
# Optional local dependencies
# ------------------------------
# Toggle local Redis usage. If true, REDIS_URL must be present.
ENABLE_REDIS_LOCAL=true
REDIS_URL=redis://:change-me@localhost:${REDIS_PORT}/0

# Toggle local NATS usage. If true, NATS_URL must be present.
ENABLE_NATS_LOCAL=false
NATS_URL=nats://localhost:${NATS_PORT}
NATS_PORT=4222

# ------------------------------
# Local DB (required for local Postgres migrations)
# ------------------------------
DATABASE_URL=postgresql://postgres:change-me@localhost:${POSTGRES_PORT}/valueos_dev?sslmode=disable
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=valueos_dev

# Optional shared secret for local Supabase containers
JWT_SECRET=replace-with-a-long-random-value
