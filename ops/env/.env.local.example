# Canonical ValueOS environment template.
# Copy to one of:
# - ops/env/.env.local      (local mode)
# - ops/env/.env.cloud-dev  (cloud-dev mode)
# - ops/env/.env.test       (test mode)
# - ops/env/.env.prod       (prod mode; usually managed by deployment platform)

# ============================================================
# Canonical mode selector
# ============================================================
# Required. Allowed values: local | cloud-dev | test | prod
APP_ENV=local
NODE_ENV=development

# ============================================================
# Supabase cloud connectivity (required in cloud-dev/test/prod)
# ============================================================
# Required for all app modes except fully-offline local experiments.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Backend-only secret. Never expose this in frontend bundles.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required when running supabase link / hosted workflows.
SUPABASE_PROJECT_REF=your-project-ref

# Canonical Postgres connection string consumed by backend + scripts.
DATABASE_URL=postgresql://valueos_dev:change-me-dev-password@localhost:5432/valueos

# Optional atomics for constructing DATABASE_URL if DATABASE_URL is omitted.
# Mapping: DATABASE_URL=postgresql://${PGUSER}:${PGPASSWORD}@${PGHOST}:${PGPORT}/${PGDATABASE}
PGHOST=localhost
PGPORT=5432
PGDATABASE=valueos
PGUSER=valueos_dev
PGPASSWORD=change-me-dev-password

# ============================================================
# Optional local dependencies
# ============================================================
# Optional. If empty, app should use in-memory fallback or disable related features.
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# ============================================================
# Runtime ports + origins
# ============================================================
FRONTEND_PORT=5173
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:3001
# Comma-separated list consumed by backend CORS middleware.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Frontend consumes this via a bridge layer -> VITE_API_BASE_URL.
API_BASE_URL=http://localhost:3001

# ============================================================
# Kafka (optional — disabled by default)
# ============================================================
# Enable Kafka event streaming. Requires KAFKA_BROKERS when KAFKA_ENABLED=true
# in staging/production. In development, the backend fails open when Kafka is
# unavailable.
# KAFKA_ENABLED=true
# KAFKA_BROKERS=localhost:9092

# ============================================================
# Docker Compose / local overrides
# ============================================================
# Optional compose profile list (comma-separated).
# Use "infra" to start Kafka locally alongside the core Redis service:
#   docker compose --profile infra up
COMPOSE_PROFILES=
