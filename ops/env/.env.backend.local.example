# Backend-only local variables.
# Copy to: ops/env/.env.backend.local

APP_ENV=local
NODE_ENV=development

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://valueos_dev:change-me-dev-password@localhost:5432/valueos
DATABASE_POOL_ROLE=api
DATABASE_EXPECTED_CONCURRENCY=12
# Optional override. Prefer leaving this blank so settings.ts derives the pool max.
# DATABASE_POOL_MAX=6

# Optional local dependencies
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# API_PORT is what Express binds to (settings.ts). BACKEND_PORT is used only for CORS/origin construction.
API_PORT=3001
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Tenant Context Token signing secret (required).
# Leave blank in template; bootstrap tooling provisions a per-developer value.
TCT_SECRET=

# Secrets management (recommended for local/dev)
# Store the client ID/secret in your local-only env file or inject them via `infisical run`.
SECRETS_PROVIDER=infisical
INFISICAL_SITE_URL=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
