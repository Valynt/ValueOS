# Backend-only local variables.
# Copy to: ops/env/.env.backend.local

APP_ENV=local
NODE_ENV=development

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://valueos_dev:change-me-dev-password@localhost:5432/valueos

# Optional local dependencies
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# API_PORT is what Express binds to (settings.ts). BACKEND_PORT is used only for CORS/origin construction.
API_PORT=3001
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
