# ValueOS Production Environment Template
# Copy to .env.production and fill in real values.
# See DEPLOY.md for full deployment instructions.
#
# NEVER commit the filled-in .env.production file to version control.

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=prod
MIGRATIONS_DIR=infra/supabase/supabase/migrations

# ─── Domain / TLS ────────────────────────────────────────────────────────────
APP_DOMAIN=app.yourdomain.com
ACME_EMAIL=ops@yourdomain.com

# ─── Ports ───────────────────────────────────────────────────────────────────
API_PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=8080

# ─── Supabase (from project dashboard → Settings → API) ─────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── Database (Postgres — sslmode=require or stricter) ───────────────────────
DATABASE_URL=postgresql://postgres.your-project-ref:PASSWORD@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require
# App traffic should prefer the Supabase transaction pooler / pgBouncer endpoint.
# Reserve the direct 5432 host for migrations or work that requires session affinity.
DATABASE_POOL_ROLE=api
DATABASE_EXPECTED_CONCURRENCY=8
# Optional override. Prefer leaving this blank so settings.ts derives the pool max.
# DATABASE_POOL_MAX=4

# ─── Redis (must use rediss:// in production) ────────────────────────────────
REDIS_URL=rediss://redis.yourdomain.internal:6379
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_TLS_CA_CERT_PATH=/run/secrets/redis-ca.crt
REDIS_TLS_SERVERNAME=redis.yourdomain.internal

# ─── CORS ────────────────────────────────────────────────────────────────────
# Both variables are required — different parts of the backend read each one.
# CORS_ALLOWED_ORIGINS: read by securityConfig.ts and settings.ts (security middleware)
# CORS_ORIGINS: read by environment.ts (main Express CORS setup via getConfig())
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com

# ─── LLM Providers (optional — leave blank to disable) ──────────────────────
TOGETHER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── LLM Runtime Defaults ───────────────────────────────────────────────────
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_MAX_ATTEMPTS=1
LLM_RETRY_BACKOFF_MS=200

# ─── Auth / Security ────────────────────────────────────────────────────────
# SUPABASE_JWT_SECRET: copy from Supabase dashboard → Project Settings → API → JWT Secret.
# Required by the backend auth middleware and the MCP WebSocket server.
# JWT_SECRET is an alias accepted by both; prefer SUPABASE_JWT_SECRET for clarity.
SUPABASE_JWT_SECRET=
JWT_SECRET=
ENCRYPTION_KEY=
# Confirm disk/volume encryption is active on all production hosts before setting this to true.
# Drives the encryption_at_rest_coverage SOC2/ISO27001 compliance control.
ENCRYPTION_AT_REST_ENABLED=true

# ─── Connection Pooling ─────────────────────────────────────────────────────
PG_POOL_MIN=4
PG_POOL_MAX=40
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000
UV_THREADPOOL_SIZE=8

# ─── Observability (optional) ───────────────────────────────────────────────
ENABLE_TELEMETRY=true
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.yourdomain.internal:4318
# SENTRY_DSN=

# ─── Stripe (optional — leave blank if billing not enabled) ─────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
