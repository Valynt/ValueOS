# Backend-only cloud-dev environment template.
# Copy to: ops/env/.env.backend.cloud-dev
# This file is safe to commit — it contains no secrets.
# See ops/env/README.md for load order and variable ownership.

APP_ENV=cloud-dev
NODE_ENV=development

# Supabase secrets — find these in: Supabase dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_KEY is an alias for SUPABASE_ANON_KEY required by FeatureFlags,
# PromptVersionControl, and MessageQueue. Set to the same value as SUPABASE_ANON_KEY.
SUPABASE_KEY=your-anon-key

# Database — find in: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:6543/postgres
# Cloud-dev uses the Supabase transaction pooler / pgBouncer endpoint (port 6543).
DATABASE_POOL_ROLE=api
DATABASE_EXPECTED_CONCURRENCY=10
# Optional override. Prefer leaving this blank so settings.ts derives the pool max.
# DATABASE_POOL_MAX=5

# Token signing secret — any random string in dev; use a strong secret in staging/prod
TCT_SECRET=change-me

# Web scraper encryption — 32-byte hex key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEB_SCRAPER_ENCRYPTION_KEY=your-32-byte-hex-key

# Ports — API_PORT is what the Express server binds to (settings.ts reads this, not BACKEND_PORT)
# BACKEND_PORT is used only for BACKEND_ORIGIN/CORS construction
API_PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:5173

ENCRYPTION_AT_REST_ENABLED=false
