# ValueOS Environment Variable Reference
# ========================================
# This file lists EVERY environment variable the application reads.
# It is NOT meant to be used directly as an env file. Instead, use the
# environment-specific templates that inherit from this reference:
#
#   ops/env/.env.local.example        -- local development
#   ops/env/.env.staging.template     -- staging
#   ops/env/.env.production.template  -- production
#   ops/env/.env.test.template        -- CI / test
#
# Grouped by concern. Empty values mean "must be provided by the operator".
# Values like "localhost" or "false" are safe development defaults.

# ═══════════════════════════════════════════════════════════════════════════════
# Runtime
# ═══════════════════════════════════════════════════════════════════════════════
# APP_ENV: local | cloud-dev | test | staging | prod
APP_ENV=local
NODE_ENV=development
MIGRATIONS_DIR=infra/supabase/supabase/migrations

# ═══════════════════════════════════════════════════════════════════════════════
# Domain / TLS
# ═══════════════════════════════════════════════════════════════════════════════
APP_DOMAIN=
ACME_EMAIL=
TLS_MODE=

# ═══════════════════════════════════════════════════════════════════════════════
# Ports
# ═══════════════════════════════════════════════════════════════════════════════
API_PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=5173

# ═══════════════════════════════════════════════════════════════════════════════
# Supabase
# ═══════════════════════════════════════════════════════════════════════════════
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_REF=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Database (Postgres)
# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE_URL is canonical. PGHOST/PGPORT/etc are optional atomics.
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=valueos
PGUSER=postgres
PGPASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# Connection Pooling
# ═══════════════════════════════════════════════════════════════════════════════
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000
UV_THREADPOOL_SIZE=4
DATABASE_POOL_MAX=
DATABASE_POOL_IDLE_TIMEOUT_MS=
DATABASE_POOL_CONNECTION_TIMEOUT_MS=
DATABASE_POOL_STATEMENT_TIMEOUT_MS=
DATABASE_POOL_QUERY_TIMEOUT_MS=

# ═══════════════════════════════════════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_TLS_CA_CERT_PATH=
REDIS_TLS_CA_CERT=
REDIS_TLS_SERVERNAME=

# ═══════════════════════════════════════════════════════════════════════════════
# NATS
# ═══════════════════════════════════════════════════════════════════════════════
NATS_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════════════════════════════════════════
# Canonical variable. The app normalises this into both CORS_ALLOWED_ORIGINS
# and CORS_ORIGINS internally via the CORS compatibility shim.
CORS_ALLOWED_ORIGINS=
CORS_ORIGINS=

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend / Vite
# ═══════════════════════════════════════════════════════════════════════════════
FRONTEND_ORIGIN=
BACKEND_ORIGIN=
API_BASE_URL=
VITE_API_BASE_URL=/api
VITE_APP_URL=
VITE_HOST=0.0.0.0
VITE_HMR_HOST=localhost
VITE_HMR_PORT=24678
VITE_HMR_CLIENT_PORT=24678
VITE_USE_POLLING=false
VITE_SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════════
# LLM Providers
# ═══════════════════════════════════════════════════════════════════════════════
TOGETHER_API_KEY=
TOGETHER_API_BASE_URL=
TOGETHER_PRIMARY_MODEL_NAME=
TOGETHER_SECONDARY_MODEL_NAME=
TOGETHER_TIMEOUT_MS=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# LLM Runtime Defaults
# ═══════════════════════════════════════════════════════════════════════════════
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_MAX_ATTEMPTS=1
LLM_RETRY_BACKOFF_MS=200

# ═══════════════════════════════════════════════════════════════════════════════
# Auth / Security
# ═══════════════════════════════════════════════════════════════════════════════
JWT_SECRET=
ENCRYPTION_KEY=
APP_ENCRYPTION_KEY=
ENCRYPTION_AT_REST_ENABLED=false
MFA_ENABLED=false
TCT_SECRET=
WEB_SCRAPER_ENCRYPTION_KEY=
CACHE_ENCRYPTION_ENABLED=false
CACHE_ENCRYPTION_KEY=
CSRF_ENABLED=true
CSP_ENABLED=true
HTTPS_ONLY=false

# ═══════════════════════════════════════════════════════════════════════════════
# Observability
# ═══════════════════════════════════════════════════════════════════════════════
ENABLE_TELEMETRY=false
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=false
GRAFANA_PORT=3000
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════════
# HA / Cluster
# ═══════════════════════════════════════════════════════════════════════════════
INSTANCE_ID=primary
REGION=us-east-1
CLUSTER_NAME=valueos-ha
MAINTENANCE_MODE=false
AUTO_ROLLBACK_ENABLED=true
HEALTH_CHECK_INTERVAL=15
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=3

# ═══════════════════════════════════════════════════════════════════════════════
# CDN
# ═══════════════════════════════════════════════════════════════════════════════
CDN_ENABLED=false
CDN_PROVIDER=
CDN_CACHE_TTL=3600

# ═══════════════════════════════════════════════════════════════════════════════
# Feature Flags
# ═══════════════════════════════════════════════════════════════════════════════
ENABLE_AGENT_FABRIC=true
ENABLE_WORKFLOW=true
ENABLE_COMPLIANCE=true
ENABLE_MULTI_TENANT=false
ENABLE_USAGE_TRACKING=true
ENABLE_BILLING=false

# ═══════════════════════════════════════════════════════════════════════════════
# Billing (Stripe)
# ═══════════════════════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# Alerts / Notifications
# ═══════════════════════════════════════════════════════════════════════════════
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
ALERT_EMAIL_RECIPIENT=

# ═══════════════════════════════════════════════════════════════════════════════
# Docker Compose
# ═══════════════════════════════════════════════════════════════════════════════
COMPOSE_PROFILES=
VALUEOS_NETWORK=valueos-network
