# ValueOS Staging Environment Template
# Copy to .env.staging and fill in real values.
# This template mirrors .env.production.template for environment parity;
# differences are called out with inline comments.
#
# NEVER commit the filled-in .env.staging file to version control.

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=staging
APP_ENV=staging
MIGRATIONS_DIR=infra/supabase/supabase/migrations

# ─── Domain / TLS ────────────────────────────────────────────────────────────
APP_DOMAIN=staging.yourdomain.com
ACME_EMAIL=ops@yourdomain.com
# Use ACME staging CA to avoid rate-limit issues during testing.
TLS_MODE=staging

# ─── Ports ───────────────────────────────────────────────────────────────────
API_PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=8080

# ─── Supabase (from project dashboard -> Settings -> API) ─────────────────────
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── Database (Postgres -- sslmode=require or stricter) ───────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@db.your-staging-project.supabase.co:5432/postgres?sslmode=require

# ─── Redis (must use rediss:// in staging) ────────────────────────────────────
REDIS_URL=rediss://redis.staging.yourdomain.internal:6379
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_TLS_CA_CERT_PATH=/run/secrets/redis-ca.crt
REDIS_TLS_SERVERNAME=redis.staging.yourdomain.internal

# ─── CORS ────────────────────────────────────────────────────────────────────
# Both variables are required -- different parts of the backend read each one.
# The CORS compatibility shim in environment.ts copies CORS_ALLOWED_ORIGINS to
# CORS_ORIGINS automatically, but set both explicitly for clarity.
CORS_ALLOWED_ORIGINS=https://staging.yourdomain.com
CORS_ORIGINS=https://staging.yourdomain.com

# ─── LLM Providers (optional -- leave blank to disable) ──────────────────────
TOGETHER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── LLM Runtime Defaults ───────────────────────────────────────────────────
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_MAX_ATTEMPTS=1
LLM_RETRY_BACKOFF_MS=200

# ─── Auth / Security ────────────────────────────────────────────────────────
SUPABASE_JWT_SECRET=
JWT_SECRET=
ENCRYPTION_KEY=
APP_ENCRYPTION_KEY=
# Set to true when staging host disk encryption is confirmed active.
ENCRYPTION_AT_REST_ENABLED=true
MFA_ENABLED=true
TCT_SECRET=
WEB_SCRAPER_ENCRYPTION_KEY=
CACHE_ENCRYPTION_ENABLED=true
CACHE_ENCRYPTION_KEY=

# ─── Connection Pooling (relaxed vs production) ─────────────────────────────
PG_POOL_MIN=2
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=2000
UV_THREADPOOL_SIZE=4

# ─── Observability ──────────────────────────────────────────────────────────
ENABLE_TELEMETRY=true
LOG_LEVEL=debug
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.staging.yourdomain.internal:4318
# SENTRY_DSN=

# ─── Stripe (optional -- leave blank if billing not enabled) ─────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ─── Staging-specific ───────────────────────────────────────────────────────
# DAST target URL for security scanning in CI.
DAST_TARGET_URL=https://staging.yourdomain.com
