# Staging bootstrap metadata only.
# Do NOT store production-class secrets in this file.

APP_DOMAIN=staging.valueos.app
ACME_EMAIL=ops@example.com
TLS_MODE=staging
BACKEND_PORT=3001
FRONTEND_PORT=8080
CORS_ALLOWED_ORIGINS=https://staging.valueos.app
CORS_ORIGINS=https://staging.valueos.app

# Public/frontend-safe values
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_KEY=your-staging-anon-key
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key
VITE_API_BASE_URL=/api

# Core backend env vars required at process start.
# Use non-production placeholders here and override via real secrets in staging.
DATABASE_URL=postgres://username:password@hostname:5432/database-name
WEB_SCRAPER_ENCRYPTION_KEY=CHANGE_ME_WEB_SCRAPER_ENCRYPTION_KEY
TCT_SECRET=CHANGE_ME_TCT_SECRET

# Managed secret provider metadata
SECRETS_MANAGER_ENABLED=true
SECRETS_PROVIDER=aws
SECRETS_TENANT_ID=platform
AWS_REGION=us-east-1
VAULT_ADDR=
VAULT_NAMESPACE=valuecanvas
VAULT_K8S_ROLE=
SECRETS_MOUNT_PATH=/mnt/secrets
SECRETS_VOLUME_WATCH_ENABLED=true

# Canonical managed secret names
DATABASE_URL_SECRET_NAME=database-url
SUPABASE_SERVICE_ROLE_KEY_SECRET_NAME=supabase-service-key
REDIS_URL_SECRET_NAME=redis-url
JWT_SECRET_SECRET_NAME=jwt-secret
ENCRYPTION_KEY_SECRET_NAME=encryption-key
TOGETHER_API_KEY_SECRET_NAME=together-api-key
OPENAI_API_KEY_SECRET_NAME=openai-api-key
APPROVAL_ACTION_SECRET_SECRET_NAME=approval-action-secret
APPROVAL_WEBHOOK_SECRET_SECRET_NAME=approval-webhook-secret
STRIPE_SECRET_KEY_SECRET_NAME=stripe-secret-key
STRIPE_WEBHOOK_SECRET_SECRET_NAME=stripe-webhook-secret
SENTRY_DSN_SECRET_NAME=sentry-dsn
WEB_SCRAPER_ENCRYPTION_KEY_SECRET_NAME=web-scraper-encryption-key
TCT_SECRET_SECRET_NAME=tct-secret
