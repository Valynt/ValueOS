# Frontend-only cloud-dev environment template.
# Copy to: ops/env/.env.frontend.cloud-dev
# This file is safe to commit — it contains no secrets.
# Must not contain SUPABASE_SERVICE_ROLE_KEY or DATABASE_URL.
# See ops/env/README.md for load order and variable ownership.

APP_ENV=cloud-dev
NODE_ENV=development

# Supabase — find these in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PROJECT_REF=your-project-ref

# Ports and origins — BACKEND_PORT must match API_PORT in ops/env/.env.backend.cloud-dev
FRONTEND_PORT=5173
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:5173
API_BASE_URL=http://localhost:3001
