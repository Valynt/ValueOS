# ValueOS Test Environment Template
# Used by CI pipelines and local test runs.
# Copy to .env.test and adjust if needed.
#
# All values here are safe defaults that allow the test suite to run
# without external services (mock LLM, in-memory Redis fallback, local Postgres).

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=test
APP_ENV=test

# ─── Ports ───────────────────────────────────────────────────────────────────
API_PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=5173

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.test-anon-key-placeholder
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.test-anon-key-placeholder
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.test-service-role-key-placeholder
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.test-anon-key-placeholder

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:test_password@localhost:5432/valueos_test
PGHOST=localhost
PGPORT=5432
PGDATABASE=valueos_test
PGUSER=postgres
PGPASSWORD=test_password

# ─── Redis (in-memory fallback when unavailable) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ─── Auth / Security ────────────────────────────────────────────────────────
SUPABASE_JWT_SECRET=test-jwt-secret-at-least-32-chars-long-for-hs256
JWT_SECRET=test-jwt-secret-at-least-32-chars-long-for-hs256
TCT_SECRET=test-tct-secret
WEB_SCRAPER_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTION_KEY=
MFA_ENABLED=false
ENCRYPTION_AT_REST_ENABLED=false

# ─── LLM (mocked in tests -- keys can be dummy values) ──────────────────────
TOGETHER_API_KEY=test-together-key
OPENAI_API_KEY=test-openai-key
LLM_FALLBACK_ENABLED=false

# ─── Observability (disabled in tests) ──────────────────────────────────────
ENABLE_TELEMETRY=false
PROMETHEUS_ENABLED=false
GRAFANA_ENABLED=false
LOG_LEVEL=error

# ─── Feature Flags ──────────────────────────────────────────────────────────
ENABLE_AGENT_FABRIC=true
ENABLE_WORKFLOW=true
ENABLE_COMPLIANCE=true
ENABLE_MULTI_TENANT=false
ENABLE_USAGE_TRACKING=false
ENABLE_BILLING=false
