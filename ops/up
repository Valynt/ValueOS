#!/usr/bin/env bash

# ValueOS Ops Up Script
# Canonical wrapper for bringing up services with proper build enforcement

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Logging functions
log_info() {
    echo -e "${BLUE}🚀 $1${NC}"
}

log_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

log_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

log_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Load image digests from lockfile
load_digests() {
    local lockfile="$PROJECT_ROOT/ops/locks/images.lock.json"

    if [ ! -f "$lockfile" ]; then
        log_error "Image lockfile not found: $lockfile"
        log_info "Run './ops bootstrap' to create lockfile"
        exit 1
    fi

    if ! jq empty "$lockfile" > /dev/null 2>&1; then
        log_error "Image lockfile is corrupted: $lockfile"
        exit 1
    fi

    log_success "Loaded digests from lockfile"
}

# Check if images are built with ops/build
check_images_built() {
    log_info "Checking if images are built with ./ops build..."

    local backend_built=false
    local frontend_built=false

    # Check if images exist with expected labels
    if docker images --format "table {{.Repository}}:{{.Tag}}\t{{.ID}}" | grep -q "valueos-backend:"; then
        # Check if image has the required OCI labels (indicating built with ops/build)
        if docker inspect "valueos-backend:latest" | jq -e '.[] | select(.Config.Labels["org.opencontainers.image.revision"] != null)' > /dev/null 2>&1; then
            backend_built=true
            log_success "Backend image found and properly labeled"
        else
            log_warning "Backend image exists but missing OCI labels. Was it built with ./ops build?"
        fi
    fi

    if docker images --format "table {{.Repository}}:{{.Tag}}\t{{.ID}}" | grep -q "valueos-frontend:"; then
        if docker inspect "valueos-frontend:latest" | jq -e '.[] | select(.Config.Labels["org.opencontainers.image.revision"] != null)' > /dev/null 2>&1; then
            frontend_built=true
            log_success "Frontend image found and properly labeled"
        else
            log_warning "Frontend image exists but missing OCI labels. Was it built with ./ops build?"
        fi
    fi

    if [ "$backend_built" = false ] || [ "$frontend_built" = false ]; then
        log_warning "Some images are missing or not built with ./ops build"
        log_info "Building missing images..."

        if [ "$backend_built" = false ]; then
            log_info "Building backend..."
            "$SCRIPT_DIR/build" backend
        fi

        if [ "$frontend_built" = false ]; then
            log_info "Building frontend..."
            "$SCRIPT_DIR/build" frontend
        fi

        log_success "Images built successfully"
    fi
}

# Ensure deterministic compose ordering
setup_compose_ordering() {
    log_info "Ensuring deterministic compose service ordering..."

    # Set COMPOSE_PROJECT_NAME for consistent naming
    export COMPOSE_PROJECT_NAME="valueos"

    # Use --no-deps to prevent automatic dependency resolution that can cause ordering issues
    # Services will be started in the order defined in compose file
    export COMPOSE_IGNORE_ORPHANS=true

    log_success "Compose ordering configured"
}

# Main up function
up_services() {
    local detach=${1:-true}

    log_info "Bringing up ValueOS services..."

    # Load digests to ensure lockfile exists
    load_digests

    # Enforce build with ops/build
    check_images_built

    # Setup deterministic ordering
    setup_compose_ordering

    # Determine compose file
    local compose_file="$PROJECT_ROOT/infra/docker/docker-compose.dev.yml"
    if [ ! -f "$compose_file" ]; then
        log_error "Compose file not found: $compose_file"
        exit 1
    fi

    # Build compose command
    local compose_cmd=("docker-compose" "-f" "$compose_file")

    if [ "$detach" = true ]; then
        compose_cmd+=("up" "-d")
    else
        compose_cmd+=("up")
    fi

    log_info "Starting services with deterministic ordering..."

    # Execute compose up
    if "${compose_cmd[@]}"; then
        log_success "Services started successfully"

        if [ "$detach" = true ]; then
            log_info "Services are running in background"
            log_info "Use './ops logs' to view logs"
            log_info "Use './ops down' to stop services"
        fi
    else
        log_error "Failed to start services"
        exit 1
    fi
}

# Main execution
main() {
    local detach=true

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --no-detach|-d)
                detach=false
                shift
                ;;
            --help|-h)
                echo "Usage: $0 [options]"
                echo ""
                echo "Options:"
                echo "  --no-detach, -d    Run in foreground (attached mode)"
                echo "  --help, -h         Show this help"
                echo ""
                echo "This script enforces building images with ./ops build before starting services."
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                echo "Use --help for usage information"
                exit 1
                ;;
        esac
    done

    echo "🚀 ValueOS Ops Up - Service Orchestrator"
    echo "Detach: $detach"
    echo ""

    # Check Docker daemon
    if ! docker info > /dev/null 2>&1; then
        log_error "Docker daemon is not running"
        exit 1
    fi

    # Check docker-compose
    if ! command -v docker-compose > /dev/null 2>&1; then
        log_error "docker-compose is not installed"
        exit 1
    fi

    up_services "$detach"

    echo ""
    log_success "ValueOS services are up and running!"
}

# Run if executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
